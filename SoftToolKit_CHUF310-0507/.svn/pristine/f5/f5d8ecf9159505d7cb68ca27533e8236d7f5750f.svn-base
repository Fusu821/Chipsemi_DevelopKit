class IDelegate
{
public:
	IDelegate(){}
	virtual ~IDelegate(){}

	virtual unsigned int Invoke( NativeTestItem& item ){ return ITEM_STA_NONE; }
};
template<class T>
class CRunTimeMethod : public IDelegate
{
public:
	typedef unsigned int (T::*FunctionTest)( NativeTestItem& item );
	CRunTimeMethod(T* object, FunctionTest method)
		:object_copy(object)
		,method_copy(method)
	{

	}
	virtual ~CRunTimeMethod(){}
	unsigned int Invoke( NativeTestItem& item )
	{
		return (object_copy->*method_copy)( item );
	}
private:
	T* object_copy;
	FunctionTest method_copy;
};
struct InternalItemInfo
{
	unsigned char bSelected;
	NativeTestItem item;
	IDelegate* funAddr;
	bool jumpIfNG;
	InternalItemInfo()
		:funAddr(NULL)
		,bSelected(0)
		,jumpIfNG(true)
	{

	}
	virtual ~InternalItemInfo()
	{
		if(funAddr) delete funAddr;
	}

};
class CTestResultSave
{
	struct StcResult 
	{
		int finalResult;
		unsigned char currentResult;
		StcResult(int final, unsigned char item)
			:finalResult(final)
			,currentResult(item)
		{

		}
		StcResult()
		{

		}
	};
public:
	CTestResultSave()
	{
		m_lock.Lock();
	}
	virtual ~CTestResultSave()
	{
		m_lock.Unlock();
	}

protected:
	void CheckAndCreateFolder( const tstring& strFilePath );
	void ReplaceAllToken( tstring& strSource );
	virtual tstring MakeFileNameToSave( const RecordData& rcDataMsg, unsigned char simulate = 0 );
	virtual tstring MakeRelativePath(unsigned int testRet, InternalItemInfo (&itemResult)[MAX_TEST_ITEMS], LPCTSTR szWorkStation, unsigned char simulate = 0);
	virtual tstring MakeAbsolutePath();
	virtual tstring MakeAbsoluteBackUp();
	
	void MakeOneStatistic( LPCTSTR szSaveFileName, const RecordData& strDataMsg, InternalItemInfo (&itemResult)[MAX_TEST_ITEMS] );
	static SYSTEMTIME StartUpTime();
	BOOL CurrentFailed( InternalItemInfo (&itemResult)[MAX_TEST_ITEMS] );
	void UpDateStatistic( const RecordData& strDataMsg, InternalItemInfo (&itemResult)[MAX_TEST_ITEMS] );
public:
	static void OnAppShutDown();
	static LPCTSTR GetStatisticText();
	virtual void SaveTestResult( const tstring& strContent, const RecordData& rcDataMsg, InternalItemInfo (&itemResult)[MAX_TEST_ITEMS], unsigned char simulate = 0 );
	virtual tstring GetFailReason( InternalItemInfo (&itemResult)[MAX_TEST_ITEMS] );
private:
	static SpinLock m_lock;
	static SYSTEMTIME m_StampTime;
	static SYSTEMTIME m_StartUpTime;
	static map<UINT64, StcResult> m_mapItemStc;
};

