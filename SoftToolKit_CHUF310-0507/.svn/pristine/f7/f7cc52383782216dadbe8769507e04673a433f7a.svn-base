void CTest570::ICArrayToSensorMatrix( unsigned short (&dataMappinged)[2][MAX_MCAP_COL], unsigned short* const dataToMapping, unsigned int dataCnt, unsigned short maxRows, unsigned short* pMaxCols )
{
	for( int iTx = 0; iTx < pCfg570->colsCnt; iTx++ )
	{
		unsigned short icChannel = pCfg570->sensor_2_ic_map[iTx];
		dataMappinged[0][iTx] = dataToMapping[icChannel + MAX_RX_NUM_570];
	}
	for( int iRx = 0; iRx < pCfg570->rowsCnt; iRx++ )
	{
		unsigned short icChannel = pCfg570->sensor_2_ic_map[iRx + MAX_TX_NUM_570];
		dataMappinged[1][iRx] = dataToMapping[icChannel];
	}
}
