		}
		if( ioVols[1][1] < pCfg5816->iic_high_min || ioVols[1][1] > pCfg5816->iic_high_max )
		{
			failerCnt++;
			//transformat( szTemp, _T("scl vol = %d, th = [%d - %d]\r\n"), ioVols[1][1], pCfg5816->iic_high_min, pCfg5816->iic_high_max );
			//TestResultInfo( szTemp );
