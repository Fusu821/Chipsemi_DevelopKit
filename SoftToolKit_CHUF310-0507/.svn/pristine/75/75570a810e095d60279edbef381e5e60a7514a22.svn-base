bool CTest3536::GetHarfScreenNormalizationFactor( const unsigned short (&fastFSDRaw)[MAX_SCAP_ROW][MAX_SCAP_COL], const unsigned short (&slowFSDRaw)[MAX_SCAP_ROW][MAX_SCAP_COL],
	                                              const unsigned short (&fastFSDBase)[MAX_SCAP_ROW][MAX_SCAP_COL], const unsigned short (&slowFSDBase)[MAX_SCAP_ROW][MAX_SCAP_COL], 
												  unsigned char* pRows, int RowsCnt, int cols,
												  double& dFactorFast, double& dFactorSlow )
{
	bool bNormalizationOk = true;
	int iDrops = (cols * RowsCnt >= 12) ? 4 : ((cols * RowsCnt >= 6) ? 2 : 1);
	double fastSum = 0, slowSum = 0, fastBase = 0, slowBase = 0;

	std::list<SortPacket> listHarf; 
	for( int iRow = 0; iRow < RowsCnt; iRow++ )
	{
		for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
		{
			int RealRow = pRows[iRow];
			double dRatio = ( (double)fastFSDRaw[RealRow][iCol] - 710 ) * 100 / ( fastFSDBase[RealRow][iCol] - 710 );
			listHarf.push_back( SortPacket( RealRow, iCol, dRatio ) );
		}
	}

	listHarf.sort();

	for( int index = 0; index < iDrops; index++ )
	{
		listHarf.pop_front();
		listHarf.pop_back();
	}


	TCHAR szTemp[256] = {0};

	for( std::list<SortPacket>::iterator it = listHarf.begin(); it != listHarf.end(); it++ )
	{
		fastSum  += fastFSDRaw[it->dpRow][it->dpCol] - 710;
		fastBase += fastFSDBase[it->dpRow][it->dpCol] - 710;
		slowSum  += slowFSDRaw[it->dpRow][it->dpCol] - 710;
		slowBase += slowFSDBase[it->dpRow][it->dpCol] - 710;
	}

	if( listHarf.size() > 0 && fastBase > 0 && slowBase > 0 )
	{
		dFactorFast = fastBase / fastSum;
		dFactorSlow = slowBase / slowSum;
	}
	else
	{
		bNormalizationOk = false;
		dFactorFast = 1;
		dFactorSlow = 1;
	}

	return bNormalizationOk;
}
double CTest3536::GetHarfScreenNormalization( short (&dataCopy)[MAX_SCAP_ROW][MAX_SCAP_COL], unsigned char* pRows, int RowsCnt  )
{
	double dwDeltaHarfMean = 0;
	std::list<short> listHarf; 

	for( int iRow = 0; iRow < RowsCnt; iRow++ )
	{
		int RealRow = pRows[iRow];
		for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
		{
			listHarf.push_back( dataCopy[RealRow][iCol] );
		}
	}
	listHarf.sort();

	if( abs( *listHarf.begin() ) > abs( *listHarf.rbegin() ) )
	{
		std::list<short>::reverse_iterator it = listHarf.rbegin();
		for( int index = 0; index < pCfg3536->harf_va_channel_num / 2; index++ )
			dwDeltaHarfMean += *it++;

		dwDeltaHarfMean = dwDeltaHarfMean / (pCfg3536->harf_va_channel_num / 2);
	}
	else
	{
		std::list<short>::iterator it = listHarf.begin();

		for( int index = 0; index < pCfg3536->harf_va_channel_num / 2; index++ )
			dwDeltaHarfMean += *it++;

		dwDeltaHarfMean = dwDeltaHarfMean / (pCfg3536->harf_va_channel_num / 2);
	}

	return dwDeltaHarfMean;
}
bool CTest3536::FSDPlusCheckMatched( int (&rcDeviation)[MAX_SCAP_ROW][MAX_SCAP_COL] )
{
	int ColT1[2] = { 0, pCfg3536->colsCnt - 1 };
	for( int iter = 0; iter < 2; iter++ )
	{
		int iCol = ColT1[iter];
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			if( rcDeviation[iRow][iCol] < pCfg3536->fsd.fsdT.fsd_plus_t1 )
			{
				return false;
			}
		}
	}

	int ColT2[2] = { 1, pCfg3536->colsCnt - 2 };
	for( int iter = 0; iter < 2; iter++ )
	{
		int iCol = ColT2[iter];
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			if( rcDeviation[iRow][iCol] < pCfg3536->fsd.fsdT.fsd_plus_t2 )
			{
				return false;
			}
		}
	}

	int ColT3[2] = { pCfg3536->colsCnt / 2 - 1, pCfg3536->colsCnt / 2 + 1 };
	for( int iter = 0; iter < 2; iter++ )
	{
		int iCol = ColT3[iter];
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			if( rcDeviation[iRow][iCol] > pCfg3536->fsd.fsdT.fsd_plus_t3 )
			{
				return false;
			}
		}
	}

	int ColT4[2] = { pCfg3536->colsCnt / 2 };
	for( int iter = 0; iter < 1; iter++ )
	{
		int iCol = ColT4[iter];
		for( int iRow = 0; iRow < 4; iRow++ )
		{
			if( rcDeviation[iRow][iCol] > pCfg3536->fsd.fsdT.fsd_plus_t4 )
			{
				return false;
			}
		}
	}

	int iMiddleCol = pCfg3536->colsCnt / 2;
	if( abs( (long)rcDeviation[1][iMiddleCol] ) < abs( (long)rcDeviation[0][iMiddleCol] ) ){
		return false;
	}
	if( abs( (long)rcDeviation[2][iMiddleCol] ) < abs( (long)rcDeviation[3][iMiddleCol] ) ){
		return false;
	}

	return true;
}
unsigned int CTest3536::FSD_Test( NativeTestItem& itemQuote )
{
	TEST_ITEM_STATUS itemStatus = (TEST_ITEM_STATUS)FSD_TestEx( itemQuote, 1 );

	if( itemStatus == ITEM_STA_FAIL && !GetSimulateGate() )
	{
		itemStatus = (TEST_ITEM_STATUS)FSD_TestEx( itemQuote, 4 );
	}

	return itemStatus;
}
unsigned int CTest3536::FSD_TestEx( NativeTestItem& itemQuote, unsigned char testCnt )
{
	bool bMarkAsTBD = false;
	BOOL bDeviationFail = FALSE;
	unsigned int iReCode = ERROR_CODE_OK, failerCount = 0;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );

	const unsigned char clkCnt = testCnt;
	unsigned short fsdTempBuffer[MAX_SCAP_BUFFER_CNT] = {0};
	unsigned short fastFSDRaw[MAX_SCAP_ROW][MAX_SCAP_COL] = {0}, slowFSDRaw[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};

    short fbTempBuffer1[100] = {0};
	short fbTempBuffer2[100] = {0};
	short fbTempBufferDelta[100] = {0};
	short fbData[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};

	short fsdData[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	short deltaFSD[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};

	unsigned char failed_channel[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	memset( failed_channel, 0, sizeof(failed_channel) );

	TestResultInfo( _T("\r\n------------------------------FSD Test------------------------------\r\n") );
	
	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);
	if( NULL == iChip3536 )         return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	iReCode = iChip3536->GetFSDFastData( pCfg3536->fsd.fsdT.f_clk, pCfg3536->fsd.fsdT.integral, fsdTempBuffer, MAX_SCAP_BUFFER_CNT * sizeof(unsigned short), clkCnt );
	if( ERROR_CODE_OK != iReCode )  return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ICArrayToSensorMatrix( fastFSDRaw, fsdTempBuffer, pCfg3536->va_channel_num, pCfg3536->rowsCnt, pCfg3536->colsCnt );

	iReCode = iChip3536->GetFSDSlowData( pCfg3536->fsd.fsdT.s_clk, pCfg3536->fsd.fsdT.integral, fsdTempBuffer, MAX_SCAP_BUFFER_CNT * sizeof(unsigned short), clkCnt );
	if( ERROR_CODE_OK != iReCode )  return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ICArrayToSensorMatrix( slowFSDRaw, fsdTempBuffer, pCfg3536->va_channel_num, pCfg3536->rowsCnt, pCfg3536->colsCnt );

	if( pCfg3536->fsd.fsdT.fb_check && !GetSimulateGate() )
	{
		iReCode = iChip3536->GetVirtualTouchData( 0x3202, 0x2257, 0x1f07, (unsigned short*)fbTempBuffer1, (unsigned short*)fbTempBuffer2, (pCfg3536->rowsCnt) * pCfg3536->colsCnt * 2 );
		if( ERROR_CODE_OK != iReCode )  return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
		for( int index = 0; index < pCfg3536->rowsCnt * pCfg3536->colsCnt; index++ )
			fbTempBufferDelta[index] = fbTempBuffer1[index] - fbTempBuffer2[index];
	}
// 	//////////////////////////////////////////////////////////////////////////
// 	unsigned short tempBufferF[MAX_SCAP_BUFFER_CNT] = {
// 		1561,1552,1568,1597,1605,1631,1607,	
// 		1535,1560,1560,1575,1603,1616,1656,	
// 		1870,1902,1925,1911,2004,1971,1805,	
// 		1747,1892,1916,1943,1961,1993,1974,
// 	};
// 	ReShappingData( fastFSDRaw, tempBufferF, (unsigned int)pCfg3536->va_channel_num, pCfg3536->rowsCnt, pCfg3536->colsCnt );
// 	unsigned short tempBufferS[MAX_SCAP_BUFFER_CNT] = {
// 		1582,1573,1590,1622,1627,1654,1629,	
// 		1557,1582,1581,1596,1625,1639,1682,	
// 		1897,1933,1955,1941,2035,2003,1831,	
// 		1774,1922,1949,1973,1993,2024,2007,
// 	};
// 	ReShappingData( slowFSDRaw, tempBufferS, (unsigned int)pCfg3536->va_channel_num, pCfg3536->rowsCnt, pCfg3536->colsCnt );
// 	clkCnt = 1;
// 	//////////////////////////////////////////////////////////////////////////
	int offset = 1338;
	int offset_t = 2048 - offset;

	unsigned char RowsUp[MAX_SCAP_ROW] = {0};
	unsigned char RowsDn[MAX_SCAP_ROW] = {0};
	for( int iRow = 0; iRow < pCfg3536->rowsCnt / 2; iRow++ )
	{
		RowsUp[iRow] = iRow;
		RowsDn[iRow] = iRow + pCfg3536->rowsCnt / 2;
	}

	//double dwFastMeanUp = 0, dwFastMeanDown = 0, dwFastBaseUp = 0, dwFastBaseDown = 0;
	//double dwSlowMeanUp = 0, dwSlowMeanDown = 0, dwSlowBaseUp = 0, dwSlowBaseDown = 0;
	double dwFastEfficientUp = 0, dwFastEfficientDn = 0, dwSlowEfficientUp = 0, dwSlowEfficientDn = 0;
	unsigned short fastFSDRawCopy[MAX_SCAP_ROW][MAX_SCAP_COL] = {0}, slowFSDRawCopy[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};

	for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
	{
		for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
		{
			fastFSDRaw[iRow][iCol] /= clkCnt;
			slowFSDRaw[iRow][iCol] /= clkCnt;
		}
	}

	memcpy_s( fastFSDRawCopy, sizeof(fastFSDRawCopy), fastFSDRaw, sizeof(fastFSDRaw) );
	memcpy_s( slowFSDRawCopy, sizeof(slowFSDRawCopy), slowFSDRaw, sizeof(slowFSDRaw) );

	//dwFastMeanUp   = GetHarfScreenSortingMean( fastFSDRawCopy, RowsUp, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;
	//dwFastMeanDown = GetHarfScreenSortingMean( fastFSDRawCopy, RowsDn, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;
	//dwFastBaseUp   = GetHarfScreenSortingMean( pCfg3536->fsd_fast, RowsUp, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;
	//dwFastBaseDown = GetHarfScreenSortingMean( pCfg3536->fsd_fast, RowsDn, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;

	//dwSlowMeanUp   = GetHarfScreenSortingMean( slowFSDRawCopy, RowsUp, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;
	//dwSlowMeanDown = GetHarfScreenSortingMean( slowFSDRawCopy, RowsDn, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;
	//dwSlowBaseUp   = GetHarfScreenSortingMean( pCfg3536->fsd_slow, RowsUp, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;
	//dwSlowBaseDown = GetHarfScreenSortingMean( pCfg3536->fsd_slow, RowsDn, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;

	//double dwFastEfficientUp = dwFastBaseUp / (dwFastMeanUp ? dwFastMeanUp : 1);
	//double dwFastEfficientDn = dwFastBaseDown / (dwFastMeanDown ? dwFastMeanDown : 1);
	//double dwSlowEfficientUp = dwSlowBaseUp / (dwSlowMeanUp ? dwSlowMeanUp : 1);
	//double dwSlowEfficientDn = dwSlowBaseDown / (dwSlowMeanDown ? dwSlowMeanDown : 1);

	GetHarfScreenNormalizationFactor( fastFSDRawCopy, slowFSDRawCopy, pCfg3536->fsd.fsd_fast, pCfg3536->fsd.fsd_slow, RowsUp, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt, dwFastEfficientUp, dwSlowEfficientUp );
	GetHarfScreenNormalizationFactor( fastFSDRawCopy, slowFSDRawCopy, pCfg3536->fsd.fsd_fast, pCfg3536->fsd.fsd_slow, RowsDn, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt, dwFastEfficientDn, dwSlowEfficientDn );

	for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
	{
		for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
		{
			double dwFastEfficient = iRow >= pCfg3536->rowsCnt / 2 ? dwFastEfficientDn : dwFastEfficientUp;
			double dwSlowEfficinet = iRow >= pCfg3536->rowsCnt / 2 ? dwSlowEfficientDn : dwSlowEfficientUp; 

			fastFSDRawCopy[iRow][iCol] = (unsigned short)( ( fastFSDRawCopy[iRow][iCol] - offset_t ) * dwFastEfficient ) + offset_t;
			slowFSDRawCopy[iRow][iCol] = (unsigned short)( ( slowFSDRawCopy[iRow][iCol] - offset_t ) * dwSlowEfficinet ) + offset_t;
			fsdData[iRow][iCol] = slowFSDRawCopy[iRow][iCol] - fastFSDRawCopy[iRow][iCol];
			deltaFSD[iRow][iCol] = fsdData[iRow][iCol] - pCfg3536->fsd.fsd_base[iRow][iCol];
		}
	}

// 	{
// 		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
// 		PrintMaxtrixValue( m_ColorText, fastFSDRawCopy, pCfg3536->invalid_node, info, _T("\r\nFast Nor Data:\r\n") );
// 	}
// 
// 	{
// 		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
// 		PrintMaxtrixValue( m_ColorText, slowFSDRawCopy, pCfg3536->invalid_node, info, _T("\r\nSlow Nor Data:\r\n") );
// 	}

	/********************************************************************************************/
	/*backup test result data*/
	memcpy_s( m_stOneRecord.Scap.fsd_test_buff, sizeof(m_stOneRecord.Scap.fsd_test_buff), fsdData, sizeof(fsdData) );
	memcpy_s( m_stOneRecord.Scap.fsd_fast_buff, sizeof(m_stOneRecord.Scap.fsd_fast_buff), fastFSDRaw, sizeof(fastFSDRaw) );
	memcpy_s( m_stOneRecord.Scap.fsd_slow_buff, sizeof(m_stOneRecord.Scap.fsd_slow_buff), slowFSDRaw, sizeof(slowFSDRaw) );
	/********************************************************************************************/

	{
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
		PrintMaxtrixValue( m_ColorText, slowFSDRaw, pCfg3536->invalid_node, info, _T("\r\nSlow CLK RawData:\r\n") );
	}
	{
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
		PrintMaxtrixValue( m_ColorText, fastFSDRaw, pCfg3536->invalid_node, info, _T("\r\nFast CLK RawData:\r\n") );
	}
	{
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
		unsigned char dataFailChannel[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		memset( dataFailChannel, 0, sizeof(dataFailChannel) );
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				if( ( fsdData[iRow][iCol] < pCfg3536->fsd.fsdT.fsd_min ) 
					/*&& ( abs(fastFSDRaw[iRow][iCol] - 2048) < 20 )*/ 
					/*&& ( abs(slowFSDRaw[iRow][iCol] - 2048) < 20 )*/ )
				{
					failerCount++;
					bDeviationFail = TRUE;	
					dataFailChannel[iRow][iCol] = 1;
				}
			}
		}

		PrintMaxtrixValue( m_ColorText, fsdData, dataFailChannel, pCfg3536->invalid_node, info, _T("\r\nFSD Data:\r\n") );
	}

	//case 0
	if(pCfg3536->fsd.fsdT.scale_check)
	{
		if( dwFastEfficientUp <= 0.5 || dwFastEfficientUp >= 1.5 )
		{
			failerCount++;
			bDeviationFail = TRUE;	
		}
		if( dwFastEfficientDn <= 0.5 || dwFastEfficientDn >= 1.5 )
		{
			failerCount++;
			bDeviationFail = TRUE;
		}
		if( dwSlowEfficientUp <= 0.5 || dwSlowEfficientUp >= 1.5 )
		{
			failerCount++;
			bDeviationFail = TRUE;
		}
		if( dwSlowEfficientDn <= 0.5 || dwSlowEfficientDn >= 1.5 )
		{
			failerCount++;
			bDeviationFail = TRUE;
		}
		if( failerCount )
		{
			TCHAR chTemp[256] = {0};
			transformat( chTemp, _T("\r\nfast coefficient up = %.3f, fast coefficient dn = %.3f, slow coefficient up = %.3f, slow coefficient dn = %.3f\r\n"), 
				dwFastEfficientUp, dwFastEfficientDn, dwSlowEfficientUp, dwSlowEfficientDn );
			ColorText text( chTemp, RGB( 255, 0, 0 ), TEXT_SIZE_SMALL, false );
			TestResultInfo( text );
		}
	}

	//case 1
	short slowRc[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	short fastRc[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};

	for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
	{
		for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
		{
			slowRc[iRow][iCol] = slowFSDRawCopy[iRow][iCol] - offset_t;
			if( 0 == slowRc[iRow][iCol] ) slowRc[iRow][iCol] = 1;

			fastRc[iRow][iCol] = fastFSDRawCopy[iRow][iCol] - offset_t;
			if( 0 == fastRc[iRow][iCol] ) fastRc[iRow][iCol] = 1;
		}
	}

	
	short fsdDataCopy1[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	double data_r[MAX_SCAP_ROW][MAX_SCAP_COL], data_t_r[MAX_SCAP_ROW][MAX_SCAP_COL];

	memcpy_s( fsdDataCopy1, sizeof(fsdDataCopy1), fsdData, sizeof(fsdData) );
	for( int iCol = 0; /*pCfg3536->bVerticalTriangle &&*/ iCol < pCfg3536->colsCnt; iCol++ )
	{
		short baseDel = 0;
		baseDel = pCfg3536->fsd.fsd_base[0 + 1][iCol] - pCfg3536->fsd.fsd_base[0][iCol];
		fsdDataCopy1[0][iCol] += baseDel;

		baseDel = pCfg3536->fsd.fsd_base[pCfg3536->rowsCnt - 2][iCol] - pCfg3536->fsd.fsd_base[pCfg3536->rowsCnt -1][iCol];
		fsdDataCopy1[pCfg3536->rowsCnt -1][iCol] += baseDel;
	}

	if( pCfg3536->bVerticalTriangle )
	{
		VerTriangleCompareDataCalc( slowRc, data_r );
		VerTriangleCompareDataCalc( fsdDataCopy1, data_t_r );
	}
	else
	{
		HorTriangleCompareDataCalc( slowRc, data_r );
		HorTriangleCompareDataCalc( fsdDataCopy1, data_t_r );
	}

	int datar_r_cmp[MAX_SCAP_ROW][MAX_SCAP_COL];
	double nbChannelCoef[MAX_SCAP_ROW][MAX_SCAP_COL];
	for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow += 2 )
	{
		for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
		{
			int iUpDownDev = abs( fsdDataCopy1[iRow][iCol] - fsdDataCopy1[iRow + 1][iCol] );
			iUpDownDev = iUpDownDev ? iUpDownDev : 1;
			nbChannelCoef[iRow][iCol] = ((double)iUpDownDev) * 2 / 10;

			if(iCol == 0 || iCol == (pCfg3536->colsCnt - 1))
			{
				nbChannelCoef[iRow][iCol] /= 3;
			}
			nbChannelCoef[iRow + 1][iCol] = nbChannelCoef[iRow][iCol];
		}
	}

	for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
	{
		for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
		{
			datar_r_cmp[iRow][iCol] = (int)( 1000 * ( data_r[iRow][iCol] / data_t_r[iRow][iCol] - 1 ) * nbChannelCoef[iRow][iCol] );
		}
	}

	{
		NodeVal nodeOutRange;
		ColorText textTemp( _T("\r\nFSD CMP:\r\n") );
		AnalyzeInfo info( pCfg3536->bVerticalTriangle ? pCfg3536->rowsCnt : 1, pCfg3536->colsCnt );
		int cmp_min[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		int cmp_max[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		FillMatrixUseValue( cmp_min, -(int)(3 * pCfg3536->fsd.fsdT.cmp_max) );
		FillMatrixUseValue( cmp_max, (int)pCfg3536->fsd.fsdT.cmp_max );

		bool bResult = AnalyzeTestResult( datar_r_cmp, cmp_min, cmp_max, pCfg3536->invalid_node, info, textTemp, nodeOutRange );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in FSD CMP: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
			MarkNodeToMatrix( &nodeOutRange, failed_channel );
			failerCount++;
		}
	}

	//case 2
	double dwDeltaUpMean = 0, dwDeltaDownMean = 0;
	short fsdDeltaCopy2[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	memcpy_s( fsdDeltaCopy2, sizeof(fsdDeltaCopy2), deltaFSD, sizeof(deltaFSD) );

	//dwDeltaUpMean = ( Sum( fsdDeltaCopy[0], pCfg3536->colsCnt ) + Sum( fsdDeltaCopy[1], pCfg3536->colsCnt ) ) / pCfg3536->harf_va_channel_num;
	//dwDeltaDownMean =( Sum( fsdDeltaCopy[2], pCfg3536->colsCnt ) + Sum( fsdDeltaCopy[3], pCfg3536->colsCnt ) ) / pCfg3536->harf_va_channel_num;

	dwDeltaUpMean = GetHarfScreenNormalization( fsdDeltaCopy2, RowsUp, pCfg3536->rowsCnt / 2 );
	dwDeltaDownMean = GetHarfScreenNormalization( fsdDeltaCopy2, RowsDn, pCfg3536->rowsCnt / 2 );

	for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
	{
		for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
		{
			int fsdDeltaFixed = 0;
			if( iRow < pCfg3536->rowsCnt / 2 )
				fsdDeltaFixed = fsdDeltaCopy2[iRow][iCol] - (int)dwDeltaUpMean;
			else
				fsdDeltaFixed = fsdDeltaCopy2[iRow][iCol] - (int)dwDeltaDownMean;

			fsdDeltaCopy2[iRow][iCol] = abs( fsdDeltaFixed );
		}
	}

	{
		NodeVal nodeOutRange;
		ColorText textTemp( _T("\r\nFSD Delta:\r\n") );
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
		int delta_min[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		FillMatrixUseValue( delta_min, 0 );

		bool bResult = AnalyzeTestResult( fsdDeltaCopy2, delta_min, pCfg3536->fsd.fsd_delta_max, pCfg3536->invalid_node, info, textTemp, nodeOutRange );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in FSD Delta: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
			MarkNodeToMatrix( &nodeOutRange, failed_channel );
			failerCount++;
		}
	}

	//case 3
	//normalization
	short fsdDataCopy3[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	memcpy_s( fsdDataCopy3, sizeof(fsdDataCopy3), fsdData, sizeof(fsdData) );
	for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
	{
		{
			int iCol = 0;
			double dwNormalization = (double)pCfg3536->fsd.fsd_base[iRow][iCol+1] / ( (pCfg3536->fsd.fsd_base[iRow][iCol] == 0) ? 0.001 : pCfg3536->fsd.fsd_base[iRow][iCol] );
			fsdDataCopy3[iRow][iCol] =  (short)( dwNormalization * fsdDataCopy3[iRow][iCol] );
		}
		{
			int iCol = pCfg3536->colsCnt - 1;
			double dwNormalization = (double)pCfg3536->fsd.fsd_base[iRow][iCol-1] / ( (pCfg3536->fsd.fsd_base[iRow][iCol] == 0) ? 0.001 : pCfg3536->fsd.fsd_base[iRow][iCol] );
			fsdDataCopy3[iRow][iCol] = (short)( dwNormalization * fsdDataCopy3[iRow][iCol] );
		}
	}
	{
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
		PrintMaxtrixValue( m_ColorText, fsdDataCopy3, pCfg3536->invalid_node, info, _T("\r\nNormalization:\r\n") );
	}

	{
		NodeVal nodeOutRange;
		ColorText textTemp( _T("\r\nFSD Delta Uniformity Left:\r\n") );
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
		int pannel_left_min[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		int pannel_left_val[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		unsigned char invalidTemp[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		CopyAndInvalid( invalidTemp, pCfg3536->invalid_node, MAX_SCAP_ROW,  0 );
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 1; iCol < pCfg3536->colsCnt; iCol++ )
			{
				pannel_left_val[iRow][iCol] = abs( fsdDataCopy3[iRow][iCol] - fsdDataCopy3[iRow][iCol - 1] );
			}
		}

		bool bResult = AnalyzeTestResult( pannel_left_val, pannel_left_min, pCfg3536->fsd.fsd_uniformity_left, invalidTemp, info, textTemp, nodeOutRange );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in FSD Delta Uniformity Left: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
			MarkNodeToMatrix( &nodeOutRange, failed_channel );
			failerCount++;
		}
	}

	{
		NodeVal nodeOutRange;
		ColorText textTemp( _T("\r\nFSD Delta Uniformity Right:\r\n") );
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
		int pannel_right_min[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		int pannel_right_val[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		unsigned char invalidTemp[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		CopyAndInvalid( invalidTemp, pCfg3536->invalid_node, MAX_SCAP_ROW, pCfg3536->colsCnt - 1 );
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt - 1; iCol++ )
			{
				pannel_right_val[iRow][iCol] = abs( fsdDataCopy3[iRow][iCol]- fsdDataCopy3[iRow][iCol + 1] );
			}
		}

		bool bResult = AnalyzeTestResult( pannel_right_val, pannel_right_min, pCfg3536->fsd.fsd_uniformity_right, invalidTemp, info, textTemp, nodeOutRange );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in FSD Delta Uniformity Right: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
			MarkNodeToMatrix( &nodeOutRange, failed_channel );
			failerCount++;
		}
	}

	//case 4
	int rcSlowDeviation[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	{
		/*unsigned*/ short baseSlowRc[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				baseSlowRc[iRow][iCol] = pCfg3536->fsd.fsd_slow[iRow][iCol] - offset_t;
				if( 0 == baseSlowRc[iRow][iCol] ) baseSlowRc[iRow][iCol] = 1;

				rcSlowDeviation[iRow][iCol] = baseSlowRc[iRow][iCol] - slowRc[iRow][iCol];
			}
		}

		double dwMeanUp = 0, dwMeanDown = 0;
		dwMeanUp = GetHarfScreenSortingMean( rcSlowDeviation, RowsUp, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt );
		dwMeanDown = GetHarfScreenSortingMean( rcSlowDeviation, RowsDn, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt );
// 		if( pCfg3536->bVerticalTriangle )
// 		{
// // 			for( int iRow = 0; iRow < pCfg3536->rowsCnt / 2; iRow++ )
// // 			{
// // 				dwMeanUp += Sum( rcSlowDeviation[iRow], pCfg3536->colsCnt );
// // 				dwMeanDown = Sum( rcSlowDeviation[iRow + pCfg3536->rowsCnt / 2], pCfg3536->colsCnt );
// // 			}
// // 			dwMeanUp /= pCfg3536->harf_va_channel_num;
// // 			dwMeanDown /= pCfg3536->harf_va_channel_num;
// 		}
// 		else
// 		{
// // 			for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
// // 				dwMeanUp += Sum( rcSlowDeviation[iRow], pCfg3536->colsCnt );
// // 
// // 			dwMeanDown = dwMeanUp = dwMeanUp / pCfg3536->va_channel_num;
// 		}
		
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				if( iRow < pCfg3536->rowsCnt / 2 )
					rcSlowDeviation[iRow][iCol] = rcSlowDeviation[iRow][iCol] - (int)dwMeanUp;
				else 
					rcSlowDeviation[iRow][iCol] = rcSlowDeviation[iRow][iCol] - (int)dwMeanDown;

				rcSlowDeviation[iRow][iCol] = 1000 * rcSlowDeviation[iRow][iCol] / baseSlowRc[iRow][iCol]; 
			}
		}
		NodeVal nodeOutRange;
		ColorText textTemp( _T("\r\nFSD Deviation:\r\n") );
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
		int deviation_min[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				deviation_min[iRow][iCol] = (-3) * pCfg3536->fsd.fsd_deviation[iRow][iCol];
			}
		}
		bool bResult = AnalyzeTestResult( rcSlowDeviation, deviation_min, pCfg3536->fsd.fsd_deviation, pCfg3536->invalid_node, info, textTemp, nodeOutRange );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in FSD Deviation Test: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
			MarkNodeToMatrix( &nodeOutRange, failed_channel );
			failerCount++;
			bDeviationFail = TRUE;
		}
	}

	//case 5
	int rcFastDeviation[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	{
		/*unsigned*/ short baseFastRc[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				baseFastRc[iRow][iCol] = pCfg3536->fsd.fsd_fast[iRow][iCol] - offset_t;
				if( 0 == baseFastRc[iRow][iCol] ) baseFastRc[iRow][iCol] = 1;

				rcFastDeviation[iRow][iCol] = baseFastRc[iRow][iCol] - fastRc[iRow][iCol];
			}
		}
		double dwMeanUp = 0, dwMeanDown = 0;
		dwMeanUp = GetHarfScreenSortingMean( rcFastDeviation, RowsUp, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt );
		dwMeanDown = GetHarfScreenSortingMean( rcFastDeviation, RowsDn, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt );
		//dwMeanUp = (double)( Sum( rcFastDeviation[0], pCfg3536->colsCnt ) + Sum( rcFastDeviation[1], pCfg3536->colsCnt ) ) / pCfg3536->harf_va_channel_num;
		//dwMeanDown = (double)( Sum( rcFastDeviation[2], pCfg3536->colsCnt ) + Sum( rcFastDeviation[3], pCfg3536->colsCnt ) ) / pCfg3536->harf_va_channel_num;
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				if( iRow < pCfg3536->rowsCnt / 2 )
					rcFastDeviation[iRow][iCol] = rcFastDeviation[iRow][iCol] - (int)dwMeanUp;
				else 
					rcFastDeviation[iRow][iCol] = rcFastDeviation[iRow][iCol] - (int)dwMeanDown;

				rcFastDeviation[iRow][iCol] = 1000 * rcFastDeviation[iRow][iCol] / baseFastRc[iRow][iCol]; 
			}
		}
	}

	{
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
		PrintMaxtrixValue( m_ColorText, rcFastDeviation, pCfg3536->invalid_node, info, _T("\r\nFast Deviation:\r\n") );
	}

	//case 6  打补丁放水
	if( !bDeviationFail && failerCount > 0 )
	{
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				//int index = iRow * pCfg3536->colsCnt + iCol;
				int asbDeltaFSD = fsdDeltaCopy2[iRow][iCol];
				if( (asbDeltaFSD >= pCfg3536->fsd.fsdT.fsd_triger_min)
					&& (asbDeltaFSD <= pCfg3536->fsd.fsdT.fsd_triger_max)
					&& (rcSlowDeviation[iRow][iCol] >= pCfg3536->fsd.fsdT.fsd_critical_slow_min)
					&& (rcSlowDeviation[iRow][iCol] <= pCfg3536->fsd.fsdT.fsd_critical_slow_max) 
					&& (rcFastDeviation[iRow][iCol] <= pCfg3536->fsd.fsdT.fsd_critical_fast_max) )
				{
					failed_channel[iRow][iCol] = 0;
					for( int iRow2 = 0; iRow2 < pCfg3536->rowsCnt; iRow2++ )
					{
						if( abs( fsdDeltaCopy2[iRow2][iCol] ) < pCfg3536->fsd.fsdT.fsd_besides_min )
							failed_channel[iRow2][iCol] = 0;
					}
					int iLeft  =  iCol == 0 ? 0 : iCol - 1;
					int iRight = iCol == (pCfg3536->colsCnt - 1) ?  (pCfg3536->colsCnt - 1) : iCol + 1;
					if( abs( (long)fsdDeltaCopy2[iRow * pCfg3536->colsCnt + iLeft] ) < pCfg3536->fsd.fsdT.fsd_besides_min )
					{
						failed_channel[iRow][iLeft] = 0;
					}
					if( abs( (long)fsdDeltaCopy2[iRow * pCfg3536->colsCnt + iRight] ) < pCfg3536->fsd.fsdT.fsd_besides_min )
					{
						failed_channel[iRow][iRight] = 0;
					}
				}
			}
		}

		failerCount = Sum( failed_channel[0], pCfg3536->colsCnt ) + Sum( failed_channel[1], pCfg3536->colsCnt ) + Sum( failed_channel[2], pCfg3536->colsCnt ) + Sum( failed_channel[3], pCfg3536->colsCnt );
		if( failerCount > 0 )
		{

		}
		else
		{
			bMarkAsTBD = pCfg3536->fsd.fsdT.fsd_recheck ? false : true;
		}
	}
	
	//cast 7  
	if( !failerCount && pCfg3536->fsd.fsdT.fsd_plus_check )
	{
		bool plus_feature_match = FSDPlusCheckMatched( rcSlowDeviation );
		if( plus_feature_match )
		{
			failerCount++;
			for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
			{
				failed_channel[iRow][0] = 1;
				failed_channel[iRow][pCfg3536->colsCnt - 1] = 1;
				failed_channel[iRow][1] = 1;
				failed_channel[iRow][pCfg3536->colsCnt - 2] = 1;
				failed_channel[iRow][pCfg3536->colsCnt / 2] = 1;
			}
		}
	}

	//case 8
	if( pCfg3536->fsd.fsdT.fb_check && !GetSimulateGate() )
	{
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
		ReShappingData<short>( fbData, fbTempBuffer1, pCfg3536->va_channel_num, pCfg3536->rowsCnt, pCfg3536->colsCnt );
		PrintMaxtrixValue( m_ColorText, fbData, pCfg3536->invalid_node, info, _T("\r\nFB RawData1:\r\n") );
		ReShappingData<short>( fbData, fbTempBuffer2, pCfg3536->va_channel_num, pCfg3536->rowsCnt, pCfg3536->colsCnt );
		PrintMaxtrixValue( m_ColorText, fbData, pCfg3536->invalid_node, info, _T("\r\nFB RawData2:\r\n") );
		ReShappingData<short>( fbData, fbTempBufferDelta, pCfg3536->va_channel_num, pCfg3536->rowsCnt, pCfg3536->colsCnt );
		PrintMaxtrixValue( m_ColorText, fbData, pCfg3536->invalid_node, info, _T("\r\nFB Data:\r\n") );

		NodeVal nodeOutRange;
		int fb_min[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		int fb_max[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		ColorText textTemp( _T("\r\nFB Delta:\r\n") );
		FillMatrixUseValue( fb_min, (int)pCfg3536->fsd.fsdT.fb_min );
		FillMatrixUseValue( fb_max, (int)pCfg3536->fsd.fsdT.fb_max );
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
				fbData[iRow][iCol] = fbData[iRow][iCol] - pCfg3536->fsd.fsdT.fb_base;
		}
		bool bResult = AnalyzeTestResult( fbData, fb_min, fb_max, pCfg3536->invalid_node, info, textTemp, nodeOutRange );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in FB Delta: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
			MarkNodeToMatrix( &nodeOutRange, failed_channel );
			failerCount++;
		}
	}

	if( pCfg3536->fsd.fsdT.fsd_recheck || pCfg3536->fsd.fsdT.fsd_plus_check )
	{
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
		PrintMaxtrixValue( m_ColorText, rcSlowDeviation, failed_channel, pCfg3536->invalid_node, info, _T("\r\nFSD Redjuge:\r\n") );
	}

	if( failerCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//FSD Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		if( bMarkAsTBD )
		{
			itemNotify.UpdateItemResult( ITEM_STA_TBD );
			TestResultInfo( "\r\n\r\n//FSD Test is TBD\r\n", ITEM_STA_TBD );
		}
		else
		{
			itemNotify.UpdateItemResult( ITEM_STA_PASS );
			TestResultInfo( "\r\n\r\n//FSD Test is Pass\r\n", ITEM_STA_PASS );
		}	
	}

	return itemNotify;
}
unsigned int CTest3536::FSDBK_Test( NativeTestItem& itemQuote )
{
	TEST_ITEM_STATUS itemStatus = (TEST_ITEM_STATUS)FSDBK_TestEx( itemQuote, 1 );

	if( itemStatus == ITEM_STA_FAIL && !GetSimulateGate() )
	{
		itemStatus = (TEST_ITEM_STATUS)FSDBK_TestEx( itemQuote, 4 );
	}

	return itemStatus;
}
unsigned int CTest3536::FSDBK_TestEx( NativeTestItem& itemQuote, unsigned char testCnt )
{
	bool bMarkAsTBD = false;
	BOOL bDeviationFail = FALSE;
	unsigned int iReCode = ERROR_CODE_OK, failerCount = 0;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );

	const unsigned char clkCnt = testCnt;
	unsigned short fsdTempBuffer[MAX_SCAP_BUFFER_CNT] = {0};
	unsigned short fastFSDRaw[MAX_SCAP_ROW][MAX_SCAP_COL] = {0}, slowFSDRaw[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};

	short fbTempBuffer1[100] = {0};
	short fbTempBuffer2[100] = {0};
	short fbTempBufferDelta[100] = {0};
	short fbData[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};

	short fsdData[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	short deltaFSD[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};

	unsigned char failed_channel[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	memset( failed_channel, 0, sizeof(failed_channel) );

	TestResultInfo( _T("\r\n------------------------------FSDBK Test------------------------------\r\n") );

	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);
	if( NULL == iChip3536 )         return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	iReCode = iChip3536->GetFSDFastData( pCfg3536->fsd.fsdB.f_clk, pCfg3536->fsd.fsdB.integral, fsdTempBuffer, MAX_SCAP_BUFFER_CNT * sizeof(unsigned short), clkCnt );
	if( ERROR_CODE_OK != iReCode )  return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ICArrayToSensorMatrix( fastFSDRaw, fsdTempBuffer, pCfg3536->real_channel_num, pCfg3536->rowsCnt + 1, pCfg3536->colsCnt );

	iReCode = iChip3536->GetFSDSlowData( pCfg3536->fsd.fsdB.s_clk, pCfg3536->fsd.fsdB.integral, fsdTempBuffer, MAX_SCAP_BUFFER_CNT * sizeof(unsigned short), clkCnt );
	if( ERROR_CODE_OK != iReCode )  return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ICArrayToSensorMatrix( slowFSDRaw, fsdTempBuffer, pCfg3536->real_channel_num, pCfg3536->rowsCnt + 1, pCfg3536->colsCnt );

	if( pCfg3536->fsd.fsdB.fb_check && !GetSimulateGate() )
	{
		iReCode = iChip3536->GetVirtualTouchData( 0x3202, 0x2257, 0x1f07, (unsigned short*)fbTempBuffer1, (unsigned short*)fbTempBuffer2, (pCfg3536->rowsCnt) * pCfg3536->colsCnt * 2 );
		if( ERROR_CODE_OK != iReCode )  return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
		for( int index = 0; index < pCfg3536->rowsCnt * pCfg3536->colsCnt; index++ )
			fbTempBufferDelta[index] = fbTempBuffer1[index] - fbTempBuffer2[index];
	}
	// 	//////////////////////////////////////////////////////////////////////////
	// 	unsigned short tempBufferF[MAX_SCAP_BUFFER_CNT] = {
	// 		1561,1552,1568,1597,1605,1631,1607,	
	// 		1535,1560,1560,1575,1603,1616,1656,	
	// 		1870,1902,1925,1911,2004,1971,1805,	
	// 		1747,1892,1916,1943,1961,1993,1974,
	// 	};
	// 	ReShappingData( fastFSDRaw, tempBufferF, (unsigned int)pCfg3536->va_channel_num, pCfg3536->rowsCnt, pCfg3536->colsCnt );
	// 	unsigned short tempBufferS[MAX_SCAP_BUFFER_CNT] = {
	// 		1582,1573,1590,1622,1627,1654,1629,	
	// 		1557,1582,1581,1596,1625,1639,1682,	
	// 		1897,1933,1955,1941,2035,2003,1831,	
	// 		1774,1922,1949,1973,1993,2024,2007,
	// 	};
	// 	ReShappingData( slowFSDRaw, tempBufferS, (unsigned int)pCfg3536->va_channel_num, pCfg3536->rowsCnt, pCfg3536->colsCnt );
	// 	clkCnt = 1;
	// 	//////////////////////////////////////////////////////////////////////////
	int offset = 1338;
	int offset_t = 2048 - offset;

// 	unsigned char RowsUp[MAX_SCAP_ROW] = {0};
// 	unsigned char RowsDn[MAX_SCAP_ROW] = {0};
// 	for( int iRow = 0; iRow < pCfg3536->rowsCnt / 2; iRow++ )
// 	{
// 		RowsUp[iRow] = iRow;
// 		RowsDn[iRow] = iRow + pCfg3536->rowsCnt / 2;
// 	}

	//double dwFastMeanUp = 0, dwFastMeanDown = 0, dwFastBaseUp = 0, dwFastBaseDown = 0;
	//double dwSlowMeanUp = 0, dwSlowMeanDown = 0, dwSlowBaseUp = 0, dwSlowBaseDown = 0;
	//double dwFastEfficientUp = 0, dwFastEfficientDn = 0, dwSlowEfficientUp = 0, dwSlowEfficientDn = 0;
	double dwFastEfficient = 0, dwSlowEfficient = 0;
	unsigned char RowsPannel[MAX_SCAP_ROW] = {0,1,2,3,4};
	unsigned short fastFSDRawCopy[MAX_SCAP_ROW][MAX_SCAP_COL] = {0}, slowFSDRawCopy[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};

	for( int iRow = 0; iRow < pCfg3536->rowsCnt + 1; iRow++ )
	{
		for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
		{
			fastFSDRaw[iRow][iCol] /= clkCnt;
			slowFSDRaw[iRow][iCol] /= clkCnt;
		}
	}

	memcpy_s( fastFSDRawCopy, sizeof(fastFSDRawCopy), fastFSDRaw, sizeof(fastFSDRaw) );
	memcpy_s( slowFSDRawCopy, sizeof(slowFSDRawCopy), slowFSDRaw, sizeof(slowFSDRaw) );

	//dwFastMeanUp   = GetHarfScreenSortingMean( fastFSDRawCopy, RowsUp, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;
	//dwFastMeanDown = GetHarfScreenSortingMean( fastFSDRawCopy, RowsDn, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;
	//dwFastBaseUp   = GetHarfScreenSortingMean( pCfg3536->fsd_fast, RowsUp, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;
	//dwFastBaseDown = GetHarfScreenSortingMean( pCfg3536->fsd_fast, RowsDn, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;

	//dwSlowMeanUp   = GetHarfScreenSortingMean( slowFSDRawCopy, RowsUp, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;
	//dwSlowMeanDown = GetHarfScreenSortingMean( slowFSDRawCopy, RowsDn, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;
	//dwSlowBaseUp   = GetHarfScreenSortingMean( pCfg3536->fsd_slow, RowsUp, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;
	//dwSlowBaseDown = GetHarfScreenSortingMean( pCfg3536->fsd_slow, RowsDn, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt ) - offset_t;

	//double dwFastEfficientUp = dwFastBaseUp / (dwFastMeanUp ? dwFastMeanUp : 1);
	//double dwFastEfficientDn = dwFastBaseDown / (dwFastMeanDown ? dwFastMeanDown : 1);
	//double dwSlowEfficientUp = dwSlowBaseUp / (dwSlowMeanUp ? dwSlowMeanUp : 1);
	//double dwSlowEfficientDn = dwSlowBaseDown / (dwSlowMeanDown ? dwSlowMeanDown : 1);

	GetHarfScreenNormalizationFactor( fastFSDRawCopy, slowFSDRawCopy, pCfg3536->fsd.fsd_fast, pCfg3536->fsd.fsd_slow, RowsPannel, pCfg3536->rowsCnt, pCfg3536->colsCnt, dwFastEfficient, dwSlowEfficient );

	for( int iRow = 0; iRow < pCfg3536->rowsCnt + 1; iRow++ )
	{
		for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
		{
			//double dwFastEfficient = iRow >= pCfg3536->rowsCnt / 2 ? dwFastEfficientDn : dwFastEfficientUp;
			//double dwSlowEfficinet = iRow >= pCfg3536->rowsCnt / 2 ? dwSlowEfficientDn : dwSlowEfficientUp; 

			fastFSDRawCopy[iRow][iCol] = (unsigned short)( ( fastFSDRawCopy[iRow][iCol] - offset_t ) * dwFastEfficient ) + offset_t;
			slowFSDRawCopy[iRow][iCol] = (unsigned short)( ( slowFSDRawCopy[iRow][iCol] - offset_t ) * dwFastEfficient ) + offset_t;
			fsdData[iRow][iCol] = slowFSDRawCopy[iRow][iCol] - fastFSDRawCopy[iRow][iCol];
			deltaFSD[iRow][iCol] = fsdData[iRow][iCol] - pCfg3536->fsd.fsd_base[iRow][iCol];
		}
	}

	// 	{
	// 		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
	// 		PrintMaxtrixValue( m_ColorText, fastFSDRawCopy, pCfg3536->invalid_node, info, _T("\r\nFast Nor Data:\r\n") );
	// 	}
	// 
	// 	{
	// 		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
	// 		PrintMaxtrixValue( m_ColorText, slowFSDRawCopy, pCfg3536->invalid_node, info, _T("\r\nSlow Nor Data:\r\n") );
	// 	}

	/********************************************************************************************/
	/*backup test result data*/
	memcpy_s( m_stOneRecord.Scap.fsd_test_buff, sizeof(m_stOneRecord.Scap.fsd_test_buff), fsdData, sizeof(fsdData) );
	memcpy_s( m_stOneRecord.Scap.fsd_fast_buff, sizeof(m_stOneRecord.Scap.fsd_fast_buff), fastFSDRaw, sizeof(fastFSDRaw) );
	memcpy_s( m_stOneRecord.Scap.fsd_slow_buff, sizeof(m_stOneRecord.Scap.fsd_slow_buff), slowFSDRaw, sizeof(slowFSDRaw) );
	/********************************************************************************************/

	{
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt, pCfg3536->real_channel_num - pCfg3536->va_channel_num, true );
		PrintMaxtrixValue( m_ColorText, slowFSDRaw, pCfg3536->invalid_node, info, _T("\r\nSlow CLK RawData:\r\n") );
	}
	{
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt, pCfg3536->real_channel_num - pCfg3536->va_channel_num, true );
		PrintMaxtrixValue( m_ColorText, fastFSDRaw, pCfg3536->invalid_node, info, _T("\r\nFast CLK RawData:\r\n") );
	}
	{
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt, pCfg3536->real_channel_num - pCfg3536->va_channel_num, true );
		unsigned char dataFailChannel[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		memset( dataFailChannel, 0, sizeof(dataFailChannel) );
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				if (0 == pCfg3536->invalid_node[iRow][iCol]) continue;

				if( ( fsdData[iRow][iCol] < pCfg3536->fsd.fsdB.fsd_min ) 
					/*&& ( abs(fastFSDRaw[iRow][iCol] - 2048) < 20 )*/ 
					/*&& ( abs(slowFSDRaw[iRow][iCol] - 2048) < 20 )*/ )
				{				
					failerCount++;
					bDeviationFail = TRUE;	
					dataFailChannel[iRow][iCol] = 1;
				}
			}
		}

		PrintMaxtrixValue( m_ColorText, fsdData, dataFailChannel, pCfg3536->invalid_node, info, _T("\r\nFSD Data:\r\n") );
	}

	if(pCfg3536->fsd.fsdB.scale_check)
	{
		//case 0
		if( dwFastEfficient <= 0.5 || dwFastEfficient >= 1.5 )
		{
			failerCount++;
			bDeviationFail = TRUE;	
		}
		if( dwSlowEfficient <= 0.5 || dwSlowEfficient >= 1.5 )
		{
			failerCount++;
			bDeviationFail = TRUE;
		}
		if( failerCount )
		{
			TCHAR chTemp[256] = {0};
			transformat( chTemp, _T("\r\nfast coefficient = %.3f, slow coefficient = %.3f\r\n"), dwFastEfficient, dwSlowEfficient );
			ColorText text( chTemp, RGB( 255, 0, 0 ), TEXT_SIZE_SMALL, false );
			TestResultInfo( text );
		}
	}

	//case 1
	short slowRc[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	short fastRc[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};

	for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
	{
		for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
		{
			slowRc[iRow][iCol] = slowFSDRawCopy[iRow][iCol] - offset_t;
			if( 0 == slowRc[iRow][iCol] ) slowRc[iRow][iCol] = 1;

			fastRc[iRow][iCol] = fastFSDRawCopy[iRow][iCol] - offset_t;
			if( 0 == fastRc[iRow][iCol] ) fastRc[iRow][iCol] = 1;
		}
	}


	//case 2
	//double dwDeltaUpMean = 0, dwDeltaDownMean = 0;
	double dwDeltaMean = 0;
	short fsdDeltaCopy2[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	memcpy_s( fsdDeltaCopy2, sizeof(fsdDeltaCopy2), deltaFSD, sizeof(deltaFSD) );

	//dwDeltaUpMean = ( Sum( fsdDeltaCopy[0], pCfg3536->colsCnt ) + Sum( fsdDeltaCopy[1], pCfg3536->colsCnt ) ) / pCfg3536->harf_va_channel_num;
	//dwDeltaDownMean =( Sum( fsdDeltaCopy[2], pCfg3536->colsCnt ) + Sum( fsdDeltaCopy[3], pCfg3536->colsCnt ) ) / pCfg3536->harf_va_channel_num;

	dwDeltaMean = GetHarfScreenNormalization( fsdDeltaCopy2, RowsPannel, pCfg3536->rowsCnt );
	//dwDeltaDownMean = GetHarfScreenNormalization( fsdDeltaCopy2, RowsDn, pCfg3536->rowsCnt / 2 );

	AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt, pCfg3536->real_channel_num - pCfg3536->va_channel_num, true );

	for( int iRow = 0; iRow < pCfg3536->rowsCnt +( info.bIncludeKey ? 1 : 0 ); iRow++ )
	{
		for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
		{
			int fsdDeltaFixed = fsdDeltaCopy2[iRow][iCol] - (int)dwDeltaMean;

			fsdDeltaCopy2[iRow][iCol] = abs( fsdDeltaFixed );
		}
	}

	{
		NodeVal nodeOutRange;
		ColorText textTemp( _T("\r\nFSD Delta:\r\n") );
		
		int delta_min[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		FillMatrixUseValue( delta_min, 0 );

		bool bResult = AnalyzeTestResult( fsdDeltaCopy2, delta_min, pCfg3536->fsd.fsd_delta_max, pCfg3536->invalid_node, info, textTemp, nodeOutRange );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in FSD Delta: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
			MarkNodeToMatrix( &nodeOutRange, failed_channel );
			failerCount++;
		}
	}

	//case 3
	//normalization
	short fsdDataCopy3[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	memcpy_s( fsdDataCopy3, sizeof(fsdDataCopy3), fsdData, sizeof(fsdData) );
// 	for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
// 	{
// 		{
// 			int iCol = 0;
// 			double dwNormalization = (double)pCfg3536->fsd.fsd_base[iRow][iCol+1] / ( (pCfg3536->fsd.fsd_base[iRow][iCol] == 0) ? 0.001 : pCfg3536->fsd.fsd_base[iRow][iCol] );
// 			fsdDataCopy3[iRow][iCol] =  (short)( dwNormalization * fsdDataCopy3[iRow][iCol] );
// 		}
// 		{
// 			int iCol = pCfg3536->colsCnt - 1;
// 			double dwNormalization = (double)pCfg3536->fsd.fsd_base[iRow][iCol-1] / ( (pCfg3536->fsd.fsd_base[iRow][iCol] == 0) ? 0.001 : pCfg3536->fsd.fsd_base[iRow][iCol] );
// 			fsdDataCopy3[iRow][iCol] = (short)( dwNormalization * fsdDataCopy3[iRow][iCol] );
// 		}
// 	}
// 	{
// 		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
// 		PrintMaxtrixValue( m_ColorText, fsdDataCopy3, pCfg3536->invalid_node, info, _T("\r\nNormalization:\r\n") );
// 	}

	{
		NodeVal nodeOutRange;
		ColorText textTemp( _T("\r\nFSD Delta Uniformity Left:\r\n") );
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
		int pannel_left_min[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		int pannel_left_val[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		unsigned char invalidTemp[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		CopyAndInvalid( invalidTemp, pCfg3536->invalid_node, MAX_SCAP_ROW,  0 );
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 1; iCol < pCfg3536->colsCnt; iCol++ )
			{
				pannel_left_val[iRow][iCol] = abs( fsdDataCopy3[iRow][iCol] - fsdDataCopy3[iRow][iCol - 1] );
			}
		}

		bool bResult = AnalyzeTestResult( pannel_left_val, pannel_left_min, pCfg3536->fsd.fsd_uniformity_left, invalidTemp, info, textTemp, nodeOutRange );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in FSD Delta Uniformity Left: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
			MarkNodeToMatrix( &nodeOutRange, failed_channel );
			failerCount++;
		}
	}

	{
		NodeVal nodeOutRange;
		ColorText textTemp( _T("\r\nFSD Delta Uniformity Right:\r\n") );
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
		int pannel_right_min[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		int pannel_right_val[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		unsigned char invalidTemp[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		CopyAndInvalid( invalidTemp, pCfg3536->invalid_node, MAX_SCAP_ROW, pCfg3536->colsCnt - 1 );
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt - 1; iCol++ )
			{
				pannel_right_val[iRow][iCol] = abs( fsdDataCopy3[iRow][iCol]- fsdDataCopy3[iRow][iCol + 1] );
			}
		}

		bool bResult = AnalyzeTestResult( pannel_right_val, pannel_right_min, pCfg3536->fsd.fsd_uniformity_right, invalidTemp, info, textTemp, nodeOutRange );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in FSD Delta Uniformity Right: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
			MarkNodeToMatrix( &nodeOutRange, failed_channel );
			failerCount++;
		}
	}

	//case 4
	int rcSlowDeviation[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	{
		/*unsigned*/ short baseSlowRc[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				baseSlowRc[iRow][iCol] = pCfg3536->fsd.fsd_slow[iRow][iCol] - offset_t;
				if( 0 == baseSlowRc[iRow][iCol] ) baseSlowRc[iRow][iCol] = 1;

				rcSlowDeviation[iRow][iCol] = baseSlowRc[iRow][iCol] - slowRc[iRow][iCol];
			}
		}

		double dwMean = 0;
		dwMean = GetHarfScreenSortingMean( rcSlowDeviation, RowsPannel, pCfg3536->rowsCnt, pCfg3536->colsCnt );
		//double dwMeanUp = 0, dwMeanDown = 0;
		//dwMeanUp = GetHarfScreenSortingMean( rcSlowDeviation, RowsUp, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt );
		//dwMeanDown = GetHarfScreenSortingMean( rcSlowDeviation, RowsDn, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt );
		// 		if( pCfg3536->bVerticalTriangle )
		// 		{
		// // 			for( int iRow = 0; iRow < pCfg3536->rowsCnt / 2; iRow++ )
		// // 			{
		// // 				dwMeanUp += Sum( rcSlowDeviation[iRow], pCfg3536->colsCnt );
		// // 				dwMeanDown = Sum( rcSlowDeviation[iRow + pCfg3536->rowsCnt / 2], pCfg3536->colsCnt );
		// // 			}
		// // 			dwMeanUp /= pCfg3536->harf_va_channel_num;
		// // 			dwMeanDown /= pCfg3536->harf_va_channel_num;
		// 		}
		// 		else
		// 		{
		// // 			for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		// // 				dwMeanUp += Sum( rcSlowDeviation[iRow], pCfg3536->colsCnt );
		// // 
		// // 			dwMeanDown = dwMeanUp = dwMeanUp / pCfg3536->va_channel_num;
		// 		}

		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				rcSlowDeviation[iRow][iCol] = rcSlowDeviation[iRow][iCol] - (int)dwMean;

				rcSlowDeviation[iRow][iCol] = 1000 * rcSlowDeviation[iRow][iCol] / baseSlowRc[iRow][iCol]; 
			}
		}
		NodeVal nodeOutRange;
		ColorText textTemp( _T("\r\nFSD Deviation:\r\n") );
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt, pCfg3536->real_channel_num - pCfg3536->va_channel_num, true );
		int deviation_min[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				deviation_min[iRow][iCol] = (-3) * pCfg3536->fsd.fsd_deviation[iRow][iCol];
			}
		}
		bool bResult = AnalyzeTestResult( rcSlowDeviation, deviation_min, pCfg3536->fsd.fsd_deviation, pCfg3536->invalid_node, info, textTemp, nodeOutRange );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in FSD Deviation Test: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
			MarkNodeToMatrix( &nodeOutRange, failed_channel );
			failerCount++;
			bDeviationFail = TRUE;
		}
	}

	//case 5
	int rcFastDeviation[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	{
		/*unsigned*/ short baseFastRc[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				baseFastRc[iRow][iCol] = pCfg3536->fsd.fsd_fast[iRow][iCol] - offset_t;
				if( 0 == baseFastRc[iRow][iCol] ) baseFastRc[iRow][iCol] = 1;

				rcFastDeviation[iRow][iCol] = baseFastRc[iRow][iCol] - fastRc[iRow][iCol];
			}
		}
		double dwMean = 0;
		dwMean = GetHarfScreenSortingMean( rcFastDeviation, RowsPannel, pCfg3536->rowsCnt, pCfg3536->colsCnt );
		//double dwMeanUp = 0, dwMeanDown = 0;
		//dwMeanUp = GetHarfScreenSortingMean( rcFastDeviation, RowsUp, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt );
		//dwMeanDown = GetHarfScreenSortingMean( rcFastDeviation, RowsDn, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt );
		//dwMeanUp = (double)( Sum( rcFastDeviation[0], pCfg3536->colsCnt ) + Sum( rcFastDeviation[1], pCfg3536->colsCnt ) ) / pCfg3536->harf_va_channel_num;
		//dwMeanDown = (double)( Sum( rcFastDeviation[2], pCfg3536->colsCnt ) + Sum( rcFastDeviation[3], pCfg3536->colsCnt ) ) / pCfg3536->harf_va_channel_num;
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				rcFastDeviation[iRow][iCol] = rcFastDeviation[iRow][iCol] - (int)dwMean;

				rcFastDeviation[iRow][iCol] = 1000 * rcFastDeviation[iRow][iCol] / baseFastRc[iRow][iCol]; 
			}
		}
	}

	{
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt, pCfg3536->real_channel_num - pCfg3536->va_channel_num, true );
		PrintMaxtrixValue( m_ColorText, rcFastDeviation, pCfg3536->invalid_node, info, _T("\r\nFast Deviation:\r\n") );
	}

	//case 6  打补丁放水
	if( !bDeviationFail && failerCount > 0 )
	{
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				//int index = iRow * pCfg3536->colsCnt + iCol;
				int asbDeltaFSD = fsdDeltaCopy2[iRow][iCol];
				if( (asbDeltaFSD >= pCfg3536->fsd.fsdB.fsd_triger_min)
					&& (asbDeltaFSD <= pCfg3536->fsd.fsdB.fsd_triger_max)
					&& (rcSlowDeviation[iRow][iCol] >= pCfg3536->fsd.fsdB.fsd_critical_slow_min)
					&& (rcSlowDeviation[iRow][iCol] <= pCfg3536->fsd.fsdB.fsd_critical_slow_max) 
					&& (rcFastDeviation[iRow][iCol] <= pCfg3536->fsd.fsdB.fsd_critical_fast_max) )
				{
					failed_channel[iRow][iCol] = 0;
					for( int iRow2 = 0; iRow2 < pCfg3536->rowsCnt; iRow2++ )
					{
						if( abs( fsdDeltaCopy2[iRow2][iCol] ) < pCfg3536->fsd.fsdB.fsd_besides_min )
							failed_channel[iRow2][iCol] = 0;
					}
					int iLeft  =  iCol == 0 ? 0 : iCol - 1;
					int iRight = iCol == (pCfg3536->colsCnt - 1) ?  (pCfg3536->colsCnt - 1) : iCol + 1;
					if( abs( (long)fsdDeltaCopy2[iRow * pCfg3536->colsCnt + iLeft] ) < pCfg3536->fsd.fsdB.fsd_besides_min )
					{
						failed_channel[iRow][iLeft] = 0;
					}
					if( abs( (long)fsdDeltaCopy2[iRow * pCfg3536->colsCnt + iRight] ) < pCfg3536->fsd.fsdB.fsd_besides_min )
					{
						failed_channel[iRow][iRight] = 0;
					}
				}
			}
		}

		failerCount = Sum( failed_channel[0], pCfg3536->colsCnt ) + Sum( failed_channel[1], pCfg3536->colsCnt ) + Sum( failed_channel[2], pCfg3536->colsCnt ) + Sum( failed_channel[3], pCfg3536->colsCnt );
		if( failerCount > 0 )
		{

		}
		else
		{
			bMarkAsTBD = pCfg3536->fsd.fsdB.fsd_recheck ? false : true;
		}
	}


	//case 8
	if( pCfg3536->fsd.fsdB.fb_check && !GetSimulateGate() )
	{
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
		ReShappingData<short>( fbData, fbTempBuffer1, pCfg3536->va_channel_num, pCfg3536->rowsCnt, pCfg3536->colsCnt );
		PrintMaxtrixValue( m_ColorText, fbData, pCfg3536->invalid_node, info, _T("\r\nFB RawData1:\r\n") );
		ReShappingData<short>( fbData, fbTempBuffer2, pCfg3536->va_channel_num, pCfg3536->rowsCnt, pCfg3536->colsCnt );
		PrintMaxtrixValue( m_ColorText, fbData, pCfg3536->invalid_node, info, _T("\r\nFB RawData2:\r\n") );
		ReShappingData<short>( fbData, fbTempBufferDelta, pCfg3536->va_channel_num, pCfg3536->rowsCnt, pCfg3536->colsCnt );
		PrintMaxtrixValue( m_ColorText, fbData, pCfg3536->invalid_node, info, _T("\r\nFB Data:\r\n") );

		NodeVal nodeOutRange;
		int fb_min[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		int fb_max[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		ColorText textTemp( _T("\r\nFB Delta:\r\n") );
		FillMatrixUseValue( fb_min, (int)pCfg3536->fsd.fsdB.fb_min );
		FillMatrixUseValue( fb_max, (int)pCfg3536->fsd.fsdB.fb_max );
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
				fbData[iRow][iCol] = fbData[iRow][iCol] - pCfg3536->fsd.fsdB.fb_base;
		}
		bool bResult = AnalyzeTestResult( fbData, fb_min, fb_max, pCfg3536->invalid_node, info, textTemp, nodeOutRange );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in FB Delta: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
			MarkNodeToMatrix( &nodeOutRange, failed_channel );
			failerCount++;
		}
	}

	if( pCfg3536->fsd.fsdB.fsd_recheck )
	{
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt );
		PrintMaxtrixValue( m_ColorText, rcSlowDeviation, failed_channel, pCfg3536->invalid_node, info, _T("\r\nFSD Redjuge:\r\n") );
	}

	if( failerCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//FSDBK Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		if( bMarkAsTBD )
		{
			itemNotify.UpdateItemResult( ITEM_STA_TBD );
			TestResultInfo( "\r\n\r\n//FSDBK Test is TBD\r\n", ITEM_STA_TBD );
		}
		else
		{
			itemNotify.UpdateItemResult( ITEM_STA_PASS );
			TestResultInfo( "\r\n\r\n//FSDBK Test is Pass\r\n", ITEM_STA_PASS );
		}	
	}

	return itemNotify;
}
unsigned int CTest3536::OS_Test( NativeTestItem& itemQuote )
{
	//err_type 0 = no err; 1 - open; 2-short; 4-tbd
	unsigned char err_type_linkly = 0;
	//failerStep 1 - M1; 2 - M2; 4 - M3
	unsigned int iReCode = ERROR_CODE_OK, failerStep = 0;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );

	int os_delta[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	unsigned short osTempBuffer[MAX_SCAP_BUFFER_CNT] = {0};
	unsigned short osSsRawDataMatrix[MAX_SCAP_ROW][MAX_SCAP_COL] = {0}, osIcRawDataMatrix[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	unsigned short osICBaseMatrix[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	unsigned short ic_2_sensor_matrix[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};

	int ref_channel_num = min(pCfg3536->real_channel_num - pCfg3536->va_channel_num, pCfg3536->colsCnt);

	TestResultInfo( _T("\r\n------------------------------OS Test------------------------------\r\n") );

	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);
	if( NULL == iChip3536 )         return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	iReCode = iChip3536->IncokeCommand( CMD_CTP_RST );
	SysDelay( 20 );

	iReCode = iChip3536->GetOSData( pCfg3536->integral, pCfg3536->scale_a, pCfg3536->scale_b, pCfg3536->os_clk, osTempBuffer, MAX_SCAP_BUFFER_CNT * sizeof(unsigned short) );

	//////////////////////////////////////////////////////////////////////////
// 	unsigned short osTemp[] = {
// 		300,1164,1176,   0,1154,1140,1104,1094, 852, 744,   0,   0,	
// 		630, 668, 944, 916, 886, 888, 886, 902, 936, 930, 944, 946,	
// 		0,   0, 704, 670, 780, 874,1132,1148,1202,1158, 326, 290,	
// 		314, 344,   0,   0, 368, 338, 298, 266,   0,   0,   0,   0
// 	};
// 	memcpy_s( osTempBuffer, sizeof(osTempBuffer), osTemp, sizeof(osTemp) );
	//////////////////////////////////////////////////////////////////////////

	if( ERROR_CODE_OK != iReCode )  return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ICArrayToSensorMatrix( osSsRawDataMatrix, osTempBuffer, pCfg3536->real_channel_num, pCfg3536->rowsCnt + 1, pCfg3536->colsCnt );

	// 4 * 12
	ReShappingData( ic_2_sensor_matrix, (unsigned short*)pCfg3536->ic_2_sensor_map, MAX_SCAP_CHANNEL, MAX_CHANNEL_ONE_GROUP, MAX_IX_NUM_3536 );
	ReShappingData( osIcRawDataMatrix, osTempBuffer, MAX_SCAP_CHANNEL, MAX_CHANNEL_ONE_GROUP, MAX_IX_NUM_3536 );
	SensorMatrixToIcMatrix( osICBaseMatrix, MAX_CHANNEL_ONE_GROUP, MAX_IX_NUM_3536, pCfg3536->os_base, pCfg3536->rowsCnt + 1, pCfg3536->colsCnt );

	/********************************************************************************************/
	/*backup test result data*/
	memcpy_s( m_stOneRecord.Scap.OS_test_buff, sizeof(m_stOneRecord.Scap.OS_test_buff), osSsRawDataMatrix, sizeof(osSsRawDataMatrix) );
	/********************************************************************************************/

	//OS - M1
	{
		NodeVal nodeOutRange;
		ColorText textTemp( _T("\r\nOS - M1:\r\n") );
		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt,  ref_channel_num, true );

		unsigned short os_m2_min[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		unsigned short os_m2_max[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};

		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				os_m2_min[iRow][iCol] = pCfg3536->os_base[iRow][iCol] - (pCfg3536->os_base[iRow][iCol] * pCfg3536->m1_ratio_lower_va) / 100;
				os_m2_max[iRow][iCol] = pCfg3536->os_base[iRow][iCol] + (pCfg3536->os_base[iRow][iCol] * pCfg3536->m1_ratio_upper_va) / 100;
			}
		}
		for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
		{
			os_m2_min[pCfg3536->rowsCnt][iCol] = pCfg3536->os_base[pCfg3536->rowsCnt][iCol] - (pCfg3536->os_base[pCfg3536->rowsCnt][iCol] * pCfg3536->m1_ratio_lower_ref) / 100;
			os_m2_max[pCfg3536->rowsCnt][iCol] = pCfg3536->os_base[pCfg3536->rowsCnt][iCol] + (pCfg3536->os_base[pCfg3536->rowsCnt][iCol] * pCfg3536->m1_ratio_upper_ref) / 100;
		}

		bool bResult = AnalyzeTestResult( osSsRawDataMatrix, os_m2_min, os_m2_max, pCfg3536->invalid_node, info, textTemp, nodeOutRange );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in OS - M1: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
			failerStep |= 0x01;
		}
	}

	//OS - M2
	unsigned char failedChannel[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	unsigned char osInvalidM1[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	memset( failedChannel, 0, sizeof(failedChannel) );
	memset( osInvalidM1, 0x00, sizeof(osInvalidM1) );
	for( int iCol = 0; iCol < MAX_IX_NUM_3536; iCol++ )
	{
		//no active channel
		if( 0 == ( ic_2_sensor_matrix[0][iCol] + ic_2_sensor_matrix[1][iCol] + ic_2_sensor_matrix[2][iCol] + ic_2_sensor_matrix[3][iCol] ) ) continue;

		for( int iRow = 0; iRow < MAX_CHANNEL_ONE_GROUP; iRow++ )
		{
			if( 0 == ic_2_sensor_matrix[iRow][iCol] ) continue;

			int nextRow = iRow;
			for( int index = 0; index < MAX_CHANNEL_ONE_GROUP; index++ )
			{
				nextRow = ( nextRow + 1 ) % MAX_CHANNEL_ONE_GROUP;
				if( ic_2_sensor_matrix[nextRow][iCol] ) break;
			}
			
			osInvalidM1[iRow][iCol]   = 1;
			osInvalidM1[nextRow][iCol] = 1;
			int productLast = osIcRawDataMatrix[iRow][iCol] * osICBaseMatrix[nextRow][iCol];
			int productNext = osIcRawDataMatrix[nextRow][iCol] * osICBaseMatrix[iRow][iCol];

			//打个补丁
			if( !productLast || !productNext )  continue;

			if( productLast > productNext + (productNext * pCfg3536->m2_ratio) / 100 )
			{
				failedChannel[iRow][iCol] = 1;
				failedChannel[nextRow][iCol] = 1;
				failerStep |= 0x02;
			}
			else if( productNext > productLast + (productLast * pCfg3536->m2_ratio) / 100 )
			{
				failedChannel[iRow][iCol] = 1;
				failedChannel[nextRow][iCol] = 1;
				failerStep |= 0x02;
			}
		}
	}
	//Print M2
	{
		AnalyzeInfo info( MAX_CHANNEL_ONE_GROUP, MAX_IX_NUM_3536 );
		PrintMaxtrixValue( m_ColorText, osIcRawDataMatrix, failedChannel, osInvalidM1, info, _T("\r\nOS - M2:\r\n") );
	}

	//OS - M3
	unsigned int sumBaseUp = 0, sumTestUp = 0;
	unsigned int sumBaseDn = 0, sumTestDn = 0;
	unsigned char RowsUp[MAX_SCAP_ROW] = {0};
	unsigned char RowsDn[MAX_SCAP_ROW] = {0};
	for( int iRow = 0; iRow < pCfg3536->rowsCnt / 2; iRow++ )
	{
		RowsUp[iRow] = iRow;
		RowsDn[iRow] = iRow + pCfg3536->rowsCnt / 2;
	}

	sumTestUp = (unsigned int)GetHarfScreenSortingMean( osSsRawDataMatrix, RowsUp, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt );
	sumTestDn = (unsigned int)GetHarfScreenSortingMean( osSsRawDataMatrix, RowsDn, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt );
	sumBaseUp = (unsigned int)GetHarfScreenSortingMean( pCfg3536->os_base, RowsUp, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt );
	sumBaseDn = (unsigned int)GetHarfScreenSortingMean( pCfg3536->os_base, RowsDn, pCfg3536->rowsCnt / 2, pCfg3536->colsCnt );

	short normalizationData[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
// 	for( int iRow = 0; iRow < pCfg3536->rowsCnt / 2; iRow++ )
// 	{
// 		sumBaseUp += Sum( &pCfg3536->os_base[iRow][1], pCfg3536->colsCnt - 2 );
// 		sumTestUp += Sum( &osSsRawDataMatrix[iRow][1], pCfg3536->colsCnt - 2 );
// 	}
// 	for( int iRow = pCfg3536->rowsCnt / 2; iRow < pCfg3536->rowsCnt; iRow++ )
// 	{
// 		sumBaseDn += Sum( &pCfg3536->os_base[iRow][1], pCfg3536->colsCnt - 2 );
// 		sumTestDn += Sum( &osSsRawDataMatrix[iRow][1], pCfg3536->colsCnt - 2 );
// 	}
	memset( os_delta, 0, sizeof(os_delta) );
	//va channel
	for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
	{
		for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
		{
			short oNormalization = 0;
			if( ( iRow * pCfg3536->colsCnt + iCol ) < pCfg3536->harf_va_channel_num )
				oNormalization = osSsRawDataMatrix[iRow][iCol] * sumBaseUp / (sumTestUp ? sumTestUp : 1);
			else
				oNormalization = osSsRawDataMatrix[iRow][iCol] * sumBaseDn / (sumTestDn ? sumTestDn : 1);

			os_delta[iRow][iCol] = oNormalization - pCfg3536->os_base[iRow][iCol];
			normalizationData[iRow][iCol] = oNormalization;
		}
	}
	//ref channel
	unsigned int sumBaseKey = 0, sumTestKey = 0;
	sumBaseKey = Sum( &pCfg3536->os_base[pCfg3536->rowsCnt][0], ref_channel_num );
	sumTestKey = Sum( &osSsRawDataMatrix[pCfg3536->rowsCnt][0], ref_channel_num );
	for( int iCol = 0; iCol < ref_channel_num; iCol++ )
	{
		unsigned int sumBaseAdd = sumBaseUp + sumBaseDn + sumBaseKey;
		unsigned int sumTestAdd = sumTestUp + sumTestDn + sumTestKey;
		os_delta[pCfg3536->rowsCnt][iCol] = osSsRawDataMatrix[pCfg3536->rowsCnt][iCol] * (sumBaseAdd) / (sumTestAdd ? sumTestAdd : 1)
			- pCfg3536->os_base[pCfg3536->rowsCnt][iCol];
	}

	{
		unsigned char failedChannel[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
		memset( failedChannel, 0 , sizeof(failedChannel) );

		//va channel
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow += 2 )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				if( os_delta[iRow][iCol] > pCfg3536->m3_delta_va_max || os_delta[iRow+1][iCol] > pCfg3536->m3_delta_va_max )
				{
					failerStep |= 0x04;
					failedChannel[iRow][iCol] = 1;
					failedChannel[iRow+1][iCol] = 1;

					err_type_linkly |= 0x02;
				}

				if( os_delta[iRow][iCol] < pCfg3536->m3_delta_level2 && os_delta[iRow+1][iCol] < pCfg3536->m3_delta_level2 )
				{
					failerStep |= 0x04;
					failedChannel[iRow][iCol] = 1;
					failedChannel[iRow+1][iCol] = 1;
					if( normalizationData[iRow][iCol] < 200 && normalizationData[iRow+1][iCol] < 200 )
						err_type_linkly |= 0x01;
					else
						err_type_linkly |= 0x02;
				}

				if( os_delta[iRow][iCol] < (pCfg3536->m3_delta_level2 + pCfg3536->m3_delta_level1) || os_delta[iRow+1][iCol] < (pCfg3536->m3_delta_level2 + pCfg3536->m3_delta_level1) )
				{
					failerStep |= 0x04;
					failedChannel[iRow][iCol] = 1;
					failedChannel[iRow+1][iCol] = 1;
					if( normalizationData[iRow][iCol] < 200 && normalizationData[iRow+1][iCol] < 200 )
						err_type_linkly |= 0x01;
					else
						err_type_linkly |= 0x02;
				}

				if( os_delta[iRow][iCol] < pCfg3536->m3_delta_level1 && os_delta[iRow+1][iCol] < pCfg3536->m3_delta_level1 )
				{
					failedChannel[iRow][iCol] = 1;
					failedChannel[iRow+1][iCol] = 1;
					err_type_linkly |= 0x04;
				}

				if( os_delta[iRow][iCol] < pCfg3536->m3_delta_level2 || os_delta[iRow+1][iCol] < pCfg3536->m3_delta_level2 )
				{
					failedChannel[iRow][iCol] = 1;
					failedChannel[iRow+1][iCol] = 1;
					err_type_linkly |= 0x04;
				}
			}
		}

		for( int iCol = 0; iCol < ref_channel_num; iCol++ )
		{
			if( os_delta[pCfg3536->rowsCnt][iCol] > 2 * (pCfg3536->m3_delta_ref_max + abs(pCfg3536->m3_delta_level1)) )
			{
				failerStep |= 0x04;
				failedChannel[pCfg3536->rowsCnt][iCol] = 1;
				err_type_linkly |= 0x01;
			}
			if( os_delta[pCfg3536->rowsCnt][iCol] < -(pCfg3536->m3_delta_ref_max + abs(pCfg3536->m3_delta_level1)) )
			{
				failerStep |= 0x04;
				failedChannel[pCfg3536->rowsCnt][iCol] = 1;
				err_type_linkly |= 0x02;
			}
			if( os_delta[pCfg3536->rowsCnt][iCol] > 2 * pCfg3536->m3_delta_ref_max )
			{
				failedChannel[pCfg3536->rowsCnt][iCol] = 1;
				err_type_linkly |= 0x04;
			}
			if( os_delta[pCfg3536->rowsCnt][iCol] < -pCfg3536->m3_delta_ref_max )
			{
				failedChannel[pCfg3536->rowsCnt][iCol] = 1;
				err_type_linkly |= 0x04;
			}
		}

		AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt, ref_channel_num, true );
		PrintMaxtrixValue( m_ColorText, os_delta, failedChannel, pCfg3536->invalid_node, info, _T("\r\nOS - M3:\r\n") );
	}

	//M4
	if( failerStep )
	{
		if( failerStep & 0x01 ) itemNotify.UpdateItemResult( ITEM_STA_FAIL, _T("M1") );
		else if( failerStep & 0x02 ) itemNotify.UpdateItemResult( ITEM_STA_FAIL, _T("M2") );
		else if( failerStep & 0x04 ) itemNotify.UpdateItemResult( ITEM_STA_FAIL, _T("M3") );
		else itemNotify.UpdateItemResult( ITEM_STA_FAIL );

// 		if( err_type_linkly & 0x01 )
// 			TestResultInfo( _T("\r\nChannel Open likely\r\n") );
// 		else if( err_type_linkly & 0x02 )
// 			TestResultInfo( _T("\r\nChannel short likely\r\n") );

		TestResultInfo( "\r\n\r\n//OS Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		if( err_type_linkly & 0x04 )
		{
			itemNotify.UpdateItemResult( ITEM_STA_TBD );
			TestResultInfo( "\r\n\r\n//OS Test is TBD\r\n", ITEM_STA_TBD );
		}
		else
		{
			itemNotify.UpdateItemResult( ITEM_STA_PASS );
			TestResultInfo( "\r\n\r\n//OS Test is Pass\r\n", ITEM_STA_PASS );
		}
	}

	return itemNotify;
}
BOOL CTest3536::CheckTpBootSame( )
{
	BOOL bCheckBootOk = FALSE;
	unsigned int iReCode = ERROR_CODE_OK;
	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);
	if( NULL == iChip3536 )   return FALSE;

	unsigned int crc_from_tp = 0, otm_time = 0;
	iReCode = iChip3536->GetBootCheckSum( &crc_from_tp, &otm_time );
	if( iReCode != ERROR_CODE_OK )  return FALSE;

	TCHAR szBuffer[MAX_PATH] = {0};
	transformat( szBuffer, _T("ID = 0x%x,   %d-%d, %d:%d:%d"), otm_time, (otm_time>>22)&0xf, (otm_time>>17)&0x1f,(otm_time>>12)&0x1f, (otm_time>>6)&0x3f, otm_time&0x3f );
	TestResultInfo( szBuffer );
	
	if( crc_from_tp == pCfg3536->boot_check_sum )
		return TRUE;

	return FALSE;
}
unsigned int CTest3536::CheckFlashEraseOk()
{
	unsigned int iReCode = ERROR_CODE_OK;

	if(pCfg3536->boot_only_check || pCfg3536->config_only_check) return ERROR_CODE_OK;

	unsigned char regHead1[] = { 0x05 };
	iReCode = SM_ChipBase(m_deviceNo)->WriteCoreSpace( 0x602, regHead1, 1 );
	CHECK_RETURN_IF_FAIL(iReCode);
	unsigned char regHead2[] = { 0x00 };
	iReCode = SM_ChipBase(m_deviceNo)->WriteCoreSpace( 0x643, regHead2, 1 );
	CHECK_RETURN_IF_FAIL(iReCode);

	iReCode = SM_ChipBase(m_deviceNo)->WriteCoreSpace( 0x8000, (unsigned char*)flashTestCodeBin, sizeof(flashTestCodeBin) );
	CHECK_RETURN_IF_FAIL(iReCode);

	unsigned char regHead3[] = { pCfg3536->I2cAddr };
	iReCode = SM_ChipBase(m_deviceNo)->WriteCoreSpace( 0x001, regHead3, 1 );
	CHECK_RETURN_IF_FAIL(iReCode);

	unsigned char regHead4[] = { 0x88 };
	iReCode = SM_ChipBase(m_deviceNo)->WriteCoreSpace( 0x602, regHead4, 1 );
	CHECK_RETURN_IF_FAIL(iReCode);
	SysDelay( 30 );

	for( int index = 0; index < 30; index++ )
	{
		unsigned int flashTestResult = 0;
		iReCode = SM_ChipBase(m_deviceNo)->ReadCoreSpace( 0x8000, (unsigned char*)&flashTestResult, 4 );
		CHECK_RETURN_IF_FAIL(iReCode);
		if( (flashTestResult >> 24) == 0x54  )
		{
			if( 0 == (flashTestResult & 0x00ffffff) )
			{
				iReCode = ERROR_CODE_OK;
			}
			else
			{
				iReCode = ERROR_CODE_INVALID_PARAM;
				TCHAR chTemp[MAX_PATH] = {0};
				transformat( chTemp, _T("WriteBurnSpace, Err = 0x%x\r\n"), flashTestResult );
				TestResultInfo( chTemp );
