<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewModel="clr-namespace:SEMIDevelopKit.Src.WinSub"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <XmlDataProvider x:Key="Ic_Type_List" XPath="XUnits">
            <x:XData>
                <XUnits xmlns="">
                    <XUnit Name="CHSC5816" HexValue="0x10" DecValue="16"></XUnit>
                </XUnits>
            </x:XData>
        </XmlDataProvider>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="125"></RowDefinition>
            <RowDefinition Height="85"></RowDefinition>
            <RowDefinition Height="85"></RowDefinition>
			<RowDefinition Height="95"></RowDefinition>
			<RowDefinition Height="95"></RowDefinition>
			<RowDefinition Height="95"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <GroupBox Header="版本号设置" Grid.Row="0">
            <UniformGrid Rows="2" Columns="8">
                <Label Content="IC类型"  HorizontalAlignment="Right" Margin="5"></Label>
                <ComboBox Margin="5" viewModel:TuningItem.ItemName="sig_fw" ItemsSource="{Binding Source={StaticResource Ic_Type_List}, XPath=XUnit}" DisplayMemberPath="@Name" SelectedValuePath="@DecValue"></ComboBox>
                <Label Content="Cfg版本" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="cfg_version"></TextBox>

                <Control></Control>
                <Control></Control>
                <Control></Control>
                <Control></Control>
                

                <Label Content="项目 ID" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="project_name"></TextBox>
				<Label Content="供应商 ID" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="vendor_name"></TextBox>
				

                
            </UniformGrid>
        </GroupBox>
        <GroupBox Header="LCD分辨率设置" Grid.Row="1">
            <UniformGrid Columns="8">
                <Label Content="X轴分辨率" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="lcdX"></TextBox>
                <Label Content="Y轴分辨率" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="lcdY"></TextBox>
            </UniformGrid>
        </GroupBox>
        <GroupBox Header="TP总通道数设置" Grid.Row="2">
            <UniformGrid Columns="8">
                <Label Content="TX通道" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="tp_tx_n"></TextBox>
                <Label Content="RX通道" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="tp_rx_n"></TextBox>
            </UniformGrid>
        </GroupBox>
		<GroupBox Header="RX 线序" Grid.Row="3">
            <DataGrid viewModel:MaxtrixEx.Row="1" viewModel:MaxtrixEx.Col="12" viewModel:TuningItem.ItemName="rx_map" AutoGenerateColumns="False" CanUserReorderColumns="False" GridLinesVisibility="All" ColumnHeaderStyle="{x:Null}">
            </DataGrid>
        </GroupBox>
        <GroupBox Header="TX 线序" Grid.Row="4">
            <DataGrid viewModel:MaxtrixEx.Row="1" viewModel:MaxtrixEx.Col="12" viewModel:TuningItem.ItemName="tx_map" AutoGenerateColumns="False" CanUserReorderColumns="False" GridLinesVisibility="All" ColumnHeaderStyle="{x:Null}">
            </DataGrid>
        </GroupBox>
    </Grid>
</UserControl>
