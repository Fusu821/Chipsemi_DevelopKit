		copytextto(info.item.testName, _T("Waiting"), lengthof(_T("Waiting")));
		info.bSelected = pCfg570->way_to_start == START_BY_AUTO;
		info.jumpIfNG = false;
		if( !info.funAddr ) info.funAddr = new CRunTimeMethod<CTestBase>( this, &CTestBase::TP_WaitTest );
