void CTest570::PrepareSimulate( SimulateData& sm )
{
	unsigned char cmdID = sm.itemID & 0xff;
	unsigned char dataIndex = (sm.itemID >> 8) & 0xff;
	unsigned char sumCnt = 1;
	int iDesIndex = 0;

	//scap data
	if( sm.itemID == ((0xfa << 16) + 0x28) )
	{
		iDesIndex += pCfg570->rowsCnt * pCfg570->colsCnt;
		for( int iCol = 0; iCol <  pCfg570->colsCnt; iCol++ )
			sm.itemArray[iDesIndex++] = sm.itemData[0][iCol] * sumCnt;
		for( int iCol = 0; iCol < pCfg570->rowsCnt; iCol++ )
			sm.itemArray[iDesIndex++] = sm.itemData[1][iCol] * sumCnt;
	}
	else
	{
		for( int iRow = 0; iRow < sm.rows; iRow++ )
		{
			for( int iCol = 0; iCol < sm.cols; iCol++ )
			{
				if( iDesIndex >= sizeof(sm.itemArray)/sizeof(short) ) break;

				//int icPosition = pCfg570->sensor_2_ic_map[index];
				sm.itemArray[iDesIndex++] = sm.itemData[iRow][iCol] * sumCnt;
			}
		}
	}
}

unsigned int CTest570::MISC_Test( NativeTestItem& itemQuote )
{
	int failerCnt = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR, errCode = 0;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );
	//char tempBuffer[MAX_PATH];

	TestResultInfo( _T("\r\n------------------------------MISC Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip570* iChip570 = (ISMChip570*)SM_ChipBase(m_deviceNo);

	unsigned short rsp[8] = {0};
	iReCode = iChip570->IncokeCommand( CMD_MISC_TST, pCfg570->misc_mode, 0, 0, (unsigned char*)rsp );
	if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	if(rsp[1])
	{
		failerCnt++;
		//transformat( tempBuffer, _T("Misc(%d), Code = 0x%x\r\n"), rsp[1],  (rsp[2] << 16) + rsp[3]);
		//TestResultInfo( tempBuffer );
		TestResultInfoR( _T("Misc(%d), Code = 0x%x\r\n"), rsp[1],  (rsp[2] << 16) + rsp[3] );
	}

	if( failerCnt )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//MISC Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//MISC Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}

unsigned int CTest570::AverageData(short* buff, int len)
{
	int sum =0;
	short* data = (short*)buff;

	for (int i = 0; i< len; i++)
	{
		sum = sum + data[i];
	}

	return sum/len;
}

unsigned int CTest570::FSD_Test(NativeTestItem& itemQuote)
{
	int failerCount = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );
	signed short baseTempBuffer[MAX_MCAP_CHANNEL * 2] = {0};
	short fdataMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];
	short sdataMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];
	short diffMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];
	short basediffMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];
	const unsigned int iRawDataLen = ((pCfg570->rowsCnt + 1) * (pCfg570->colsCnt + 1) * 2 + 3) & 0xfffffffc;
	const unsigned int iScapRawDataLen = pCfg570->rowsCnt + pCfg570->colsCnt;
	unsigned short retBuffer[16] = {0};
	unsigned int data_addr = 0;

	int ref_channel_num = min(pCfg570->real_channel_num - pCfg570->va_channel_num, pCfg570->colsCnt);
	AnalyzeInfo info( pCfg570->rowsCnt, pCfg570->colsCnt, ref_channel_num, false );

	TestResultInfo( _T("\r\n------------------------------FSD Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip570* iChip570 = (ISMChip570*)SM_ChipBase(m_deviceNo);

	iReCode = iChip570->IncokeCommand(CMD_FSD_TST );
	if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand(CMD_IDENTITY,0,0,0,(unsigned char*)retBuffer);
	if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	if ((retBuffer[1] + retBuffer[2] != 0xffff) || (retBuffer[1] != 0xe903))
	{
		return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	}

	data_addr = (retBuffer[4] <<16) | retBuffer[3];

	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand(CMD_CTP_PMU, pCfg570->fsd_xy_num|pCfg570->fsd_i2v_rfb<<8,
		pCfg570->fsd_lpf_sft|pCfg570->fsd_dec_sft<<8, pCfg570->fsd_c2v_rfb|pCfg570->fsd_rx_rin<<8,(unsigned char*)retBuffer);
	if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand(CMD_CTP_FREQ,0x15,pCfg570->fsd_fast_div, pCfg570->fsd_frames);
	if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	for (int k=0; k<100; k++)
	{
		SysDelay(20);
		iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand(CMD_CTP_FREQ,0x15,100, 0,(unsigned char*)retBuffer);
		if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
		unsigned short d0 = retBuffer[1];
		if(1 == d0)
		{
			break;

		}else if(0 == d0)
		{
			TestResultInfoR("\r\nGet fast freq data fail!!!");
			return itemNotify.UpdateItemResult( ITEM_STA_FAIL);
		}
		if (k > 30)
		{
			TestResultInfoR("\r\nGet fast freq data timeout!!!");
			return itemNotify.UpdateItemResult( ITEM_STA_FAIL);
		}

	}

	//iReCode = iChip570->GetFwData((short*)baseTempBuffer, iRawDataLen );
	iReCode = iChip570->ReadCoreSpace(data_addr,(unsigned char*)baseTempBuffer, iRawDataLen );
	if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	ReShappingData</*unsigned*/ short>( fdataMatrix, (/*unsigned*/ short*)baseTempBuffer, G_XMLConfig->real_channel_num * 2, pCfg570->rowsCnt, pCfg570->colsCnt );

	ColorText textTempa( _T("\r\nfsd_fast:\r\n") );
	PrintMaxtrixValue<short,MAX_MCAP_ROW, MAX_MCAP_COL> ( textTempa, fdataMatrix,pCfg570->invalid_node, info, true );
	TestResultInfo( textTempa );

	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand(CMD_CTP_FREQ,0x15,pCfg570->fsd_slow_div, pCfg570->fsd_frames);
	if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	for (int k=0; k<100; k++)
	{
		SysDelay(20);
		iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand(CMD_CTP_FREQ,0x15,100, 0,(unsigned char*)retBuffer);
		if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
		unsigned short d0 = retBuffer[1];
		if(1 == d0)
		{
			break;

		}else if(0 == d0)
		{
			TestResultInfoR("\r\nGet fast freq data fail!!!");
			return itemNotify.UpdateItemResult( ITEM_STA_FAIL);
		}
		if (k > 30)
		{
			TestResultInfoR("\r\nGet fast freq data timeout!!!");
			return itemNotify.UpdateItemResult( ITEM_STA_FAIL);
		}

	}

	//iReCode = iChip570->GetFwData((short*)baseTempBuffer, iRawDataLen );
	iReCode = iChip570->ReadCoreSpace(data_addr,(unsigned char*)baseTempBuffer, iRawDataLen );
	if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	ReShappingData</*unsigned*/ short>( sdataMatrix, (/*unsigned*/ short*)baseTempBuffer, G_XMLConfig->real_channel_num * 2, pCfg570->rowsCnt, pCfg570->colsCnt );

	textTempa = ( _T("\r\nfsd_slow:\r\n") );
	PrintMaxtrixValue<short,MAX_MCAP_ROW, MAX_MCAP_COL> ( textTempa, sdataMatrix,pCfg570->invalid_node, info, true );
	TestResultInfo( textTempa );

	if (pCfg570->fsd_fast_mcap_test == 1)
	{
		NodeVal nodeOutRange;
		ColorText textTemp = (_T("\r\nfast_macap_tset:\r\n")) ;
		bool bResult = AnalyzeTestResult<short, unsigned short, unsigned short, MAX_MCAP_ROW, MAX_MCAP_COL>( fdataMatrix, pCfg570->fsd_fast_min,pCfg570->fsd_fast_max, pCfg570->invalid_node, info, textTemp, nodeOutRange, true );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			failerCount++;
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in macap: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
		}

	}

	fsd_diff<short,short,MAX_MCAP_ROW, MAX_MCAP_COL>(diffMatrix,fdataMatrix,sdataMatrix,pCfg570->rowsCnt,pCfg570->colsCnt);
	textTempa = ( _T("\r\nfsd_data:\r\n") );
	PrintMaxtrixValue<short,MAX_MCAP_ROW, MAX_MCAP_COL> ( textTempa, diffMatrix,pCfg570->invalid_node, info, true );
	TestResultInfo( textTempa );

	fsd_diff<short,unsigned short,MAX_MCAP_ROW, MAX_MCAP_COL>(basediffMatrix,pCfg570->fsd_fast,pCfg570->fsd_slow,pCfg570->rowsCnt,pCfg570->colsCnt);

	textTempa = ( _T("\r\nfsd_base_data:\r\n") );
	PrintMaxtrixValue<short,MAX_MCAP_ROW, MAX_MCAP_COL> ( textTempa, basediffMatrix,pCfg570->invalid_node, info, true );
	TestResultInfo( textTempa );

	textTempa = ( _T("\r\nfsd_diff:\r\n") );
	MatrixSubtraction<short, short, short, MAX_MCAP_ROW, MAX_MCAP_COL>(diffMatrix,basediffMatrix,diffMatrix,pCfg570->rowsCnt,pCfg570->colsCnt);
	PrintMaxtrixValue<short,MAX_MCAP_ROW, MAX_MCAP_COL> ( textTempa, diffMatrix,pCfg570->invalid_node, info, true );
	TestResultInfo( textTempa );

	fsd_LineSubtraction<short, short, MAX_MCAP_ROW, MAX_MCAP_COL>(basediffMatrix,diffMatrix,pCfg570->rowsCnt,pCfg570->colsCnt,true);

	unsigned short mindata[MAX_MCAP_ROW][MAX_MCAP_COL];
	FillMatrixUseValue( mindata, (unsigned short)0 );

	NodeVal nodeOutRange;
	ColorText textTemp = (_T("\r\nfsd_final_diff:\r\n")) ;
	bool bResult = AnalyzeTestResult<short, unsigned short, unsigned short, MAX_MCAP_ROW, MAX_MCAP_COL>( basediffMatrix, mindata, pCfg570->fsd_diff_max, pCfg570->invalid_node, info, textTemp, nodeOutRange, true );
	TestResultInfo( textTemp );
	if( !bResult )
	{
		failerCount++;
		LPCTSTR strHead = _T("\r\n//========= Out of Threshold in base_diff: \r\n");
		PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
	}

	if( failerCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//FSD Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//FSD Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}

void CTest570::ICArrayToSensorMatrixVT(unsigned short (&dataOn)[1][MAX_MCAP_COL],unsigned short (&dataOff)[1][MAX_MCAP_COL], unsigned short* const dataToMapping)
{
	for( int iRx = 0; iRx < pCfg570->rowsCnt; iRx++ )
	{
		unsigned short icChannel = pCfg570->sensor_2_ic_map[iRx + MAX_TX_NUM_570];
		dataOff[0][iRx] = dataToMapping[icChannel];
		dataOn[0][iRx] = dataToMapping[icChannel + 42];
	}
}

unsigned int CTest570::WBase_Test(NativeTestItem& itemQuote)
{
	int failerCount = 0;
	unsigned short retBuffer[16];
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );
	short baseTempBuffer[MAX_MCAP_CHANNEL] = {0};
	short baseTempBuffer1[MAX_MCAP_CHANNEL] = {0};
	short mcap_dataMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];
	short scap_dataMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];

	const unsigned short (*tmp_base[8])[MAX_MCAP_COL]={pCfg570->tmp_1_mcapdata, pCfg570->tmp_2_mcapdata, pCfg570->tmp_3_mcapdata, pCfg570->tmp_4_mcapdata, pCfg570->tmp_5_mcapdata, pCfg570->tmp_6_mcapdata, pCfg570->tmp_7_mcapdata, pCfg570->tmp_8_mcapdata};

	const unsigned int iRetry = 10;

	const unsigned int iRawDataLen = ((pCfg570->rowsCnt * pCfg570->colsCnt + pCfg570->rowsCnt + pCfg570->colsCnt) * 2 + 3) & 0xfffffffc;
	const unsigned int iScapRawDataLen = pCfg570->rowsCnt + pCfg570->colsCnt;

	unsigned char writeBuffer[20*1024] = {0};
	memset(writeBuffer,0xff,sizeof(writeBuffer));//必须初始化成0xff

	unsigned char readBuffer[20*1024] = {0};
	memset(readBuffer,0xff,sizeof(readBuffer));//必须初始化成0xff

	short diff_dataMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];

	raw_flash_info* tmp_data;
	tmp_data = (raw_flash_info*)&writeBuffer[0];

	TestResultInfo( _T("\r\n------------------------------WBase Data Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip570* iChip570 = (ISMChip570*)SM_ChipBase(m_deviceNo);

	int addRow = ( pCfg570->real_channel_num - pCfg570->va_channel_num ) ? 1 : 0;

	int ref_channel_num = min(pCfg570->real_channel_num - pCfg570->va_channel_num, pCfg570->colsCnt);
	AnalyzeInfo info( pCfg570->rowsCnt, pCfg570->colsCnt );
	unsigned short maxCols[] = { pCfg570->colsCnt, pCfg570->rowsCnt };

	ColorText textTemp;

	tmp_data->sig = FLASH_SAVE_SIG;
	tmp_data->sizeHead = sizeof(raw_flash_info);
	tmp_data->cnt = 1;
	tmp_data->version = 1;
	tmp_data->type = 0;
	tmp_data->lenSingle = iRawDataLen;
	tmp_data->lenTotal = sizeof(raw_flash_info) + iRawDataLen * pCfg570->tmp_num;
	tmp_data->head2En = 0;
	tmp_data->chkHead = 0;
	tmp_data->chkAll = 0;

	SYSTEMTIME SysTime;
	::GetLocalTime(&SysTime);
	tmp_data->time = (SysTime.wMonth << 22) + (SysTime.wDay << 17) + (SysTime.wHour << 12) + (SysTime.wMinute << 6) + SysTime.wSecond;

	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand( CMD_SWITCH_IIC );
	if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	SysDelay( 10 );

	iReCode = SM_ChipBase(m_deviceNo)->EraseBurnSpace( USR_ROM_FACTORY_START, 20 * 1024);
	if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand( CMD_CTP_RST );
	if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	SysDelay( 200 );

	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand( CMD_SWITCH_IIC );
	if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	SysDelay( 10 );

	iReCode = iChip570->SwitchMode( MODE_RAWDATA, iRawDataLen );
	if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	for(int i = 0; i < 8; i++)
	{
		if (i < pCfg570->tmp_num)
		{ 
			iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand(CMD_CTP_FREQ,0x15,i + 1, 20);
			if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

			for (int k=0; k<100; k++)
			{
				SysDelay(20);
				iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand(CMD_CTP_FREQ,0x15,100, 0,(unsigned char*)retBuffer);
				if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
				unsigned short d0 = retBuffer[1];
				if(1 == d0)
				{
					break;

				}else if(0 == d0)
				{
					TestResultInfoR("\r\nGet fast freq data fail!!!");
					return itemNotify.UpdateItemResult( ITEM_STA_FAIL);
				}
				if (k > 30)
				{
					TestResultInfoR("\r\nGet fast freq data timeout!!!");
					return itemNotify.UpdateItemResult( ITEM_STA_FAIL);
				}

			}

			iReCode = iChip570->GetFwData((short*)baseTempBuffer, iRawDataLen );
			if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

		}
		else
		{
			memset(baseTempBuffer,0,sizeof(baseTempBuffer));
			break;
		}

		auto str = StrFormat("\r\ntmp_%d_mcapdata:\r\n",i+1);
		textTemp+=str;

		ReShappingData</*unsigned*/ short>( mcap_dataMatrix, (/*unsigned*/ short*)baseTempBuffer, G_XMLConfig->real_channel_num * 2, pCfg570->rowsCnt, pCfg570->colsCnt );
		PrintMaxtrixValue<short, MAX_MCAP_ROW, MAX_MCAP_COL>( textTemp, mcap_dataMatrix, info, true );

		str = StrFormat("\r\ntmp_%d_scapdata:\r\n",i+1);
		textTemp+=str;
		ReShappingData</*unsigned*/ short>( scap_dataMatrix, (/*unsigned*/ short*)baseTempBuffer + pCfg570->rowsCnt * pCfg570->colsCnt, iScapRawDataLen, 2, maxCols );
		PrintScapData<short, MAX_MCAP_ROW, MAX_MCAP_COL>( textTemp, scap_dataMatrix, pCfg570->tmp_invalid_node, info, true );

		str = StrFormat("\r\nnormalization_%d_mcapdata:\r\n",i+1);
		textTemp+=str;
		tmp_data_normalization<short, short, MAX_MCAP_ROW, MAX_MCAP_COL>(mcap_dataMatrix, mcap_dataMatrix, pCfg570->rowsCnt, pCfg570->colsCnt,1);
		PrintMaxtrixValue<short, MAX_MCAP_ROW, MAX_MCAP_COL>( textTemp, mcap_dataMatrix, info, true );

		str = StrFormat("\r\nnormalization_%d_bmcapdata:\r\n",i+1);
		textTemp+=str;
		PrintMaxtrixValue<const unsigned short, MAX_MCAP_ROW, MAX_MCAP_COL>( textTemp, tmp_base[i], info, true );

		MatrixSubtraction<short, short, const unsigned short, MAX_MCAP_ROW, MAX_MCAP_COL>(diff_dataMatrix, mcap_dataMatrix, tmp_base[i], MAX_MCAP_ROW, MAX_MCAP_COL);	

		str = StrFormat("\r\ndiff_%d_mcapdata:\r\n",i+1);
		textTemp+=str;
		/*调试屏蔽*/
		PrintMaxtrixValue<short, MAX_MCAP_ROW, MAX_MCAP_COL>( textTemp, diff_dataMatrix, info, true );

		ConvertShappingData<short, MAX_MCAP_ROW, MAX_MCAP_COL>(baseTempBuffer1,diff_dataMatrix, G_XMLConfig->real_channel_num * 2, pCfg570->rowsCnt, pCfg570->colsCnt );

		RollingR pRolling;
		pRolling.RollingNoiseFit1(baseTempBuffer1,(unsigned char)pCfg570->rowsCnt, (unsigned char)pCfg570->colsCnt);

		ReShappingData</*unsigned*/ short>( diff_dataMatrix, (/*unsigned*/ short*)baseTempBuffer1, G_XMLConfig->real_channel_num * 2, pCfg570->rowsCnt, pCfg570->colsCnt );

		MatrixInvalidSet<short, MAX_MCAP_ROW, MAX_MCAP_COL>(diff_dataMatrix, pCfg570->tmp_invalid_node, MAX_MCAP_ROW, MAX_MCAP_COL, 0);

		str = StrFormat("\r\nfinal_diff_%d_mcapdata:\r\n",i+1);
		textTemp+=str;

		NodeVal nodeOutRange;
		bool bResult = WTmpDiffAnalyzeTestResult<short, MAX_MCAP_ROW,MAX_MCAP_COL>(diff_dataMatrix, pCfg570->rowsCnt, pCfg570->colsCnt, pCfg570->wbase_node33_diff_max, pCfg570->wbase_node33_num_max,
			pCfg570->wbase_all_diff_max, pCfg570->wbase_all_num_max, textTemp, nodeOutRange);
		if (!bResult)
		{
			failerCount++;
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in Wbase Test: \r\n");
			PrintBaseNodeValue( textTemp, &nodeOutRange, strHead );
		}

		if ((failerCount == 0))
		{
			memcpy((unsigned char*)&writeBuffer[sizeof(raw_flash_info)+(i * iRawDataLen)],(unsigned char*)baseTempBuffer,iRawDataLen);
			unsigned int chk = caculate_check_sum_u32((unsigned int*)baseTempBuffer, iRawDataLen);
			tmp_data->chk[i] = chk;
			tmp_data->chkAll += chk;

		}
	}

	TestResultInfo( textTemp );

	if ((failerCount == 0))
	{
		tmp_data->chkCfgCdsp = caculate_check_sum_u32((unsigned int*)&pCfg570->cfgBinBuffer[CFG_CDSP_OFFSET], CFG_CDSP_SIZE);
		tmp_data->chkHead = 0 - caculate_check_sum_u32((unsigned int*)tmp_data, sizeof(raw_flash_info));
		memcpy((unsigned char*)&writeBuffer[sizeof(raw_flash_info)+(pCfg570->tmp_num * iRawDataLen)],(unsigned char*)pCfg570->cfgBinBuffer,pCfg570->cfgBinSize);

		iReCode = SM_ChipBase(m_deviceNo)->WriteBurnSpace( USR_ROM_FACTORY_START, writeBuffer, sizeof(writeBuffer), OTP_W_CHK | TLK_DATACHK_EX1);
		if( iReCode != ERROR_CODE_OK )
		{
			TestResultInfoR("\r\nWrite base data fail!!!");
			return itemNotify.UpdateItemResult( ITEM_STA_FAIL, GetErrorMessage( iReCode ) );
		}

		iReCode = SM_ChipBase(m_deviceNo)->ReadBurnSpace( USR_ROM_FACTORY_START, readBuffer, sizeof(readBuffer));
		if( iReCode != ERROR_CODE_OK )
		{
			TestResultInfoR("\r\nRead base data fail!!!");
			return itemNotify.UpdateItemResult( ITEM_STA_FAIL, GetErrorMessage( iReCode ) );
		}

		tmp_data = (raw_flash_info*)&readBuffer[0];

		for (int i=0; i<sizeof(readBuffer); i++)
		{
			if (readBuffer[i] != writeBuffer[i])
			{
				TestResultInfoR("\r\nCheck base data fail!!!");
				failerCount++;

				break;
			}

		}
	}

	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand( CMD_CTP_RST );
	if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	SysDelay( 200 );

	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand(CMD_CTP_FREQ,0x0c,2);
	if( iReCode != ERROR_CODE_OK )
	{
		TestResultInfoR("\r\nIC check base data fail!!!");

		iReCode = SM_ChipBase(m_deviceNo)->EraseBurnSpace( USR_ROM_FACTORY_START, 4 * 1024);
		if( iReCode != ERROR_CODE_OK )
		{
			TestResultInfoR("\r\nErase base data fail!!!");
		}

		failerCount++;
	}

	if( failerCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//WBaseData Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//WBaseData Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;

}

