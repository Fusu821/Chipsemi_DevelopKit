//00 no test; 01 normal test; 10 force paint 
#define TEST_FLOW_TYPE                  (0x03 << 0)

//0 data test; 1 graph test
#define TEST_TARGET_KING                (1 << 2)

//0 not stop; 1 stop
#define STOP_RUNING_LOOP                (1 << 3)

//0 flow is off; 1 flow is on
#define ONE_TEST_FLOW_ON                (1 << 4)

//0 not check; 1 checked
#define CHECK_MKT_UPDATE                (1 << 5)

//0 not over; 1 over
#define TEST_GAME_OVER                  (1 << 6)

  
#define InitTestStatus()                (m_TestOperation = 0) 
#define SetTestStatus(x)                (m_TestOperation |= x)              

#define SetOperationEmpty(p)            do{p->m_TestOperation &= ~TEST_FLOW_TYPE; p->m_TestOperation |= 0x0000;}while(0)
#define SetOperationNormal(p)           do{p->m_TestOperation &= ~TEST_FLOW_TYPE; p->m_TestOperation |= 0x0001;}while(0)
#define SetOperationForcePaint(p)       do{p->m_TestOperation &= ~TEST_FLOW_TYPE; p->m_TestOperation |= 0x0002;}while(0)
#define DoOperationNarmal(ptrTest)      (0x0001 == (ptrTest->m_TestOperation & TEST_FLOW_TYPE))
#define DoOperationForcePaint(ptrTest)  (0x0002 == (ptrTest->m_TestOperation & TEST_FLOW_TYPE))
#define DoOperationEmpty(ptrTest)       (0x0000 == (ptrTest->m_TestOperation & TEST_FLOW_TYPE))

#define SetTestStatusInDataStep()       (m_TestOperation &= ~TEST_TARGET_KING)       
#define SetTestStatusInGraphStep()      (m_TestOperation | TEST_TARGET_KING)
#define IsTestInGraphStep()             ((m_TestOperation & TEST_TARGET_KING) > 0)

#define SetLoopRuning()                 (m_TestOperation &= ~STOP_RUNING_LOOP)
#define StopLoopRuning()                (m_TestOperation |= STOP_RUNING_LOOP)
#define IsLoopStillRun()                (0 == (m_TestOperation & STOP_RUNING_LOOP))    

#define SetTestFlowOnLine()             (m_TestOperation |= ONE_TEST_FLOW_ON)
#define SetTestFlowOffLine()            (m_TestOperation &= ~ONE_TEST_FLOW_ON)
#define IsTestStillOnLine(p)            ((p->m_TestOperation & ONE_TEST_FLOW_ON) > 0)

// #define TestTriggerOn()                 (m_TestOperation |= WAIT_START_TRIGGER)  
// #define TestTiggerOff()                 (m_TestOperation &= ~WAIT_START_TRIGGER)
// #define TestTiggered()                  ((m_TestOperation & WAIT_START_TRIGGER) > 0)

#define SetGameOver()                   (m_TestOperation |= (STOP_RUNING_LOOP | TEST_GAME_OVER))
#define IsGameOver(p)                    ((p->m_TestOperation & TEST_GAME_OVER) > 0)

#define SetMtkUpdatedMark()             (m_TestOperation |= CHECK_MKT_UPDATE)
#define ClearMtkUpdatedMark()           (m_TestOperation &= (~CHECK_MKT_UPDATE))
#define HasMtkUpdated()                 ((m_TestOperation & CHECK_MKT_UPDATE) > 0)
