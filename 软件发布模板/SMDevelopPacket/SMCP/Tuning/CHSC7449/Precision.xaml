<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewModel="clr-namespace:SEMIDevelopKit.Src.WinSub"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
			<RowDefinition Height="485"></RowDefinition>
			<RowDefinition Height="125"></RowDefinition>
        </Grid.RowDefinitions>
		
        <GroupBox Header="13.1：精度调整(拉伸、截位、平移)" Grid.Row="0">
            <UniformGrid Rows="11">    
				<UniformGrid Columns="16">
					<Label Content="LCD-X坐标位移" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemName="xShift"></TextBox>
					<Label Content="LCD-Y坐标位移" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemName="yShift"></TextBox>
				</UniformGrid>
				
				<UniformGrid Columns="16">
					<Control></Control>
				</UniformGrid>
				
                <UniformGrid Columns="16">
                    <Label Content="上半部整体拉伸" HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5" viewModel:TuningItem.ItemName="cut_up"></TextBox>
                    <Label Content="下半部整体拉伸" HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5" viewModel:TuningItem.ItemName="cut_down"></TextBox>
                </UniformGrid>
				
                <UniformGrid Columns="16">
                    <Label Content="左半部整体拉伸" HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5" viewModel:TuningItem.ItemName="cut_left"></TextBox>
                    <Label Content="右半部整体拉伸" HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5" viewModel:TuningItem.ItemName="cut_right"></TextBox>
                </UniformGrid>
				
				<UniformGrid Columns="16">
					<Control></Control>
				</UniformGrid>
				
				<UniformGrid Columns="16">
                    <Label Content="边缘拉伸 距边距离 T" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemName="stretchEdgeT"></TextBox>
                    <Label Content="拉边系数 T" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemName="stretchRatioT"></TextBox>
                </UniformGrid>
			
				<UniformGrid Columns="16">
                    <Label Content="边缘拉伸 距边距离 B" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemName="stretchEdgeB"></TextBox>
                    <Label Content="拉边系数 B" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemName="stretchRatioB"></TextBox>
                </UniformGrid>

				<UniformGrid Columns="16">
                    <Label Content="边缘拉伸 距边距离 L" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemName="stretchEdgeL"></TextBox>
                    <Label Content="拉边系数 L" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemName="stretchRatioL"></TextBox>
                </UniformGrid>
				
				<UniformGrid Columns="16">
                    <Label Content="边缘拉伸 距边距离 R" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemName="stretchEdgeR"></TextBox>
                    <Label Content="拉边系数 R" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemName="stretchRatioR"></TextBox>
                </UniformGrid>
				
				<UniformGrid Columns="16">
					<Control></Control>
				</UniformGrid>
				
                <UniformGrid Columns="16">
					<Label Content="报点内缩 X" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemName="marginX"></TextBox>
					<Label Content="报点内缩 Y" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemName="marginY"></TextBox>
					<Label Content="[7:4]:上/左, [3:0]:下/右(LCD分辨率)" HorizontalAlignment="Left" Margin="5"></Label>
                </UniformGrid>
            </UniformGrid>
        </GroupBox>
		
		<GroupBox Header="13.2：水滴位置精度调整" Grid.Row="1">
            <UniformGrid Rows="2">    
				<UniformGrid Columns="16">
					<Label Content="水滴半径占用通道" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemName="DropChannelRatio"></TextBox>
					<Label Content="单位0.1通道，默认18=1.8个通道" HorizontalAlignment="Left" Margin="5"></Label>
				</UniformGrid>
				
			    <UniformGrid Columns="16">
					<Label Content="坐标拉伸强度" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemName="DropStretchRatio"></TextBox>
					<Label Content="35=3.5倍默认强度" HorizontalAlignment="Left" Margin="5"></Label>
				</UniformGrid>
            </UniformGrid>
        </GroupBox>
		
    </Grid>
</UserControl>
