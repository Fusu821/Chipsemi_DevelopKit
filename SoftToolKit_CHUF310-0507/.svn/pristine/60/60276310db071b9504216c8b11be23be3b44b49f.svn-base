<Page x:Class="SEMITestApp.Src.WinSet.CommonSet"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
      mc:Ignorable="d" 
      xmlns:app_util="clr-namespace:SEMITestApp.Src.Util"
      d:DesignHeight="1000" d:DesignWidth="800"
	Title="CommonSet" IsVisibleChanged="CommonSet_IsVisibleChanged">
<ScrollViewer VerticalScrollBarVisibility="Visible">
    <StackPanel Orientation="Vertical" Height="1300">
        <GroupBox Header="Misc">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                 </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Label Content="Mode" Grid.Row="0" HorizontalAlignment="Right" Margin="5"></Label>
                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding ListModes}" SelectedValue="{Binding TestMode}" SelectedValuePath="TypeVal" DisplayMemberPath="TypeName" Margin="5"></ComboBox>
                <Label Grid.Row="0" Grid.Column="2" Content="HoldUp" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="3" Text="{Binding HoldUp}" Grid.Row="0" Grid.Column="3"></TextBox>
                
                <Label Content="Way to Start" Grid.Row="1" HorizontalAlignment="Right" Margin="5"></Label>
                <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding ListStartKind}" SelectedValue="{Binding WayToStart}" SelectedValuePath="TypeVal" DisplayMemberPath="TypeName" Margin="5"></ComboBox>
                <Label Grid.Row="1" Content="SN Len" HorizontalAlignment="Right" Visibility="{Binding WayToStart, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=3}" Grid.Column="2" Margin="5"></Label>
                <TextBox Grid.Row="1" Margin="5" Text="{Binding SNLen}" Grid.Column="3" Visibility="{Binding WayToStart, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=3}"></TextBox>
                <CheckBox Grid.Row="1" Grid.Column="5" Margin="5" Content="NeedClickStart" IsChecked="{Binding NeedClickStart}"  Visibility="{Binding WayToStart, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=3}"></CheckBox>

                <Label Grid.Row="2" Content="Result-Format" HorizontalAlignment="Right" Margin="5"></Label>
                <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding ListFormat}" SelectedValue="{Binding SelectedFormat}" SelectedValuePath="TypeVal" DisplayMemberPath="TypeName" Margin="5"></ComboBox>

                <Label Grid.Row="2" Grid.Column="2" Content="Heatbeat-Voltate" HorizontalAlignment="Right" Margin="5"></Label>
                <ComboBox Grid.Row="2" Grid.Column="3" ItemsSource="{Binding ListHeatbeatVol}" SelectedValuePath="TypeVal" DisplayMemberPath="TypeName" SelectedValue="{Binding SelectedHeatBeatVol}" Margin="5"></ComboBox>
                <CheckBox Grid.Row="2" Grid.Column="5" Margin="5" Content="NeedRemoveIC" IsChecked="{Binding NeedRemoveIC}"></CheckBox>

                <Label Grid.Row="3" Content="User-Record" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" Text="{Binding UserRecord}" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"></TextBox>

                <Label Grid.Row="4" Content="Log-Path" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" Text="{Binding LogPath}" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3"></TextBox>
                <Button Grid.Row="4" Grid.Column="4" Content="Path" Margin="5">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <i:InvokeCommandAction Command="{Binding ctrlClickCommand}" CommandParameter="log-path-click"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Button>
                <Label Content="SNFilter" Grid.Row="5" Grid.Column="0"  HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5"  Grid.Row="5" Grid.Column="1"  Grid.ColumnSpan="3" Text="{Binding SNFilter}"></TextBox>
                </Grid>
        </GroupBox>

        <GroupBox Header="FileUpload">
            <UniformGrid Rows="4" Columns="5">
                <Label Content="Protocal" HorizontalAlignment="Right" Margin="5"></Label>
                <ComboBox ItemsSource="{Binding FtpServerList}" SelectedValuePath="TypeVal" DisplayMemberPath="TypeName" SelectedValue="{Binding FtpType}" Margin="{StaticResource ItemMargin}"></ComboBox>
                <Control></Control>
                <Control></Control>
                <Control></Control>


                <Label Content="FTP Host" HorizontalAlignment="Right" Margin="5" Visibility="{Binding ServerType, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=2}"></Label>
                <TextBox Margin="5" Text="{Binding FtpIpAddr}" Visibility="{Binding ServerType, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=2}"></TextBox>
                <Label Content="Port" HorizontalAlignment="Right" Margin="5" Visibility="{Binding ServerType, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=2}"></Label>
                <TextBox Margin="5" Text="{Binding FtpPortNum}" Visibility="{Binding ServerType, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=2}"></TextBox>
                <Control></Control>

                <Label Content="Account" HorizontalAlignment="Right" Margin="5" Visibility="{Binding ServerType, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=2}"></Label>
                <TextBox Margin="5" Text="{Binding FtpAccount}" Visibility="{Binding ServerType, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=2}"></TextBox>
                <Label Content="PassWord" HorizontalAlignment="Right" Margin="5" Visibility="{Binding ServerType, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=2}"></Label>
                <TextBox Margin="5" Text="{Binding FtpPassWord}" Visibility="{Binding ServerType, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=2}"></TextBox>
                <Control></Control>

                <Label Content="Relative Path" HorizontalAlignment="Right" Margin="5" Visibility="{Binding ServerType, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=2}"></Label>
                <TextBox Margin="5" Text="{Binding FtpRelativePath}" Visibility="{Binding ServerType, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=2}"></TextBox>
            </UniformGrid>
        </GroupBox>

        <GroupBox Header="Online">
            <UniformGrid Rows="3" Columns="5">
                <Label Content="Link Type" HorizontalAlignment="Right" Margin="5"></Label>
                <ComboBox ItemsSource="{Binding LinkTypeList}" SelectedValuePath="TypeVal" DisplayMemberPath="TypeName" SelectedValue="{Binding LinkType}" Margin="{StaticResource ItemMargin}"></ComboBox>
                <Control></Control>
                <Control></Control>
                <Control></Control>

                <Label Content="Port" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" Text="{Binding PortNum}"></TextBox>
                <Label Content="IP Addr" HorizontalAlignment="Right" Margin="5" Visibility="{Binding LinkType, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=2}"></Label>
                <app_util:IpAddressControl IP="{Binding IpAddr}" Visibility="{Binding LinkType, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=2}"></app_util:IpAddressControl>
                <Control></Control>
                <Label Content="SourcePort" HorizontalAlignment="Right" Margin="5" Visibility="{Binding LinkType, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=2}"></Label>
                <TextBox Margin="5" Text="{Binding PortSource}" Visibility="{Binding LinkType, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=2}"></TextBox>
            </UniformGrid>
        </GroupBox>

        <GroupBox Header="CustomV1" Visibility="{Binding SelectedFormat, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=3}">
            <UniformGrid Rows="1" Columns="6">
                <Label Content="LineID" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" Text="{Binding LineID}"></TextBox>
                <!--Control></Control>
                <Control></Control>
                <Control></Control>
                <Label Content="Account" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" Text="{Binding Account}"></TextBox>
                <Label Content="Password" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" Text="{Binding Password}"></TextBox-->
            </UniformGrid>
        </GroupBox>

        <GroupBox Header="CustomV2" Visibility="{Binding SelectedFormat, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=7}">
            <UniformGrid Rows="1" Columns="6">
                <Label Content="FixtureId" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" Text="{Binding Device_ID}"></TextBox>
                <Label Content="Station" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" Text="{Binding Process_name}"></TextBox>
            </UniformGrid>
        </GroupBox>
        <GroupBox Header="Custom_Ofilm" Visibility="{Binding SelectedFormat, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=8}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Label Content="MesUrl" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5"  Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding MesUrl}"></TextBox>
                <Label Content="StepId" Grid.Row="1" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5"  Grid.Row="1" Grid.Column="1"  Text="{Binding StepId}"></TextBox>
                <Label Content="TestStepId" Grid.Row="1" Grid.Column="2"  HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5"  Grid.Row="1" Grid.Column="3"  Text="{Binding TestStepId}"></TextBox>
                <Label Content="MacAddress" Grid.Row="1" Grid.Column="4"  HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5"  Grid.Row="1" Grid.Column="5"  Text="{Binding MacAddress}"></TextBox>
                <!--<Label Content="SNFilter" Grid.Row="2" Grid.Column="0"  HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5"  Grid.Row="2" Grid.Column="1"  Grid.ColumnSpan="3" Text="{Binding SNFilter}"></TextBox>-->
                </Grid>
        </GroupBox>
        
            <GroupBox Header="Custom_PBH" Visibility="{Binding SelectedFormat, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=9}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Label Content="上传地址" HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding MesUrl}"></TextBox>
                    <Label Content="治具编号" Grid.Row="1" HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="1" Grid.Column="1"  Text="{Binding FixtureId}"></TextBox>
                    <Label Content="工单编号" Grid.Row="1" Grid.Column="2"  HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="1" Grid.Column="3"  Text="{Binding TestStepId}"></TextBox>
                    <Label Content="站号" Grid.Row="1" Grid.Column="4"  HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="1" Grid.Column="5"  Text="{Binding EqpId}"></TextBox>
                    <Label Content="工号" Grid.Row="2" Grid.Column="0"  HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="2" Grid.Column="1"  Text="{Binding UserId}"></TextBox>
                    <Label Content="密码" Grid.Row="2" Grid.Column="2"  HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="2" Grid.Column="3"  Text="{Binding Password}"></TextBox>
                </Grid>

            </GroupBox>

            <GroupBox Header="Custom_ChuangWei" Visibility="{Binding SelectedFormat, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=13}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Label Content="url(上传地址)" HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding MesUrlCW}"></TextBox>
                    <Label Content="user(用户ID)" Grid.Row="1" HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="1" Grid.Column="1"  Text="{Binding UserIdCW}"></TextBox>
                    <Label Content="processcode(工站代码)" Grid.Row="1" Grid.Column="2"  HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="1" Grid.Column="3"  Text="{Binding TestStepIdCW}"></TextBox>
                    <Label Content="linecode(线体代码)" Grid.Row="1" Grid.Column="4"  HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="1" Grid.Column="5"  Text="{Binding LineIDCW}"></TextBox>
                    <Label Content="message(信息)" Grid.Row="2" Grid.Column="0"  HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="2" Grid.Column="1"  Text="{Binding EqpIdCW}"></TextBox>


                    <CheckBox Grid.Row="3" Grid.Column="1" Margin="5" Content="Simulation" IsChecked="{Binding SimulationUp}"></CheckBox>
                    <Label Content="orderno(订单号)" Grid.Row="3" Grid.Column="2"  HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="3" Grid.Column="3"  Text="{Binding FixtureIdCW}"></TextBox>
                    <Label Content="pcid(电脑IP)" Grid.Row="3" Grid.Column="4"  HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="3" Grid.Column="5"  Text="{Binding MacAddressCW}"></TextBox>
                </Grid>

            </GroupBox>

            <GroupBox Header="Custom_Hes" Visibility="{Binding SelectedFormat, Converter={StaticResource EnumerToVisibleConverter}, ConverterParameter=14}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Label Content="url(上传地址)" HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding MesUrlHes}"></TextBox>
                    <Label Content="machine_no(设备编号)" Grid.Row="1" HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="1" Grid.Column="1"  Text="{Binding MachineNoHes}"></TextBox>
                    <Label Content="lot_no(生产批次)" Grid.Row="1" Grid.Column="2"  HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="1" Grid.Column="3"  Text="{Binding LotNoHes}"></TextBox>
                    <Label Content="subop_no(工步)" Grid.Row="1" Grid.Column="4"  HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="1" Grid.Column="5"  Text="{Binding SubopNoHes}"></TextBox>
                    <Label Content="process_person(处理人员)" Grid.Row="2" Grid.Column="0"  HorizontalAlignment="Right" Margin="5"></Label>
                    <TextBox Margin="5"  Grid.Row="2" Grid.Column="1"  Text="{Binding PersonHes}"></TextBox>
                </Grid>

            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</Page>
