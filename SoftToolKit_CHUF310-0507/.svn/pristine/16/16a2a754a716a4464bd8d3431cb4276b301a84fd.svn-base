void mytolower(char *s){
	int len=strlen(s);
	for(int i=0;i<len;i++){
		if(s[i]>='A'&&s[i]<='Z'){
			s[i]+=32;//+32×Ş»»ÎŞĐˇĐ´
			//s[i]=s[i]-'A'+'a';
		}
	}
}

