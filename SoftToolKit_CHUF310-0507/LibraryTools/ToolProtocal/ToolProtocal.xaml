<UserControl x:Class="LibraryTools.ToolProtocal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LibraryTools"   
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="850">
    <UserControl.Resources>
        <local:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
    </UserControl.Resources>
    <Grid Background="#AAAAAA" AllowDrop="True" DragEnter="Grid_DragEnter" Drop="Grid_Drop"><!--Drop="ParserView_Drop" DragEnter="ParserView_DragEnter"-->
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="120"></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <RichTextBox VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Auto">
            <FlowDocument>
                <Paragraph>
                    <Run AllowDrop="True" Text="{Binding ModelToolProtocal.ProtocalParsed}"/>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>
        <GroupBox Grid.Row="1" Header="ProtocalType">
            <UniformGrid Rows="3" Columns="2">
                <RadioButton Content="I2C"      IsChecked="{Binding ModelToolProtocal.CurSelTranslate, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static local:EnumTranslateType.Translate_PackToIIC}}"></RadioButton>
                <RadioButton Content="SPI"      IsChecked="{Binding ModelToolProtocal.CurSelTranslate, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static local:EnumTranslateType.Translate_PackToSPI}}"></RadioButton>
                <RadioButton Content="Hex->Txt" IsChecked="{Binding ModelToolProtocal.CurSelTranslate, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static local:EnumTranslateType.Translate_HexToTxt}}"></RadioButton>
                <RadioButton Content="Txt->Hex" IsChecked="{Binding ModelToolProtocal.CurSelTranslate, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static local:EnumTranslateType.Translate_TxtToHex}}"></RadioButton>
                <RadioButton Content="SPI(s)"   IsChecked="{Binding ModelToolProtocal.CurSelTranslate, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static local:EnumTranslateType.Translate_PackToSPIx}}"></RadioButton>
                <RadioButton Content="USART"   IsChecked="{Binding ModelToolProtocal.CurSelTranslate, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static local:EnumTranslateType.Translate_PackToUSART}}"></RadioButton>
            </UniformGrid>
        </GroupBox>
        <UniformGrid Grid.Row="2" Rows="1" Columns="4">
            <CheckBox Content="PacketTime" Margin="20, 2" IsChecked="{Binding ModelToolProtocal.PacketTime}"></CheckBox>
            <TextBox Text="{Binding ModelToolProtocal.Pattern}" Margin="5, 2"></TextBox>
            <Button Content="ShotCuts" Command="{Binding ModelToolProtocal.ClickShotCuts}"  Background="Transparent" Margin="5, 2" ></Button>
            <Button Content="Pattern"  Command="{Binding ModelToolProtocal.ClickPattern}" Background="Transparent" Margin="5, 2"></Button>
        </UniformGrid>
    </Grid>
</UserControl>
