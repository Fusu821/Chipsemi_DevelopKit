/***********************************************************************************/
bool DoLinkTest( HANDLE hDevice, int& ucDeviceNo )
{
	unsigned char  ReCode = ERROR_CODE_OK;

#ifdef _MSC_VER
	int flag = 0;

	OVERLAPPED oWrite;
	memset((char*)&oWrite, 0, sizeof(OVERLAPPED));
	oWrite.hEvent = CreateEvent(NULL, TRUE, FALSE, NULL);
	ResetEvent(oWrite.hEvent);

	DWORD nBytesReaded = 0;
	unsigned char writeBuffer[] = { 0x02, (SM_MTK_DEVICE_NO_ADDR >> 8) & 0xff, (SM_MTK_DEVICE_NO_ADDR >> 0) & 0xff, 0 };
	if( DeviceIoControl( hDevice, IOCTL_USBPRINT_VENDOR_GET_COMMAND, writeBuffer, 4, (LPVOID)&flag, 8 + 4, &nBytesReaded, &oWrite ) )
	{
		ReCode = ERROR_CODE_OK;
	}
	else
	{
		DWORD dError = GetLastError();
		if( GetLastError() == ERROR_IO_PENDING )
		{
			long WaitResult = WaitForSingleObject( oWrite.hEvent, USB_RW_TIMEOUT );
			if( WaitResult == WAIT_OBJECT_0 )
			{
				ReCode = ERROR_CODE_OK;
			}
			else if( WaitResult == WAIT_TIMEOUT )
			{
				ReCode = ERROR_CODE_WAIT_RESPONSE_TIMEOUT;
				CancelIo(hDevice);  //close all I/O Operation
			}
			else
			{
				ReCode = ERROR_CODE_WRITE_USB_ERROR;
				CancelIo(hDevice);  //close all I/O Operation
			}
		}
		else
		{
			ReCode = ERROR_CODE_WRITE_USB_ERROR;
		}
	}

	//wasim
 	if( !VARIFY_DEVICE_NO_OK( flag ) )
 	{
// 		ReCode = ERROR_CODE_READ_USB_ERROR;
 	}
	ucDeviceNo = (flag & 0x0f) % MAX_DEVICE_NUM;
#endif

	return ERROR_CODE_OK == ReCode;
}
HDEVNOTIFY  hRegistNotify;
TCHAR arrayDevicePath[MAX_DEVICE_NUM][MAX_PATH] = {0};
bool EnumPrintDevice( const GUID* pInterfaceGUID, HANDLE (&arrayHandle)[MAX_DEVICE_NUM] )
{
	HANDLE handle = (HANDLE)INVALID_HANDLE_VALUE;

#ifdef _MSC_VER
	HDEVINFO hardwareDeviceInfo;
	//SP_DEVINFO_DATA hwInfoData;
	SP_INTERFACE_DEVICE_DATA deviceInfoData;
	PSP_INTERFACE_DEVICE_DETAIL_DATA functionClassDeviceData = NULL;
	ULONG predictedLength = 0;
	ULONG requiredLength  = 0;
	ULONG hwpredictedLength = 254;
	ULONG hwrequiredLength  = 254;

	//TCHAR lpPath[MAX_PATH] = {0};//ĐÂĽÓ»ńČˇHIDÉč±¸ĘµŔýÂ·ľ¶˛éŐŇ×Ö·ű´®
	//::GetModuleFileName( GetModuleHandle( _T("SEMITouch.dll") ), lpPath, MAX_PATH );
	//*(_tcsrchr( lpPath, _T('\\') ) + 1) = 0;
	//copytextappend(lpPath, _T("Ini.ini"));
	//LPTSTR PathInfor= new char[128];
	//GetPrivateProfileString("HIDIIC", "PathInfor", "", PathInfor, 128, lpPath);
	//mytolower(PathInfor);

	deviceInfoData.cbSize = sizeof(SP_INTERFACE_DEVICE_DATA);
	hardwareDeviceInfo = SetupDiGetClassDevs( pInterfaceGUID, NULL, NULL, (DIGCF_PRESENT|DIGCF_DEVICEINTERFACE) );
	for (int i = 0; i < 128; i++)
	{
		//±éŔúËůÓĐµÄUSBÉč±¸
		if (!SetupDiEnumDeviceInterfaces( hardwareDeviceInfo, 0, pInterfaceGUID, i, &deviceInfoData) ) continue;
		SetupDiGetDeviceInterfaceDetail( hardwareDeviceInfo, &deviceInfoData, NULL, 0, &requiredLength, NULL );
		predictedLength = requiredLength;
		functionClassDeviceData = (PSP_INTERFACE_DEVICE_DETAIL_DATA)malloc(predictedLength);
		if (!functionClassDeviceData) continue;
		functionClassDeviceData->cbSize = sizeof(SP_INTERFACE_DEVICE_DETAIL_DATA);
		if (!SetupDiGetDeviceInterfaceDetail(hardwareDeviceInfo, &deviceInfoData, functionClassDeviceData, predictedLength, &requiredLength, NULL)) 
		{
			free( functionClassDeviceData );
			break;
		}

		if((NULL != findtext( functionClassDeviceData->DevicePath, _T("vid_248a&pid_"))))//ÁŞĎëĐˇĐÂhid#msft0001&col03  || (NULL != findtext(functionClassDeviceData->DevicePath, PathInfor))
		{
			static int iDeviceIndex = 0;
			if(*pInterfaceGUID == IID_SMHIDGUID && INVALID_HANDLE_VALUE != handle) break;

			handle = CreateFile( functionClassDeviceData->DevicePath, GENERIC_READ|GENERIC_WRITE, FILE_SHARE_READ|FILE_SHARE_WRITE, NULL, OPEN_EXISTING, FILE_FLAG_OVERLAPPED, NULL );
			if ( handle == INVALID_HANDLE_VALUE )
			{
				free( functionClassDeviceData );
				continue;
			}

			if( *pInterfaceGUID == IID_SMUSBGUID && !DoLinkTest( handle, iDeviceIndex ) ) 
			{
				CloseHandle( handle );
				free( functionClassDeviceData );
				continue;
			}

			if( NULL != arrayHandle[iDeviceIndex] )
			{
				//¸ĂIDµÄÉč±¸ŇŃľ­±»´ňżŞąýÁË 
				CloseHandle( arrayHandle[iDeviceIndex] );
				arrayHandle[iDeviceIndex] = NULL;
			}

			arrayHandle[iDeviceIndex] = handle;
			memset( arrayDevicePath[iDeviceIndex], 0, sizeof(TCHAR) * MAX_PATH );
			copytextto( arrayDevicePath[iDeviceIndex], functionClassDeviceData->DevicePath, lengthof(functionClassDeviceData->DevicePath) );
			free( functionClassDeviceData );
			functionClassDeviceData = NULL;	
		}
	}
	SetupDiDestroyDeviceInfoList( hardwareDeviceInfo );
	//delete [] PathInfor;
#endif

	return (handle != (HANDLE)NULL);
}

unsigned char OpenDeviceByName( LPCTSTR pszName, HANDLE& hDevice, int& number )
{
#ifdef _MSC_VER
	//Ö¸¶¨´ňżŞÉč±¸µÄĂűłĆ Ö±˝Ó»ńČˇÉč±¸ľä±ú
	HANDLE handle = CreateFile( pszName, GENERIC_READ|GENERIC_WRITE, FILE_SHARE_READ|FILE_SHARE_WRITE, NULL, OPEN_EXISTING, FILE_FLAG_OVERLAPPED/*0*/, NULL );
	if ( handle != INVALID_HANDLE_VALUE )
	{
		hDevice = handle;
		DoLinkTest( hDevice, number );

		return ERROR_CODE_OK;
	}
#endif

	return ERROR_CODE_INVALID_PARAM;
}

unsigned char HalLinkAndDoInit( LinkParam& param )
{
	int iRet = ERROR_CODE_INVALID_PARAM;

	if( LINK_TYPE_USB == param.LinkType || LINK_TYPE_HID == param.LinkType || LINK_TYPE_HID_IIC == param.LinkType )
	{
		if( NULL == param.usb.pszLinkName )
		{
			HANDLE arrayHandle[MAX_DEVICE_NUM] = {0};

			EnumPrintDevice( LINK_TYPE_USB == param.LinkType ? &IID_SMUSBGUID : &IID_SMHIDGUID, arrayHandle );

#ifdef _1_MULTIPLE_N_
			for( int index = 0; index < MAX_DEVICE_NUM; ++index )
			{
                if( (HANDLE)NULL == arrayHandle[index] )  continue;

				Device device;
				device.handle = arrayHandle[index];
				device.iDevIndex = index;
				
				param.usb.devID = device.iDevIndex;
				iRet = CChipWrapper::m_SeltContainer[index]->HalLinkAndDoInit( param, device );
			}
#else
			Device device;
			device.handle = NULL;
			for( int index = 0; index < MAX_DEVICE_NUM; ++index )
			{
	            if( arrayHandle[index] )
				{
					device.handle = arrayHandle[index];
					device.iDevIndex = 0;
					break;
				}
			}
			iRet = CChipWrapper::m_SeltContainer->HalLinkAndDoInit( param, device );
			if( NULL == device.handle )  iRet = ERROR_CODE_DEVICE_CLOSED;
#endif
		}
		else
		{
			Device device;
			iRet = OpenDeviceByName( param.usb.pszLinkName, device.handle, device.iDevIndex );
			if( iRet == ERROR_CODE_OK )
			{
				param.usb.devID = device.iDevIndex;
				memset( arrayDevicePath[device.iDevIndex], 0, sizeof(TCHAR) * MAX_PATH );
				copytextto( arrayDevicePath[device.iDevIndex], param.usb.pszLinkName, lengthof(param.usb.pszLinkName) );
#ifdef _1_MULTIPLE_N_
				iRet = CChipWrapper::m_SeltContainer[device.iDevIndex]->HalLinkAndDoInit( param, device );
#else
				iRet = CChipWrapper::m_SeltContainer->HalLinkAndDoInit( param, device );
#endif
			}
		}
	}
	else if(LINK_TYPE_TCP == param.LinkType||LINK_TYPE_THP == param.LinkType){
		Device device;
		device.handle = (HANDLE)NULL;
		device.iDevIndex = 0;
#ifndef _1_MULTIPLE_N_
		iRet = CChipWrapper::m_SeltContainer->HalLinkAndDoInit( param, device );
#else
		iRet = CChipWrapper::m_SeltContainer[device.iDevIndex]->HalLinkAndDoInit( param, device );
#endif
	}
	else if(LINK_TYPE_FAKE == param.LinkType){
		Device device;
		device.handle = (HANDLE)NULL;
		device.iDevIndex = 0;
#ifndef _1_MULTIPLE_N_
		iRet = CChipWrapper::m_SeltContainer->HalLinkAndDoInit( param, device );
#else
		iRet = CChipWrapper::m_SeltContainer[device.iDevIndex]->HalLinkAndDoInit( param, device );
#endif
	}
	else if(LINK_TYPE_PROC == param.LinkType)
	{
		Device device;
		device.handle = (HANDLE)NULL;
		device.iDevIndex = 0;
#ifndef _1_MULTIPLE_N_
		iRet = CChipWrapper::m_SeltContainer->HalLinkAndDoInit( param, device );
#else
		iRet = CChipWrapper::m_SeltContainer[device.iDevIndex]->HalLinkAndDoInit( param, device );
#endif
	}
	else 
	{

	}

	return iRet;
}
unsigned char HalDetachAndClean( LinkParam& param )
{
    int iRet = ERROR_CODE_INVALID_PARAM;
	if( LINK_TYPE_USB == param.LinkType ||LINK_TYPE_HID == param.LinkType ||LINK_TYPE_HID_IIC == param.LinkType  )
	{
        if( param.usb.pszLinkName )
		{
			Device device;
			device.handle = (HANDLE)NULL;

#ifdef _1_MULTIPLE_N_
			int index = 0;
			for( int index = 0; index < MAX_DEVICE_NUM; ++index )
			{
				if( 0 == icomparetext( param.usb.pszLinkName, arrayDevicePath[index] ) )
				{
					memset( arrayDevicePath[index], 0, sizeof(TCHAR) * MAX_PATH );

					device.iDevIndex = index + 1;
					CChipWrapper::m_SeltContainer[index]->HalLinkAndDoInit( param, device );
					break;
				}
			}
#else
			CChipWrapper::m_SeltContainer->HalLinkAndDoInit( param, device );
#endif
		}
	}
	else
	{
       
	}

	return iRet;
}
unsigned char RegisterNotification( HWND wnd, REFIID guid )
{
#ifdef _MSC_VER
	static GUID uid = {0};
	if( uid != guid )
	{
		DEV_BROADCAST_DEVICEINTERFACE devIF = {0};
		devIF.dbcc_size = sizeof(devIF);
		devIF.dbcc_devicetype = DBT_DEVTYP_DEVICEINTERFACE;
		devIF.dbcc_classguid  = guid;
		hRegistNotify = RegisterDeviceNotification(wnd, &devIF, DEVICE_NOTIFY_WINDOW_HANDLE);
		if(hRegistNotify == NULL){
			return ERROR_CODE_INVALID_PARAM;
		}
		uid = guid;
	}
#endif

	return ERROR_CODE_OK;
}
unsigned char UnRegisterNotification( )
{
#ifdef _MSC_VER
	UnregisterDeviceNotification( hRegistNotify );
#endif

#ifdef _1_MULTIPLE_N_
	for( int index = 0; index < MAX_DEVICE_NUM; ++index )
		CChipWrapper::m_SeltContainer[index]->MakeClean();
#else
	CChipWrapper::m_SeltContainer->MakeClean();
#endif

	return ERROR_CODE_OK;
}
void GetDeviceNameInfo(unsigned char Index, void *pName)
{
    if(Index >= MAX_DEVICE_NUM) return ;

    memcpy_s(pName, sizeof(TCHAR) * MAX_PATH, arrayDevicePath[Index], sizeof(TCHAR) * MAX_PATH);
    return ;
}

bool HaveDeviceAttached( int deviceNum /*= 0*/ )
{
#ifdef _1_MULTIPLE_N_
	return NULL != CChipWrapper::m_SeltContainer[deviceNum]->GetCommBaseInterface() && CChipWrapper::m_SeltContainer[deviceNum]->GetCommBaseInterface()->Connected();
#else
	return NULL != CChipWrapper::m_SeltContainer->GetCommBaseInterface() && CChipWrapper::m_SeltContainer->GetCommBaseInterface()->Connected();
#endif

	return ERROR_CODE_OK;
}
int NumOfDeviceAttached()
{
	int number = 0;
#ifdef _1_MULTIPLE_N_
	for( int index = 0; index < MAX_DEVICE_NUM; index++ )
		if( CChipWrapper::m_SeltContainer[index]->GetCommBaseInterface() && CChipWrapper::m_SeltContainer[index]->GetCommBaseInterface()->Connected() ) number++;
#else
	if( CChipWrapper::m_SeltContainer->GetCommBaseInterface() && CChipWrapper::m_SeltContainer->GetCommBaseInterface()->Connected() ) number++;
#endif

	return number;
}



LPCTSTR GetErrorMessage( unsigned int errorCode )
{

	if( ERROR_CODE_OK == errorCode ) 
		return _T("Comm OK.");
	else if( ERROR_CODE_LOOP_BEYOND_MAX_RETRY == errorCode )
		return _T("Loop Max Try");
	else if( ERROR_CODE_NO_DEVICE == errorCode )
		return _T("No Usb Device");
	else if( ERROR_CODE_NO_KINDOF_IC == errorCode )
		return _T("No Ic Type");
	else if( ERROR_CODE_INVALID_PARAM == errorCode )
		return _T("Invalid Parameter");
	else if( ERROR_CODE_WRITE_USB_ERROR == errorCode )
		return _T("Wrte Usb Error");
	else if( ERROR_CODE_WAIT_RESPONSE_TIMEOUT == errorCode )
		return _T("Wait Timeout");
	else if( ERROR_CODE_READ_USB_ERROR == errorCode )
		return _T("Read Usb Error");
	else if( ERROR_CODE_COMM_ERROR == errorCode )
		return _T("Comm Error");
	else if( ERROR_CODE_DEVICE_CLOSED == errorCode )
		return _T("Usb Device Closed");
	else if( ERROR_CODE_CHECK_RESPONSE_FAILED == errorCode )
		return _T("Response Error");
	else if( ERROR_CODE_ONE_PROCESS_RUNING == errorCode )
		return _T("Multiple Process");
	else if( ERROR_CODE_INVALID_FILE == errorCode )
		return _T("Invalid File");
	else if( ERROR_CODE_CHECK_SUM_MISMATCH == errorCode )
		return _T("CheckSum mismatch");

	return _T("UnDefined Error!");
}
LPCTSTR GetProgramErrorMessage( unsigned char errorCode )
{
	return _T("UnDefined Error!");
}

void SysDelayFake( unsigned int DelayMS )
{

}
void SysDelayReal( unsigned int DelayMS )	
{
#ifdef _MSC_VER
	LARGE_INTEGER Param;
	LONGLONG StartTime, EndTime;
	double SysFreq;

	QueryPerformanceFrequency( &Param );
	SysFreq = (double)Param.QuadPart;
	QueryPerformanceCounter( &Param );
	StartTime = Param.QuadPart;
	do
	{
		QueryPerformanceCounter( &Param );
		EndTime = Param.QuadPart;
	}while((EndTime-StartTime)*1000/SysFreq<DelayMS);
#else
	usleep((DelayMS) * 1000);
#endif
}

SysDelayFunctionPoint SysDelay = SysDelayReal;

void SetSimulateGate( BOOL bSimulateGateOpen /*= FALSE */)
{
	if( bSimulateGateOpen )
	{
		SysDelay = SysDelayFake;
	}
	else
	{
		SysDelay = SysDelayReal;
	}
}
BOOL GetSimulateGate()
{
    return SysDelay == SysDelayFake;
}

