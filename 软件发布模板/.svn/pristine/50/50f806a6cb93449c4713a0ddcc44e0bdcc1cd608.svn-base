<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewModel="clr-namespace:SEMIDevelopKit.Src.WinSub"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
			<RowDefinition Height="205"></RowDefinition>
			<RowDefinition Height="125"></RowDefinition>
			<RowDefinition Height="525"></RowDefinition>
			<RowDefinition Height="525"></RowDefinition>
			<RowDefinition Height="130"></RowDefinition>
			<RowDefinition Height="285"></RowDefinition>
			<RowDefinition Height="165"></RowDefinition>
        </Grid.RowDefinitions>
		
		<GroupBox Header="17：AD/DA分频系数、HD长度（不可配）" Grid.Row="0">
            <UniformGrid Rows="4">
				<UniformGrid Columns="16">
				<Label Content="MCU主时钟" HorizontalAlignment="Right" Margin="5"></Label>
			    <CheckBox Content="MCU 64M clk"    Tag="6" viewModel:TuningItem.ItemName="funcCfg"  HorizontalAlignment="Left" Margin="5" ></CheckBox>
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="ADC分频系数" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="clkdiv_adc"></TextBox>
				<Label Content="配置0:FW自动" HorizontalAlignment="Left" Margin="5"></Label>
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="DAC分频系数" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="clkdiv_dac"></TextBox>
                <Label Content="配置0:FW自动" HorizontalAlignment="Left" Margin="5"></Label>
				</UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="哈达码长度" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="hd_len"></TextBox>
                <Label Content="配置0:FW自动" HorizontalAlignment="Left" Margin="5"></Label>
				</UniformGrid>
			</UniformGrid>
        </GroupBox>

        <GroupBox Header="18：扩展功能开关" Grid.Row="1">
            <UniformGrid Rows="2">
				<UniformGrid Columns="16">
                <Control></Control>
                <CheckBox Content="Glove En"         Tag="0" viewModel:TuningItem.ItemName="funcCfgEx1"  HorizontalAlignment="Left" Margin="5" ></CheckBox>
                <CheckBox Content="Glove FH Dis"     Tag="1" viewModel:TuningItem.ItemName="funcCfgEx1"  HorizontalAlignment="Left" Margin="5" ></CheckBox>
                <CheckBox Content="Glove Idle Dis"   Tag="2" viewModel:TuningItem.ItemName="funcCfgEx1"  HorizontalAlignment="Left" Margin="5" ></CheckBox>
                </UniformGrid>	

				<UniformGrid Columns="16">
                <Control></Control>
                <CheckBox Content="Glove Mode Lock"  Tag="4" viewModel:TuningItem.ItemName="funcCfgEx1"  HorizontalAlignment="Left" Margin="5" ></CheckBox>
                </UniformGrid>	
            </UniformGrid>
        </GroupBox>	

        <GroupBox Header="19：手套模式--扫频参数（XY分频、截位、积分、累和）" Grid.Row="2">
            <UniformGrid Rows="12">
				<UniformGrid Columns="16">
                <Control></Control>
				<Control></Control>
				<Label Content="主频" HorizontalAlignment="Right" Margin="5"></Label>
				</UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="XY分频系数(mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_clkdiv_xy_mul"></TextBox>
                <Label Content="4的倍数" HorizontalAlignment="Left" Margin="5"></Label>
				<Label Content="XY分频系数(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_clkdiv_xy_self"></TextBox>
                <Label Content="4的倍数" HorizontalAlignment="Left" Margin="5"></Label>
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="积分次数(mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_clkdiv_hd_mul"></TextBox>
				<Label Content="(4~40)" HorizontalAlignment="Left" Margin="5"></Label>
				<Label Content="积分次数(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_clkdiv_hd_self"></TextBox>
				<Label Content="(4~40)" HorizontalAlignment="Left" Margin="5"></Label>  
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="数据截位(mul)"  Margin="5" HorizontalAlignment="Right"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_shift_mul"></TextBox>
                <Label Content="(0~7)" HorizontalAlignment="Left" Margin="5"></Label>
				<Label Content="数据截位(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_shift_self"></TextBox>
                <Label Content="[7:4]Tx;[3:0]Rx(0~7)" HorizontalAlignment="Left" Margin="5"></Label>
                </UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="ADC输出截位(sel+mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_shift_adc"></TextBox>
                <Label Content="[7:4]自容;[3:0]互容(0~7)" HorizontalAlignment="Left" Margin="5"></Label>
				<Label Content="DAC输出步进(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_dac_step"></TextBox>
				<Label Content="可配置(2~8)" HorizontalAlignment="Left" Margin="5"></Label>
                </UniformGrid>
				
				<UniformGrid Columns="16">
				<Control></Control>	
				<Control></Control>	
				<Control></Control>	
				<Label Content="累和次数(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_self_inte"></TextBox>
				<Label Content="(1~16)" HorizontalAlignment="Left" Margin="5"></Label>                  
				</UniformGrid>	
				
				<UniformGrid Columns="16">
                <Control></Control>
				<Control></Control>
				<Label Content="辅频" HorizontalAlignment="Right" Margin="5"></Label>
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="XY分频系数(mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_clkdiv_xy_mul1"></TextBox>
                <Label Content="4的倍数" HorizontalAlignment="Left" Margin="5"></Label>
				<Label Content="XY分频系数(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_clkdiv_xy_self1"></TextBox>
                <Label Content="4的倍数" HorizontalAlignment="Left" Margin="5"></Label>				
				</UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="积分次数(mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_clkdiv_hd_mul1"></TextBox>
				<Label Content="(4~40)" HorizontalAlignment="Left" Margin="5"></Label> 
				<Label Content="积分次数(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_clkdiv_hd_self1"></TextBox>
				<Label Content="可配置(4~40)" HorizontalAlignment="Left" Margin="5"></Label>
                </UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="数据截位(mul）"  Margin="5" HorizontalAlignment="Right"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_shift_mul1"></TextBox>
                <Label Content="(0~7)" HorizontalAlignment="Left" Margin="5"></Label>
                <Label Content="数据截位(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_shift_self1"></TextBox>
                <Label Content="[7:4]Tx;[3:0]Rx(0~7)" HorizontalAlignment="Left" Margin="5"></Label>
                </UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="ADC输出截位(sel+mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_shift_adc1"></TextBox>
                <Label Content="[7:4]自容;[3:0]互容(0~7)" HorizontalAlignment="Left" Margin="5"></Label>
				<Label Content="DAC输出步进(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_dac_step1"></TextBox>
				<Label Content="(2~8)" HorizontalAlignment="Left" Margin="5"></Label>
                </UniformGrid>
				
				<UniformGrid Columns="16">
				<Control></Control>	
				<Control></Control>	
				<Control></Control>	
				<Label Content="累和次数(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_self_inte1"></TextBox>
				<Label Content="(1~16)" HorizontalAlignment="Left" Margin="5"></Label>                  
				</UniformGrid>
			</UniformGrid>
        </GroupBox>			
		
        <GroupBox Header="20：手套模式--触摸阈值、抬起阈值、按键阈值" Grid.Row="3">
            <UniformGrid Rows="12">
				<UniformGrid Columns="16">
                <Control></Control>
				<Control></Control>
				<Label Content="      主频" HorizontalAlignment="Left" Margin="5"></Label>
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="触摸阈值 (mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_touchLv_mul"></TextBox>
                <Label Content="抬起阈值 (mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_leaveLv_mul"></TextBox>
				</UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="触摸阈值  (slt)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_touchLv_slt"></TextBox>
				<Label Content="抬起阈值  (slt)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_leaveLv_slt"></TextBox>
				</UniformGrid>

				<UniformGrid Columns="16">
				<Label Content="触摸阈值  (slr)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_touchLv_slr"></TextBox>
				<Label Content="抬起阈值  (slr)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_leaveLv_slr"></TextBox>
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="触摸阈值 (mul key)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_keyTouchLv"></TextBox>
				<Label Content="抬起阈值 (mul key)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_keyLeaveLv"></TextBox>
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="自容阈值比例 (self key)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_key_thd_self"></TextBox>
				<Label Content="[7:4]:Rx、[3:0]:Tx是Va区的比例" HorizontalAlignment="Left" Margin="5"></Label>
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Control></Control>
				<Control></Control>
				<Label Content="      辅频" HorizontalAlignment="Left" Margin="5"></Label>
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="触摸阈值 (mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_touchLv_mul1"></TextBox>
                <Label Content="抬起阈值 (mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_leaveLv_mul1"></TextBox>
				</UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="触摸阈值  (slt)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_touchLv_slt1"></TextBox>
				<Label Content="抬起阈值  (slt)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_leaveLv_slt1"></TextBox>	
				</UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="触摸阈值  (slr)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_touchLv_slr1"></TextBox>		
				<Label Content="抬起阈值  (slr)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_leaveLv_slr1"></TextBox>
				</UniformGrid>
                
				<UniformGrid Columns="16">
                <Label Content="触摸阈值 (mul key)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_keyTouchLv1"></TextBox>
                <Label Content="抬起阈值 (mul key)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_keyLeaveLv1"></TextBox>		
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="自容阈值比例 (self key)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_key_thd_self1"></TextBox>
				<Label Content="[7:4]:Rx、[3:0]:Tx是Va区的比例" HorizontalAlignment="Left" Margin="5"></Label>
				</UniformGrid>
			</UniformGrid>
        </GroupBox>	
		
       <GroupBox Header="21：普通模式 Rolling Noise 和框阈值" Grid.Row="4">
            <UniformGrid Rows="2">
				<UniformGrid Columns="16">
                <Label Content="Rolling Noise 负阈值"  HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="NoiseThdNeg"></TextBox>
                <Label Content="Rolling Noise 正阈值" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="NoiseThdPos"></TextBox>
                </UniformGrid>

				<UniformGrid Columns="16">
                <Label Content="框 多边型阈值 最小值" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="RectPolygonMin"></TextBox>
				<Label Content="框 多边型阈值 palm" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="RectPolygonPalm"></TextBox>  
				</UniformGrid>
            </UniformGrid>
        </GroupBox>		
		
        <GroupBox Header="22：手套模式--主频 Rolling Noise 和框阈值" Grid.Row="5">
            <UniformGrid Rows="6">
				<UniformGrid Columns="16">
                <Control></Control>
				<Control></Control>
				<Label Content="      主频" HorizontalAlignment="Left" Margin="5"></Label>
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="Rolling Noise 负阈值"  HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="GloveNoiseThdNeg"></TextBox>
                <Label Content="Rolling Noise 正阈值" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="GloveNoiseThdPos"></TextBox>
                </UniformGrid>

				<UniformGrid Columns="16">
                <Label Content="框 多边型阈值 最小值" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="GloveRectPolygonMin"></TextBox>
				<Label Content="框 多边型阈值 palm" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="GloveRectPolygonPalm"></TextBox>  
				</UniformGrid>

				<UniformGrid Columns="16">
                <Control></Control>
				<Control></Control>
				<Label Content="      辅频" HorizontalAlignment="Left" Margin="5"></Label>
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="Rolling Noise 负阈值"  HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="GloveNoiseThdNeg1"></TextBox>
                <Label Content="Rolling Noise 正阈值" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="GloveNoiseThdPos1"></TextBox>
                </UniformGrid>

				<UniformGrid Columns="16">
                <Label Content="框 多边型阈值 最小值" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="GloveRectPolygonMin1"></TextBox>
				<Label Content="框 多边型阈值 palm" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="GloveRectPolygonPalm1"></TextBox>  
				</UniformGrid>
            </UniformGrid>
        </GroupBox>		
		
        <GroupBox Header="23：其他参数" Grid.Row="6">
            <UniformGrid Rows="3">
				<UniformGrid Columns="16">
                <Label Content="过滤peak比值"  HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="GlovePeakFilterRatio"></TextBox>
                <Label Content="手套模式 哈达码长度"  HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="Glove_hd_len"></TextBox>				
                </UniformGrid>				
				
				<UniformGrid Columns="16">
                <Label Content="普通模式 水滤点Tx阈值百分比"  HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="WaterFilterTxThdRatio"></TextBox>
                <Label Content="普通模式 水滤点Rx阈值百分比" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="WaterFilterRxThdRatio"></TextBox>
                </UniformGrid>			
			
				<UniformGrid Columns="16">
                <Label Content="手套模式 水滤点Tx阈值百分比"  HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="GloveWaterFilterTxThdRatio"></TextBox>
                <Label Content="手套模式 水滤点Rx阈值百分比" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="GloveWaterFilterRxThdRatio"></TextBox>
                </UniformGrid>			
            </UniformGrid>
        </GroupBox>		
		
    </Grid>
</UserControl>
