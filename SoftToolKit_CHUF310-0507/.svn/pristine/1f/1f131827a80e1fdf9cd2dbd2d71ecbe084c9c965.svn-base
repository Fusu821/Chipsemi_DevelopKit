<Window x:Class="SEMITestApp.Src.WinSet.OfilmCustomizedWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Information(MES信息)" Height="187" Width="443" WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow" MinWidth="411" MinHeight="144">
    <Grid Loaded="Grid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150*"></ColumnDefinition>
            <ColumnDefinition Width="282*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Label Content="FixtureId(治具代码)" Grid.Row="0" Margin="5"></Label>
        <TextBox Margin="3" Text="{Binding FixtureId}"  Grid.Row="0" Grid.Column="1"></TextBox>
        <Label Content="UserId(员工号)" Grid.Row="1"  Margin="5"></Label>
        <TextBox Margin="3" Text="{Binding UserId}" Grid.Row="1" Grid.Column="1"></TextBox>
        <Label Content="EqpId(机台代码)" Grid.Row="2"  Margin="5"></Label>
        <TextBox Margin="3" Text="{Binding EqpId}" Grid.Row="2" Grid.Column="1"></TextBox>
        <Button Margin="3"  Grid.Row="3" Grid.Column="1" MaxWidth="50" HorizontalAlignment="Right" MinWidth="50" Content="Save" Click="Button_Click"></Button>
    </Grid>
</Window>
