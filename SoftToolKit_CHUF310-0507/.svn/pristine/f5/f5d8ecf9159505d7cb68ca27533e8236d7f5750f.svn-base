#define DTestResultInfo(strResult, ...) \
	({\
	(do{\
	static TCHAR szBuffer[MAX_PATH] = {0}; \
	transformat( szBuffer,strResult, ##__VA_ARGS__);\
	TestResultInfo(szBuffer);\
	}while(0))\
	(szBuffer);\
	})\

