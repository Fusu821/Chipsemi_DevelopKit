<UserControl x:Class="SEMITestApp.Src.WinSub.OneAppFrame"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SEMITestApp.Src.WinSub"
             
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <DockPanel>
        <DataGrid x:Name="TestGrid"
                  Visibility="{Binding EnterGraphMode, Converter={StaticResource GraphVisibleConverter}, ConverterParameter=0}"
                  RenderOptions.ClearTypeHint="Enabled"
                  TextOptions.TextFormattingMode="Display"
                  HeadersVisibility="All"
                  Margin="5"
                  ItemsSource="{Binding Path=TestItems}"
                  AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ItemCode" Binding="{Binding ItemCode}"/>
                <DataGridTextColumn Header="ItemName" Binding="{Binding ItemName}"/>
                <DataGridTextColumn Header="ItemResult" Binding="{Binding ItemResult}"/>
                <DataGridTextColumn Header="ItemMark" Binding="{Binding ItemMark}"/>
            </DataGrid.Columns>
        </DataGrid>
        <Image x:Name="TestGraph" Visibility="{Binding EnterGraphMode, Converter={StaticResource GraphVisibleConverter}, ConverterParameter=1}"></Image>
    </DockPanel>
</UserControl>
