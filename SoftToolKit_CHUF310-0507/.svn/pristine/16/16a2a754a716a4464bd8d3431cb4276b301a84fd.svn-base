CChipWrapper::CChipWrapper(  )
:m_pChipIntr( 0 )
,m_pCommIntr( 0 )
,m_ucIDMark( 0 )
/*,m_pProgramIntr( 0 )*/
{
}
CChipWrapper::CChipWrapper( unsigned char id )
:m_pChipIntr( 0 )
,m_pCommIntr( 0 )
,m_ucIDMark( id )
{
#if LOG_SEMI_TOUCH_OPEN
	OnLineLogApp.OnInitLogParam( m_ucIDMark );
#endif
}
CChipWrapper::~CChipWrapper()
{
    MakeClean();
}
void CChipWrapper::MakeClean()
{
// 	if( NULL != m_pProgramIntr// 	elete m_pProgramIntr;
// 	m_pProgramIntr = NULL;

	if(NULL != m_pChipIntr )      delete m_pChipIntr;
	m_pChipIntr = NULL;
	if( NULL != m_pCommIntr )     delete m_pCommIntr;
	m_pCommIntr = NULL;
}

unsigned int CChipWrapper::HalLinkAndDoInit( LinkParam& param, Device hDevice )
{
	if( m_pCommIntr )
	{
#ifdef _MSC_VER
		if( param.LinkType != m_pCommIntr->GetCommType() )
#endif
		{
			LinkParam tp;
			tp.LinkType = m_pCommIntr->GetCommType();
			HalDetachAndClean(param);
			delete m_pCommIntr;
			m_pCommIntr = NULL;
		}
	}

	if( NULL == m_pCommIntr )
	{
		m_pCommIntr = (ICommBase*)RunTimeClassFactoryInstEx(COMM_TYPE).CreateObject( (COMM_TYPE)param.LinkType, (unsigned long)&param );
	}

	if( m_pCommIntr )
	{
		if(LINK_TYPE_TCP == param.LinkType)
		{
			((CCommAdb*)m_pCommIntr)->SetWrapperAddr( this );
			((CCommAdb*)m_pCommIntr)->SyncWorkcInit( );
		}
		else if(LINK_TYPE_THP == param.LinkType)
		{
			((CCommAdbTHP*)m_pCommIntr)->SetWrapperAddr( this );
			((CCommAdbTHP*)m_pCommIntr)->SyncWorkcInit( );
		}
		else
		{
			((CCommMtk*)m_pCommIntr)->SetWrapperAddr( this );
			m_pCommIntr->HalTrySetDeviceManuly( hDevice );
			
			if( m_pChipIntr )
			{
				m_pCommIntr->SyncWorkcInit();
			}
		}
	}

	return m_pCommIntr ? ERROR_CODE_OK : ERROR_CODE_INVALID_PARAM;
}

unsigned int CChipWrapper::SetICTypeAndCreateComponent( USHORT uIcType )
{
	//if( NULL != m_pProgramIntr ) delete m_pProgramIntr;
    if( NULL != m_pChipIntr )     delete m_pChipIntr;

    m_pChipIntr = (ISMChipBase*)RunTimeClassFactoryInst(CHIP_TYPE).CreateObject( (CHIP_TYPE)uIcType );
	if( m_pChipIntr )
	{
		RefSelf* SRefIntr = (RefSelf*)m_pChipIntr->GetSRefInterface();
		if( NULL != SRefIntr ) SRefIntr->SetWrapperAddr( this );
	}

	return ERROR_CODE_OK;
}

