	public ref class SMCallBack
	{
	private:
		static SMCallBack^ callBack = nullptr;
	public:
		OnOneTestStart^           onOneTestStart;
		OnListItemChange^         onListItemChange;
		OnRefleshProcessBar^      onProcessBarChanging;
		//OnInitProcessBar^         onInitProcessBar;
		OnOneTestOver^            onOneTestOver;
		OnTouchReport^            onTouchReport;

		OnInformationUpload^      OnInforUpload;  

	public:
		static SMCallBack^ GetInstance()
		{
			if( callBack == nullptr )
			{
				callBack = gcnew SMCallBack();
			}
			return callBack;
		}
	private:
		SMCallBack(){}
	};

