                        <Border BorderBrush="#cccccc" BorderThickness="1" Margin="4,2" Padding="0" CornerRadius="8" Background="#2ecc71">
                            <Rectangle Name="fillRectangle" Fill="#e74c3c" RadiusX="8" RadiusY="8" Visibility="Collapsed"/>
                        </Border>
                        <Border Name="slideBorder" BorderBrush="#aaaaaa" BorderThickness="1" HorizontalAlignment="Left" CornerRadius="15" Width="24" Height="24">
