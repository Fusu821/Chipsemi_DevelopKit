<Page x:Class="SEMITestApp.Src.WinSet.TestItemSet"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SEMITestApp.Src.WinSet"
      mc:Ignorable="d" 
      KeepAlive="True"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TestItemSet" IsVisibleChanged="TestItem_IsVisibleChanged">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="32*" />
            <ColumnDefinition Width="768*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="225*"></RowDefinition>
            <RowDefinition Height="54*"></RowDefinition>
            <RowDefinition Height="171*" />
        </Grid.RowDefinitions>
        <GroupBox Header="Must Required Test Items" Grid.ColumnSpan="2" Margin="5">
            <ItemsControl ItemsSource="{Binding TestItemList, Converter={StaticResource ItemListToSubItemConverter}, ConverterParameter=1}" Margin="10,0,189,0" Width="500">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="5" Columns="3"></UniformGrid>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox DataContext="{Binding}"  Content="{Binding ItemText}" IsChecked="{Binding Checked}"></CheckBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <!--UniformGrid Rows="4" Columns="2" Margin="10,0,189,0" Width="500">
                <CheckBox DataContext="{Binding TestItemList, Converter={StaticResource ItemListToItemConverter}, ConverterParameter=1}" Content="{Binding ItemText}" IsChecked="{Binding Checked}"></CheckBox>
                <CheckBox DataContext="{Binding TestItemList, Converter={StaticResource ItemListToItemConverter}, ConverterParameter=2}" Content="{Binding ItemText}" IsChecked="{Binding Checked}"></CheckBox>
                <CheckBox DataContext="{Binding TestItemList, Converter={StaticResource ItemListToItemConverter}, ConverterParameter=3}" Content="{Binding ItemText}" IsChecked="{Binding Checked}"></CheckBox>
                <CheckBox DataContext="{Binding TestItemList, Converter={StaticResource ItemListToItemConverter}, ConverterParameter=4}" Content="{Binding ItemText}" IsChecked="{Binding Checked}"></CheckBox>  
            </UniformGrid-->
        </GroupBox>
        <GroupBox Grid.Row="1" Header="Option Test Items" Grid.ColumnSpan="2" Margin="5" Grid.RowSpan="2">
            <ItemsControl ItemsSource="{Binding TestItemList, Converter={StaticResource ItemListToSubItemConverter}, ConverterParameter=0}" Margin="10,0,189,0" Width="500">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="5" Columns="3"></UniformGrid>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox DataContext="{Binding}"  Content="{Binding ItemText}" IsChecked="{Binding Checked}"></CheckBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <!--UniformGrid Rows="4" Columns="2" Margin="10,0,189,0" Width="500">
                <CheckBox DataContext="{Binding TestItemList, Converter={StaticResource ItemListToItemConverter}, ConverterParameter=5}" Content="{Binding ItemText}" IsChecked="{Binding Checked}"></CheckBox>
                <CheckBox DataContext="{Binding TestItemList, Converter={StaticResource ItemListToItemConverter}, ConverterParameter=6}" Content="{Binding ItemText}" IsChecked="{Binding Checked}"></CheckBox>
                <CheckBox DataContext="{Binding TestItemList, Converter={StaticResource ItemListToItemConverter}, ConverterParameter=7}" Content="{Binding ItemText}" IsChecked="{Binding Checked}"></CheckBox>
            </UniformGrid-->
        </GroupBox>
    </Grid>
</Page>
