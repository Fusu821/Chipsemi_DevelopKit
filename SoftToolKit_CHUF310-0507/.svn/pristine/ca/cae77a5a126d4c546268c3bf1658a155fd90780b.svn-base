	[Serializable]  
	public ref struct CLRLinkParam
	{
		static const byte CLRLINK_TYPE_USB  = LINK_TYPE_USB;
		static const byte CLRLINK_TYPE_COM  = LINK_TYPE_COM;
		static const byte CLRLINK_TYPE_TCP  = LINK_TYPE_TCP;
		static const byte CLRLINK_TYPE_UDP  = LINK_TYPE_UDP;
		static const byte CLRLINK_TYPE_FAKE = LINK_TYPE_FAKE; 
		static const byte CLRLINK_TYPE_HID  = LINK_TYPE_HID;
		static const byte CLRLINK_TYPE_THP  = LINK_TYPE_THP;
		String^ szCurMsg;
		unsigned short vid;
		unsigned short pid;
		unsigned short devID;
		byte   LinkType;

		String^ szIpAddress;
		unsigned short port;
		unsigned char async;
	};
	public ref class ExportDeclares
	{
	public:
		static const Int32 MAX_DEVICE_NUMS   = MAX_DEVICE_NUM;

		static const Int32 SM_TEXT_SIZE_SMALL = TEXT_SIZE_SMALL;
		static const Int32 SM_TEXT_SIZE_LARGE = TEXT_SIZE_LARGE;

		static const Int32 SM_ITEM_STA_NONE  = ITEM_STA_NONE;
		static const Int32 SM_ITEM_STA_PASS  = ITEM_STA_PASS;
		static const Int32 SM_ITEM_STA_FAIL  = ITEM_STA_FAIL;
		static const Int32 SM_ITEM_STA_START = ITEM_STA_START;
		static const Int32 SM_ITEM_STA_WAIT  = ITEM_STA_WAIT;
		static const Int32 SM_ITEM_STA_TBD   = ITEM_STA_TBD;
		static const Int32 SM_ITEM_STA_EXCEPTION = ITEM_STA_EXCEPTION;
		static const Int32 SM_ITEM_STA_PRESS = ITEM_STA_PRESS;

		static const Int32 SM_TEST_NONE      = TEST_NONE;
		static const Int32 SM_TEST_PASS      = TEST_PASS;
		static const Int32 SM_TEST_NG        = TEST_NG;
		static const Int32 SM_TEST_TBD       = TEST_TBD;
		static const Int32 SM_TEST_GOING     = TEST_GOING;

		static const UINT32 SM_COMMAND_NONE  = COMMAND_LINE_NONE;
		static const UINT32 SM_COMMAND_DEBUG = COMMAND_LINE_DEBUG;
		static const UINT32 SM_COMMAND_FAE   = COMMAND_LINE_FAE;
		static const UINT32 SM_COMMAND_STOP   = COMMAND_LINE_STOP;
		static const UINT32 SM_COMMAND_LINE_SHUT_DOWN = COMMAND_LINE_SHUT_DOWN;

		static const Int32 SM_MIN_GRAPH_ID   = TEST_ITEM_GRAPH_TEST_START;

		static const Int32 SM_MAX_NUM_POINT    = 10;

		static const Int32 SM_OTHER_NUM_POINT    = 1;

	    static const Int32 SM_MAX_ROWS         = MAX_MCAP_ROW;
		static const Int32 SM_MAX_COLS         = MAX_MCAP_COL; 

		static bool CLRRegisterNotification(IntPtr wnd, array<unsigned char>^ arrayUID)
		{
			GUID managedID;
			managedID.Data1 = (arrayUID[3] << 24) |  (arrayUID[2] << 16) | (arrayUID[1] << 8) | (arrayUID[0] << 0);
			managedID.Data2 = (arrayUID[5] << 8) |  (arrayUID[4] << 0);
			managedID.Data3 = (arrayUID[7] << 8) |  (arrayUID[6] << 0);
			managedID.Data4[0] = arrayUID[8];
			managedID.Data4[1] = arrayUID[9];
			managedID.Data4[2] = arrayUID[10];
			managedID.Data4[3] = arrayUID[11];
			managedID.Data4[4] = arrayUID[12];
			managedID.Data4[5] = arrayUID[13];
			managedID.Data4[6] = arrayUID[14];
			managedID.Data4[7] = arrayUID[15];

			return ERROR_CODE_OK == RegisterNotification( (HWND)wnd.ToInt64(), managedID );
		}
		static bool CLRUnRegisterNotification()
		{
			return ERROR_CODE_OK == UnRegisterNotification();
		}
		static bool CLRHalLinkAndDoInit( CLRLinkParam^ pm )
		{
			LinkParam param;
			param.usb.devID =0;
			param.LinkType = pm->LinkType;

			if(LINK_TYPE_TCP == pm->LinkType||LINK_TYPE_THP == pm->LinkType)
			{
				if( String::IsNullOrEmpty(pm->szIpAddress) )
				{
					param.tcp.pszIpAddress = _T("127.0.0.1");
					//param.tcp.pszIpAddress = _T("192.168.5.1");
					//pm->port = 3536;
				}
				else 
				{
					TCHAR arrayPath[MAX_PATH] = {0};
					for( int index = 0; index < pm->szIpAddress->Length; ++index ){
						arrayPath[index] = (TCHAR)pm->szIpAddress[index];
					}
					param.tcp.pszIpAddress = arrayPath;
				}

				param.tcp.port = pm->port ? pm->port : 3535;
				param.tcp.async = pm->async;
			}
			else
			{
				if( String::IsNullOrEmpty(pm->szCurMsg) )
				{
					param.usb.pszLinkName = NULL;
				}
				else 
				{
					TCHAR arrayPath[MAX_PATH] = {0};
					for( int index = 0; index < pm->szCurMsg->Length; ++index )
						arrayPath[index] = (TCHAR)pm->szCurMsg[index];

					param.usb.pszLinkName = arrayPath;
				}
			}

			unsigned int iReCode =  HalLinkAndDoInit( param );
			pm->devID = param.usb.devID;

			return ERROR_CODE_OK == iReCode;
		}
		static int GetNumDeviceAttached( array<unsigned char>^ arrayState )
		{
			int iDeviceNum = NumOfDeviceAttached();

			for( int index = 0; index < MAX_DEVICE_NUM; index++ )
			{
				if( HaveDeviceAttached( index ) )
					arrayState[index] = 1;
				else
					arrayState[index] = 0;
			}
			return iDeviceNum;
		}
		static bool CLRHalDetachAndClean( CLRLinkParam^ pm)
		{
			LinkParam param;
			param.LinkType = pm->LinkType;
			if( String::IsNullOrEmpty(pm->szCurMsg) )
				param.usb.pszLinkName = NULL;
			else 
			{
				TCHAR arrayPath[MAX_PATH] = {0};
				for( int index = 0; index < pm->szCurMsg->Length; ++index )
					arrayPath[index] = (TCHAR)pm->szCurMsg[index];

				param.usb.pszLinkName = arrayPath;
			}
			return ERROR_CODE_OK == HalDetachAndClean( param );
		}
		static String^ CLRGetErrorMessage( unsigned int code )
		{
			LPCTSTR pszMessage = GetErrorMessage( code );
			
			String^ strTemp = gcnew String(pszMessage);
// 			for( int index = 0; index < (int)lengthof(pszMessage); ++index )
// 			{
// 				strTemp += *(pszMessage + index);
// 			}
			return strTemp;
		}
		static String^ CLRGetProgramErrorMessage( unsigned char code )
		{
			LPCTSTR pszMessage = GetProgramErrorMessage( code );
			String^ strTemp = gcnew String(pszMessage);
// 			for( int index = 0; index < (int)lengthof(pszMessage); ++index )
// 			{
// 				strTemp += *(pszMessage + index);
// 			}
			return strTemp;
		}
	};

