        private byte[] deviceStates = new byte[ExportDeclares.MAX_DEVICE_NUMS];
        public byte[] DeviceStates
        {
            get { return deviceStates; }
            set
            {
                if (value != deviceStates)
                {
                    deviceStates = value;
