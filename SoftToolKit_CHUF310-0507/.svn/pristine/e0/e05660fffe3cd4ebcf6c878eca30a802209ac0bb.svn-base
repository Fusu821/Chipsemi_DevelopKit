    public class AppSetting
    {
        public static XmlDocument xml = new XmlDocument();
        public static string GetXmlAttrbuteString(XmlNode parent, string node, string key, string defRet = "")
        {
            if (null == parent) return defRet;
            XmlNode children = parent.SelectSingleNode(node);
            if (null == children) return defRet;
            if (null == children.Attributes[key]) return defRet;

            return children.Attributes[key].Value;
        }

        public static int GetXmlAttrbuteValue(XmlNode parent, string node, string key, int defRet = 0)
        {
            string ret = GetXmlAttrbuteString(parent, node, key, defRet.ToString());
            if (ret.Contains("0x"))
                return int.Parse(ret.Replace("0x", ""), NumberStyles.HexNumber);
            else
                return int.Parse(ret);
        }
        public static void SaveXmlAttrbuteString(XmlNode parent, string node, string key, string val)
        {
            XmlNode sub = parent.SelectSingleNode(node);
            if (null == sub)
            {
                sub = xml.CreateElement(node);
                parent.AppendChild(sub);
            }

            XmlAttribute attr = sub.Attributes[key];
            if (null == attr)
            {
                attr = xml.CreateAttribute(key);
                sub.Attributes.Append(attr);
            }
            attr.Value = val;
        }

        public static void SaveXmlAttrbuteValue<T>(XmlNode parent, string node, string key, T val, string format = null)
        {
            string strValue = "";
            if (string.IsNullOrEmpty(format))
            {
                strValue = val.ToString();
            }
            else
            {
                strValue = string.Format(format, val);
            }
            SaveXmlAttrbuteString(parent, node, key, strValue);
        }
        public static bool LoadXml(string path)
        {
            try
            {
                xml.RemoveAll();
                xml.Load(path);
            }
            catch (Exception ex)
            {
                ex.ToString();
                return false;
            }

            return true;
        }

        public static bool SaveXml(string path)
        {
            try
            {
                int endIndex = path.LastIndexOf('\\');
                string dir = path.Substring(0, endIndex);
                if (false == System.IO.Directory.Exists(dir))
                    System.IO.Directory.CreateDirectory(dir);

                xml.Save(path);
            }
            catch (Exception ex)
            {
                ex.ToString();
                return false;
            }

            return true;
        }
        public static void CreateNewXmlDoc()
        {
            xml = new XmlDocument();
            XmlDeclaration dec = xml.CreateXmlDeclaration("1.0", "utf-8", "yes");
            xml.AppendChild(dec);

            XmlElement tester = xml.CreateElement("semidevelop");
            xml.AppendChild(tester);

            //             XmlElement common = xml.CreateElement("common");
            //             tester.AppendChild(common);
        }
    }

    public class MainViewModel : CtrlEventDispacher
    {
        private MainWindow view = null;
        private static MainViewModel single = null;
        public MainViewModel(MainWindow v)
        {
            view = v;
            single = this;

            ProtocalList = new List<SMDefinition>()
            {
                new SMDefinition(0, "IIC"),
                new SMDefinition(1, "SPI"),
            };

            byte icType = eChipTypeList.CLR_IC_TYPE_ALL;
            int count = eChipTypeList.Count(icType);
            for (int index = 0; index < count; index++)
            {
                SMDefinition node = new SMDefinition(eChipTypeList.GetIcCodeByIndex(index, icType), eChipTypeList.GetIcNameByIndex(index, icType));
                icLists.Add(node);
            }

            LoadAndResolveAppSetting();
            //SelectedIC = 0x0400;
            //SlaveAddr = 0x5c;
        }

        public void LoadAndResolveAppSetting()
        {
            bool bOK = AppSetting.LoadXml(System.AppDomain.CurrentDomain.SetupInformation.ApplicationBase + "semichip_develop.xml");
            if (bOK)
            {
                XmlNode root = AppSetting.xml.SelectSingleNode("semidevelop");
                if (null != root)
                {
                    int selectedIcID = AppSetting.GetXmlAttrbuteValue(root, "params", "ic_type", 0x400);
                    SelectedIC = (ushort)selectedIcID;

                    int protocal = AppSetting.GetXmlAttrbuteValue(root, "params", "protocal", 0);
                    SelectedProtocal = (byte)protocal;

                    int iicspeed = AppSetting.GetXmlAttrbuteValue(root, "params", "i2c_speed", 5);
                    I2cSpeedIndex = (byte)iicspeed;

                    int spispeed = AppSetting.GetXmlAttrbuteValue(root, "params", "spi_speed", 2 << 3);
                    SpiSpeedDivision = (byte)spispeed;

                    int slave = AppSetting.GetXmlAttrbuteValue(root, "params", "i2c_addr", 0x5c);
                    SlaveAddr = (byte)slave;

                    int vdd = AppSetting.GetXmlAttrbuteValue(root, "params", "vdd_votage", 0x6E);
                    VddVotage = (byte)vdd;

                    int iovdd = AppSetting.GetXmlAttrbuteValue(root, "params", "iovdd_votage", 0x47);
                    IoVddVotage = (byte)iovdd;

                    int agent = AppSetting.GetXmlAttrbuteValue(root, "params", "agent", 0x1);
                    Agent = (byte)agent;

                    int vihvdd = AppSetting.GetXmlAttrbuteValue(root, "params", "vih_votage", 1800);
                    VIHVotage = (ushort)vihvdd;

                    IpAddress = AppSetting.GetXmlAttrbuteString(root, "params", "ip_addr", "127.0.0.1");

                    NotReset = AppSetting.GetXmlAttrbuteValue(root, "params", "not_reset", 0)>=1 ? true : false;
                }
            }
            else
            {
                AppSetting.CreateNewXmlDoc();
            }
        }

        ~MainViewModel()
        {
            XmlNode root = AppSetting.xml.SelectSingleNode("semidevelop");
            AppSetting.SaveXmlAttrbuteValue(root, "params", "ic_type", SelectedIC, "0x{0:X}");
            AppSetting.SaveXmlAttrbuteValue(root, "params", "protocal", SelectedProtocal);
            AppSetting.SaveXmlAttrbuteValue(root, "params", "vdd_votage", VddVotage, "0x{0:X}");
            AppSetting.SaveXmlAttrbuteValue(root, "params", "iovdd_votage", IoVddVotage, "0x{0:X}");
            AppSetting.SaveXmlAttrbuteValue(root, "params", "agent", Agent, "0x{0:X}");
            AppSetting.SaveXmlAttrbuteValue(root, "params", "i2c_addr", SlaveAddr, "0x{0:X}");
            AppSetting.SaveXmlAttrbuteValue(root, "params", "i2c_speed", I2cSpeedIndex);
            AppSetting.SaveXmlAttrbuteValue(root, "params", "spi_speed", SpiSpeedDivision);
            AppSetting.SaveXmlAttrbuteString(root, "params", "ip_addr", IpAddress);

            AppSetting.SaveXmlAttrbuteValue(root, "params", "vih_votage", VIHVotage);

            AppSetting.SaveXmlAttrbuteValue(root, "params", "not_reset", NotReset ? 1 : 0);

            AppSetting.SaveXml(System.AppDomain.CurrentDomain.SetupInformation.ApplicationBase + "semichip_develop.xml");
        }

