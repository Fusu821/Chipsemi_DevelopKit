<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewModel="clr-namespace:SEMIDevelopKit.Src.WinSub"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
			<RowDefinition Height="125"></RowDefinition>
			<RowDefinition Height="285"></RowDefinition>
        </Grid.RowDefinitions>
		
		<GroupBox Header="10：跳频、锁频" Grid.Row="0">
            <UniformGrid Rows="2">
				<UniformGrid Columns="16">
				<Control></Control>
				<CheckBox Content="FrequencyHopping(跳频)" Tag="3" viewModel:TuningItem.ItemName="funcCfg1"  HorizontalAlignment="Left" Margin="5" ></CheckBox>
				<CheckBox Content="锁定频率" Tag="7" viewModel:TuningItem.ItemName="fh_freq_lock"  HorizontalAlignment="Left" Margin="5" ></CheckBox>
				<CheckBox Content="选择辅频" Tag="0" viewModel:TuningItem.ItemName="fh_freq_lock"  HorizontalAlignment="Left" Margin="5" ></CheckBox>
				</UniformGrid>
				
				<UniformGrid Columns="16">
				<Control></Control>
				<CheckBox Content="自动切回主频" Tag="4" viewModel:TuningItem.ItemName="funcCfg1"  HorizontalAlignment="Left" Margin="5" ></CheckBox>
				</UniformGrid>
			</UniformGrid>
        </GroupBox>
		
		<GroupBox Header="11：跳频(FH)模式、跳频阈值配置" Grid.Row="1">
            <UniformGrid Rows="6">
				<UniformGrid Columns="16">
				<Label Content="分组选择" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="fh_noise_group"></TextBox>
                <Label Content="0:FW智能,0x0F:四组全选" HorizontalAlignment="Left" Margin="5"></Label>	
				<Control></Control>
				<CheckBox Content="只扫触摸首组"    Tag="28" viewModel:TuningItem.ItemName="funcCfgEx1"  HorizontalAlignment="Left" Margin="5" ></CheckBox>
				</UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="主频noise max" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="fh_noise_max"></TextBox>
				<Label Content="通道最大值" HorizontalAlignment="Left" Margin="5"></Label>                
                <Label Content="主频noise sum" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="fh_noise_sum"></TextBox>
				<Label Content="通道累和值" HorizontalAlignment="Left" Margin="5"></Label>                
				</UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="辅频noise max" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="fh_noise_max_auxi"></TextBox>
				<Label Content="通道最大值" HorizontalAlignment="Left" Margin="5"></Label>                
                <Label Content="辅频noise sum" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="fh_noise_sum_auxi"></TextBox>
				<Label Content="通道累和值" HorizontalAlignment="Left" Margin="5"></Label>                
				</UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="Max差值" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="fh_diff_max"></TextBox>
				<Label Content="最大值差" HorizontalAlignment="Left" Margin="5"></Label>                
                <Label Content="Sum差值" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="fh_diff_sum"></TextBox>
				<Label Content="通道累和值差" HorizontalAlignment="Left" Margin="5"></Label>                
				</UniformGrid>
				
				<UniformGrid Columns="16">
				<Control></Control>              
				</UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="敏感区间" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="NoiseFilterRatio"></TextBox>
				<Label Content="区间范围（比例100%）" HorizontalAlignment="Left" Margin="5"></Label>                
                <Label Content="滤帧" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="NoiseFilterCnt"></TextBox>
				<Label Content="过滤帧数" HorizontalAlignment="Left" Margin="5"></Label>                
				</UniformGrid>
			</UniformGrid>
        </GroupBox>
    </Grid>
</UserControl>
