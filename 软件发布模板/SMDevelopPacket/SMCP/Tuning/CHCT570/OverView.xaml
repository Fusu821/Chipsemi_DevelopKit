<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewModel="clr-namespace:SEMIDevelopKit.Src.WinSub"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <StackPanel>
        <ContentControl Content="{Binding XamlPath, Converter={StaticResource LinkUriConverter}, ConverterParameter=BasicSet.xaml}"></ContentControl>
        <ContentControl Content="{Binding XamlPath, Converter={StaticResource LinkUriConverter}, ConverterParameter=Function.xaml}"></ContentControl>
        <ContentControl Content="{Binding XamlPath, Converter={StaticResource LinkUriConverter}, ConverterParameter=FreqScan.xaml}"></ContentControl>
        <ContentControl Content="{Binding XamlPath, Converter={StaticResource LinkUriConverter}, ConverterParameter=FreqHopping.xaml}"></ContentControl>
        <ContentControl Content="{Binding XamlPath, Converter={StaticResource LinkUriConverter}, ConverterParameter=Threshold.xaml}"></ContentControl>
        <ContentControl Content="{Binding XamlPath, Converter={StaticResource LinkUriConverter}, ConverterParameter=Precision.xaml}"></ContentControl>
        <ContentControl Content="{Binding XamlPath, Converter={StaticResource LinkUriConverter}, ConverterParameter=Keys.xaml}"></ContentControl>
        <ContentControl Content="{Binding XamlPath, Converter={StaticResource LinkUriConverter}, ConverterParameter=Filter.xaml}"></ContentControl>
        <ContentControl Content="{Binding XamlPath, Converter={StaticResource LinkUriConverter}, ConverterParameter=Others.xaml}"></ContentControl>
    </StackPanel>
</UserControl>