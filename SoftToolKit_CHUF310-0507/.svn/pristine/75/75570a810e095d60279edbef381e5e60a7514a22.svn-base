struct SortPacket 
{
	double dpVal;
	int dpRow;
	int dpCol;
	SortPacket( int row, int col, double val = 0 )
		:dpRow(row)
		,dpCol(col)
		,dpVal(val)
	{

	}
	bool operator < ( const SortPacket& cmp ) const
	{
		return this->dpVal < cmp.dpVal;
	}
};

