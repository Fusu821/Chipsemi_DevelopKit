<UserControl x:Class="SEMIDevelopKit.Src.WinSub.TuningFrame"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             x:Name="tuningFrame"
             d:DesignHeight="500" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="80"></RowDefinition>
        </Grid.RowDefinitions>
        <UniformGrid Grid.Row="1" Rows="1" Columns="8" Margin="1">
            <Button Content="Bin->Host" Name="btn_cfg_pc" Command="{Binding ButtonCommand, ElementName=tuningFrame}" Margin="5"></Button>
            <Button Content="Host->Bin" Name="btn_pc_cfg" Command="{Binding ButtonCommand, ElementName=tuningFrame}" Margin="5"></Button>
            <Button Content="Tp->Host"  Name="btn_tp_pc" Command="{Binding ButtonCommand, ElementName=tuningFrame}" Margin="5"></Button>
            <Button Content="Host->Tp"  Name="btn_pc_tp" Command="{Binding ButtonCommand, ElementName=tuningFrame}" Margin="5"></Button>
            <Button Content="Ram->Host" Name="btn_ram_pc" Command="{Binding ButtonCommand, ElementName=tuningFrame}" Margin="5"></Button>
            <Button Content="Host->Ram" Name="btn_pc_ram" Command="{Binding ButtonCommand, ElementName=tuningFrame}" Margin="5"></Button>
            <Button Content=""></Button>
            <Button Content=""></Button>
        </UniformGrid>
        <TextBox Grid.Row="2" Margin="1, 0, 1, 1" Text="{Binding TuningInfo}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"></TextBox>
        <Grid Name="tuningGrid" Grid.Row="0">

        </Grid>
    </Grid>
</UserControl>
