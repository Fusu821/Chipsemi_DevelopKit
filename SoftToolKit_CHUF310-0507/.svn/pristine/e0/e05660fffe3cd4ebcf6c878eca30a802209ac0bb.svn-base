        private IList<SMDefinition> agentList = new List<SMDefinition>()
        {
            new SMDefinition(0x01,   "MTK"),
            new SMDefinition(0x03,   "ADB"),
            new SMDefinition(0x07,   "HID"),
            new SMDefinition(0x08,   "HIDIIC"),
            new SMDefinition(0x13,   "WIFI"),
            new SMDefinition(0x9,    "HTP_TCP"),
        };
        public IList<SMDefinition> AgentList
        {
            get { return agentList; }
            set { if (value != agentList) { agentList = value; OnPropertyChanged("AgentList"); } }
        }

        private ushort agent = 1;
        public ushort Agent
        {
            get { return agent; }
            set
            {
                if (value != agent)
                {
                    agent = value; 
                    OnPropertyChanged("Agent");

                    RuningKernel.Instance().Pause(false);
                    RuningKernel.Instance().Work.AddWorkTemporary(() =>
                    {
                        SMCommBase.MtkBoardReBoot((uint)agent);
                    });
                    RuningKernel.Instance().Work.AddWorkTemporary(() =>
                    {
                        CLRLinkParam linkParam = new CLRLinkParam();
                        if (0x13 == agent || 0x9 == agent)
                        {
                            linkParam.port = 3536;
                        }
                        else if (0x03 == agent) 
                        {
                            IpAddress = "127.0.0.1";
                            linkParam.port = 3535;
                        }
                        linkParam.LinkType = (byte)(agent & 0x0F);
                        linkParam.szIpAddress = IpAddress;

                        bool bConnected = ExportDeclares.CLRHalLinkAndDoInit(linkParam);
                        if (bConnected) DeviceStates = new byte[] { 1, 0, 0, 0 };
                        else DeviceStates = new byte[ExportDeclares.MAX_DEVICE_NUMS];

                        SMChipBase.SetICTypeAndCreateComponent(selectedIC);
                    });
                }
            }
        }

