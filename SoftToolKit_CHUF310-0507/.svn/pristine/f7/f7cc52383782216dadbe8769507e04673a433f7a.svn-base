unsigned int CTest570::OSCTrim_Test( NativeTestItem& itemQuote )
{
	int failerCnt = 0;
	unsigned int iReCode = ERROR_CODE_OK;
	osc_trim_t testTrim;
	ISMChip570* iChip570 = (ISMChip570*)SM_ChipBase(m_deviceNo);
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );

	TestResultInfo( _T("\r\n------------------------------OSC Trim Test------------------------------\r\n") );

	//unsigned short osTrim1 = 0, osTrim2 = 0, oscTrimNew = 0;
	unsigned int osTrim32k = 0, osTrim136m = 0, osTrim140m = 0, osTrim144m = 0, osTrim148m = 0, osTrim152m = 0, osTrim250m = 0;
	unsigned int osc32k_freq = 0, osc136m_freq = 0, osc140m_freq = 0, osc144m_freq = 0, osc148m_freq = 0, osc152m_freq = 0, osc250m_freq = 0;
	unsigned char readBuffer[1024] = {0}, markBuffer[4] = {0};
	//char szBuffer[MAX_PATH] = {0};
	unsigned int crc;

	testTrim.sig = 0x46726530;

	unsigned int oscTrimArray[8];

	bool needWriteFalsh = false;


	iReCode = SM_ChipBase(m_deviceNo)->ReadBurnSpace( FCT_ROM_VNM_REGION, readBuffer, sizeof(readBuffer) );
	if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	iReCode = SM_ChipBase(m_deviceNo)->ReadCoreSpace( 0x40008034, markBuffer, sizeof(markBuffer) );
	if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	osTrim32k  = (unsigned int)readBuffer[0];
	osTrim144m  = (unsigned int)readBuffer[2];
	osTrim144m  = (osTrim144m<<8) + (unsigned int)readBuffer[1];
	osTrim250m  = (unsigned int)readBuffer[03];
	m_stOneRecord.ReleaseID = *(UINT64*)&readBuffer[8];

	crc = caculate_check_sum_u32((unsigned int*)&readBuffer[32], sizeof(osc_trim_t));

	if( 0xff != (readBuffer[1] + readBuffer[5]) 
		|| 0xff != (readBuffer[2] + readBuffer[6])
		|| 0xff != (readBuffer[3] + readBuffer[7])
		|| osTrim250m < pCfg570->trim_250m_min 
		|| osTrim250m > pCfg570->trim_250m_max
		|| osTrim144m < pCfg570->trim_144m_min
		|| osTrim144m > pCfg570->trim_144m_max 
		|| osTrim32k < pCfg570->trim_32k_min
		|| osTrim32k > pCfg570->trim_32k_max
		|| (0 != crc)
		)//|| true
	{
		needWriteFalsh = true;
	}
	
	if (pCfg570->trim_only_check && needWriteFalsh == true)
	{
		failerCnt++;
		TestResultInfo( _T("\r\nOSCtrim only check error\r\n") );
		TestResultInfoR( _T("32K = 0x%02x, 144M=0x%02x, 250M=0x%02x, mark=0x%08x, crc=0x%08x"), osTrim32k, osTrim144m, osTrim250m, *(unsigned int*)markBuffer, crc);

		TestResultInfo( "\r\n\r\n//OSCTrim Test is Fail\r\n", ITEM_STA_FAIL );
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		return itemNotify;
	}
	else
	{
		TestResultInfo( _T("Start Trim And Refresh Trim Value\r\n") );
		SysDelay( 10 );

		iReCode = iChip570->GetOSCTrim( (unsigned char*)&osTrim32k, (unsigned char*)&osTrim144m,(unsigned char*) &osTrim250m, pCfg570->trim_speed_mode, pCfg570->tick_32k_standard, pCfg570->tick_144m_standard, pCfg570->tick_250m_standard, oscTrimArray);
		if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

		osc32k_freq = oscTrimArray[1];
		osc144m_freq = oscTrimArray[3];
		osc250m_freq = oscTrimArray[5];

		iReCode = iChip570->GetOSCTrim( (unsigned char*)&osTrim32k, (unsigned char*)&osTrim136m,(unsigned char*) &osTrim250m, pCfg570->trim_speed_mode, pCfg570->tick_32k_standard, pCfg570->tick_144m_standardNo2, 0, oscTrimArray);//136000
		if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
		osc136m_freq = oscTrimArray[3];

		iReCode = iChip570->GetOSCTrim( (unsigned char*)&osTrim32k, (unsigned char*)&osTrim140m,(unsigned char*) &osTrim250m, pCfg570->trim_speed_mode, pCfg570->tick_32k_standard, pCfg570->tick_144m_standardNo3, 0, oscTrimArray);//140000
		if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
		osc140m_freq = oscTrimArray[3];

		iReCode = iChip570->GetOSCTrim( (unsigned char*)&osTrim32k, (unsigned char*)&osTrim148m,(unsigned char*) &osTrim250m, pCfg570->trim_speed_mode, pCfg570->tick_32k_standard, pCfg570->tick_144m_standardNo4, 0, oscTrimArray);//148000
		if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
		osc148m_freq = oscTrimArray[3];

		iReCode = iChip570->GetOSCTrim( (unsigned char*)&osTrim32k, (unsigned char*)&osTrim152m,(unsigned char*) &osTrim250m, pCfg570->trim_speed_mode, pCfg570->tick_32k_standard, pCfg570->tick_144m_standardNo5, 0, oscTrimArray);//152000
		if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
		osc152m_freq = oscTrimArray[3];
	
	}

	if (needWriteFalsh == true)
	{
		if( osTrim32k < pCfg570->trim_32k_min )
			failerCnt++;
		else if( osTrim32k > pCfg570->trim_32k_max )
			failerCnt++;
		else if( osTrim144m < pCfg570->trim_144m_min )
			failerCnt++;
		else if( osTrim144m > pCfg570->trim_144m_max )
			failerCnt++;
		else if( osTrim250m < pCfg570->trim_250m_min )
			failerCnt++;
		else if( osTrim250m > pCfg570->trim_250m_max )
			failerCnt++;
	}

	int offset32k = (pCfg570->offset_32k) * pCfg570->tick_32k_standard;

	int offset144m = (pCfg570->offset_144m) * pCfg570->tick_144m_standard;
	int offset136m = (pCfg570->offset_144m) * pCfg570->tick_144m_standardNo2;
	int offset140m = (pCfg570->offset_144m) * pCfg570->tick_144m_standardNo3;
	int offset148m = (pCfg570->offset_144m) * pCfg570->tick_144m_standardNo4;
	int offset152m = (pCfg570->offset_144m) * pCfg570->tick_144m_standardNo5;

	int offset250m = (pCfg570->offset_250m) * pCfg570->tick_250m_standard;

	//iReCode = iChip570->GetTrimeDosc(fo_trim);
	//if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	int err32k = osc32k_freq - pCfg570->tick_32k_standard*1000;

	int err136m = osc136m_freq - pCfg570->tick_144m_standardNo2*1000;
	int err140m = osc140m_freq - pCfg570->tick_144m_standardNo3*1000;
	int err144m = osc144m_freq - pCfg570->tick_144m_standard*1000;
	int err148m = osc148m_freq - pCfg570->tick_144m_standardNo4*1000;
	int err152m = osc152m_freq - pCfg570->tick_144m_standardNo5*1000;

	int err250m = osc250m_freq - pCfg570->tick_250m_standard*1000;

	TestResultInfoR( _T("osc32k = %d, osc136m = %d, osc140m = %d, osc144m = %d, osc148m = %d, osc152m = %d, osc250m = %d\r\n"),
		osc32k_freq,osc136m_freq,osc140m_freq,osc144m_freq,osc148m_freq,osc152m_freq,osc250m_freq);
	if(abs(err32k) > offset32k )
	{
		failerCnt++;
		TestResultInfoR( _T("error 32k:Actual offset(%d), offset(%d), proportion(‰)(%d)\r\n"),abs(err32k),offset32k, pCfg570->offset_32k);
	}
	if((abs(err136m) > offset136m) ||(abs(err140m) > offset140m) || (abs(err144m) > offset144m) || (abs(err148m) > offset148m) || (abs(err152m) > offset152m))
	{
		failerCnt++;
		TestResultInfoR( _T("error 144m:Actual offset(%d, %d, %d, %d, %d), offset(%d, %d, %d, %d, %d), proportion(‰)(%d)\r\n")
			,abs(err136m),abs(err140m),abs(err144m),abs(err148m),abs(err152m),offset136m,offset140m,offset144m,offset148m,offset152m, pCfg570->offset_144m);
	}
	if(abs(err250m) > offset250m )
	{
		failerCnt++;
		TestResultInfoR( _T("error 250m:Actual offset(%d), offset(%d), proportion(‰)(%d)\r\n"),abs(err250m),offset250m, pCfg570->offset_250m);
	}

	if (needWriteFalsh == true)
	{
		testTrim.d[0][0] = osTrim136m;
		testTrim.d[0][1] = pCfg570->tick_144m_standardNo2 * 1000;

		testTrim.d[1][0] = osTrim140m;
		testTrim.d[1][1] = pCfg570->tick_144m_standardNo3 * 1000;

		testTrim.d[2][0] = osTrim144m;
		testTrim.d[2][1] = pCfg570->tick_144m_standard*1000;

		testTrim.d[3][0] = osTrim148m;
		testTrim.d[3][1] = pCfg570->tick_144m_standardNo4 * 1000;

		testTrim.d[4][0] = osTrim152m;
		testTrim.d[4][1] = pCfg570->tick_144m_standardNo5 * 1000;

		testTrim.chk  = testTrim.sig;
		testTrim.chk += testTrim.d[0][0];
		testTrim.chk += testTrim.d[0][1];
		testTrim.chk += testTrim.d[1][0];
		testTrim.chk += testTrim.d[1][1];
		testTrim.chk += testTrim.d[2][0];
		testTrim.chk += testTrim.d[2][1];
		testTrim.chk += testTrim.d[3][0];
		testTrim.chk += testTrim.d[3][1];
		testTrim.chk += testTrim.d[4][0];
		testTrim.chk += testTrim.d[4][1];
		testTrim.chk  = 0-testTrim.chk;

		osTrim144m = testTrim.d[2][0];

		readBuffer[0] = osTrim32k;
		readBuffer[1] = osTrim144m;
		readBuffer[2] = osTrim144m>>8;
		readBuffer[3] = osTrim250m;

		readBuffer[4] = ~readBuffer[0];
		readBuffer[5] = ~readBuffer[1];
		readBuffer[6] = ~readBuffer[2];
		readBuffer[7] = ~readBuffer[3];

		if (0 == failerCnt)
		{
			//Gen ICID
			unsigned int* pIntData = (unsigned int*)&readBuffer[8];
			unsigned short* pShortData = (unsigned short*)&readBuffer[8];
			if(0xffff != (pShortData[2] + pShortData[3]))
			{
				SYSTEMTIME SysTime;
				::GetLocalTime(&SysTime);
				pIntData[0] = (SysTime.wMonth << 22) + (SysTime.wDay << 17) + (SysTime.wHour << 12) + (SysTime.wMinute << 6) + SysTime.wSecond;

				std::srand((pIntData[0]+SysTime.wMilliseconds));
				::GetLocalTime(&SysTime);
				pShortData[2] = (((rand()&0xffff) + ((SysTime.wMilliseconds % 1000)<<3))&0xfff8) + m_deviceNo;
				pShortData[3] = ~pShortData[2];
			}

			//vid_pid
			UINT64* p_vid_pid = (UINT64*)&readBuffer[16];
			*p_vid_pid = pCfg570->vid_pid;

			memcpy(&readBuffer[32], &testTrim, sizeof(testTrim));
			iReCode = SM_ChipBase(m_deviceNo)->WriteBurnSpace( FCT_ROM_VNM_REGION, readBuffer, sizeof(readBuffer), OTP_W_CHK | TLK_DATACHK_EX1 );
			if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
		}

	}

	m_stOneRecord.ReleaseID = *(UINT64*)&readBuffer[8];
	UINT32 otm_time = *(UINT32*)&m_stOneRecord.ReleaseID;

	TestResultInfoR( _T("ICID = 0x%llx,   %d-%d, %d:%d:%d\r\n"), m_stOneRecord.ReleaseID, (otm_time>>22)&0xf, (otm_time>>17)&0x1f,(otm_time>>12)&0x1f, (otm_time>>6)&0x3f, otm_time&0x3f );

	m_stOneRecord.Mcap.oscTrim = *((unsigned int*)readBuffer);

	osTrim32k  = (unsigned int)readBuffer[0];
	osTrim144m  = (unsigned int)readBuffer[2];
	osTrim144m  = (osTrim144m<<8) + (unsigned int)readBuffer[1];
	osTrim250m  = (unsigned int)readBuffer[03];

	auto szBuffer = TestResultInfoR( _T("32K = 0x%02x, 144M=0x%02x, 250M=0x%02x, mark=0x%08x"), osTrim32k, osTrim144m, osTrim250m, *(unsigned int*)markBuffer );

	if( failerCnt )
	{
		TestResultInfo( "\r\n\r\n//OSCTrim Test is Fail\r\n", ITEM_STA_FAIL );
		itemNotify.UpdateItemResult( ITEM_STA_FAIL, szBuffer );
	}
	else
	{
		TestResultInfo( "\r\n\r\n//OSCTrim Test is Pass\r\n", ITEM_STA_PASS );
		itemNotify.UpdateItemResult( ITEM_STA_PASS, szBuffer );
	}

	return itemNotify;
}
unsigned int CTest570::Current_Test( NativeTestItem& itemQuote )
{
	TEST_ITEM_STATUS itemStatus = ITEM_STA_NONE;
	for( int index = 0; index < 3; index++ )
	{
		itemStatus = (TEST_ITEM_STATUS)Current_TestEx( itemQuote );
		if( itemStatus == ITEM_STA_PASS ) break;
	}
	return itemStatus;
}
unsigned int CTest570::Current_TestEx( NativeTestItem& itemQuote )
{
	int failedCount = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );

	TestResultInfo( _T("\r\n------------------------------Current Test------------------------------\r\n") );

	ISMChip570* iChip570 = (ISMChip570*)SM_ChipBase(m_deviceNo);
	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	short deepCurrent = 0, sleepCurrent = 0, activeCurrent = 0, idleCurrent = 0;
	short vbus_deepCurrent = 0, vbus_sleepCurrent = 0, vbus_activeCurrent = 0;
	short level[2][3] = {
		pCfg570->active_current_min, pCfg570->sleep_current_min, pCfg570->deep_current_min,
		pCfg570->active_current_max, pCfg570->sleep_current_max, pCfg570->deep_current_max,
	};
	//iReCode = iChip570->GetCurrent( level, (unsigned short*)&activeCurrent, (unsigned short*)&sleepCurrent, (unsigned short*)&deepCurrent, (unsigned short*)&idleCurrent );
	iReCode = iChip570->GetCurrent55xx( level, (unsigned short*)&activeCurrent, (unsigned short*)&sleepCurrent, (unsigned short*)&deepCurrent,(unsigned short*)&vbus_activeCurrent, (unsigned short*)&vbus_sleepCurrent, (unsigned short*)&vbus_deepCurrent);
	if( ERROR_CODE_OK != iReCode )  return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	//iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand( CMD_CTP_RST );
	//SysDelay( 50 );

	//TCHAR szTmep[MAX_PATH] = {0};

	{
		m_stOneRecord.current_mode1 = activeCurrent;
		m_stOneRecord.current_mode2 = sleepCurrent;
		m_stOneRecord.current_mode3 = deepCurrent;
		//transformat( szTmep, _T("\r\nactive = %d(mA), sleep = %d(uA), deep = %d(uA)\r\n"), activeCurrent, sleepCurrent, deepCurrent );
		//TestResultInfo( szTmep );
		TestResultInfoR( _T("\r\navdd_active = %d(mA), avdd_sleep = %d(uA), avdd_deep = %d(uA)\r\n"), activeCurrent, sleepCurrent, deepCurrent);
		TestResultInfoR( _T("\r\nvbus_active = %d(mA), vbus_sleep = %d(uA), vbus_deep = %d(uA)\r\n"), vbus_activeCurrent, vbus_sleepCurrent, vbus_deepCurrent);
	}
	if( activeCurrent < pCfg570->active_current_min )
	{
		failedCount++;
		//transformat( szTmep, _T( "\r\nactive(%d) < setting min(%d)\r\n"), activeCurrent, pCfg570->active_current_min );
		//TestResultInfo( szTmep );
		TestResultInfoR( _T( "\r\nactive(%d) < setting min(%d)\r\n"), activeCurrent, pCfg570->active_current_min );
	}
	if( activeCurrent > pCfg570->active_current_max )
	{
		failedCount++;
		//transformat( szTmep, _T( "\r\nactive(%d) > setting max(%d)\r\n"), activeCurrent, pCfg570->active_current_max );
		//TestResultInfo( szTmep );
		TestResultInfoR( _T( "\r\nactive(%d) > setting max(%d)\r\n"), activeCurrent, pCfg570->active_current_max );
	}
	if( sleepCurrent < pCfg570->sleep_current_min )
	{
		failedCount++;
		//transformat( szTmep, _T( "\r\nsleep(%d) < setting min(%d)\r\n"), sleepCurrent, pCfg570->sleep_current_min );
		//TestResultInfo( szTmep );
		TestResultInfoR( _T( "\r\nsleep(%d) < setting min(%d)\r\n"), sleepCurrent, pCfg570->sleep_current_min );
	}
	if( sleepCurrent > pCfg570->sleep_current_max )
	{
		failedCount++;
		//transformat( szTmep, _T( "\r\nsleep(%d) > setting max(%d)\r\n"), sleepCurrent, pCfg570->sleep_current_max );
		//TestResultInfo( szTmep );
		TestResultInfoR( _T( "\r\nsleep(%d) > setting max(%d)\r\n"), sleepCurrent, pCfg570->sleep_current_max );
	}
	if( deepCurrent < pCfg570->deep_current_min )
	{
		failedCount++;
		//transformat( szTmep, _T( "\r\ndeep(%d) < setting min(%d)\r\n"), deepCurrent, pCfg570->deep_current_min );
		//TestResultInfo( szTmep );
		TestResultInfoR( _T( "\r\ndeep(%d) < setting min(%d)\r\n"), deepCurrent, pCfg570->deep_current_min );
	}
	if( deepCurrent > pCfg570->deep_current_max )
	{
		failedCount++;
		//transformat( szTmep, _T( "\r\ndeep(%d) > setting max(%d)\r\n"), deepCurrent, pCfg570->deep_current_max );
		//TestResultInfo( szTmep );
		TestResultInfoR( _T( "\r\ndeep(%d) > setting max(%d)\r\n"), deepCurrent, pCfg570->deep_current_max );
	}

	if( vbus_activeCurrent < pCfg570->vbus_active_current_min )
	{
		failedCount++;
		TestResultInfoR( _T( "\r\nvbus_active(%d) < setting min(%d)\r\n"), vbus_activeCurrent, pCfg570->vbus_active_current_min );
	}
	if( vbus_activeCurrent > pCfg570->vbus_active_current_max )
	{
		failedCount++;
		TestResultInfoR( _T( "\r\nvbus_active(%d) > setting max(%d)\r\n"), vbus_activeCurrent, pCfg570->vbus_active_current_max );
	}

	if( vbus_sleepCurrent < pCfg570->vbus_sleep_current_min )
	{
		failedCount++;
		TestResultInfoR( _T( "\r\nvbus_sleep(%d) < setting min(%d)\r\n"), vbus_sleepCurrent, pCfg570->vbus_sleep_current_min );
	}
	if( vbus_sleepCurrent > pCfg570->vbus_sleep_current_max )
	{
		failedCount++;
		TestResultInfoR( _T( "\r\nvbus_sleep(%d) > setting max(%d)\r\n"), vbus_sleepCurrent, pCfg570->vbus_sleep_current_max );
	}

	if( vbus_deepCurrent < pCfg570->vbus_deep_current_min )
	{
		failedCount++;
		TestResultInfoR( _T( "\r\nvbus_deep(%d) < setting min(%d)\r\n"), vbus_deepCurrent, pCfg570->vbus_deep_current_min );
	}
	if( vbus_deepCurrent > pCfg570->vbus_deep_current_max )
	{
		failedCount++;
		TestResultInfoR( _T( "\r\nvbus_deep(%d) > setting max(%d)\r\n"), vbus_deepCurrent, pCfg570->vbus_deep_current_max );
	}

	if( failedCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//Current Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//Current Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}
unsigned int CTest570::ScapRawData_Test( NativeTestItem& itemQuote )
{
	int failerCount = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );
	signed short baseTempBuffer[MAX_MCAP_CHANNEL * 2] = {0};
	/*unsigned*/ short dataMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];
	const unsigned int iRawDataLen = ((pCfg570->rowsCnt + 1) * (pCfg570->colsCnt + 1) * 2 + 3) & 0xfffffffc;
	const unsigned int iScapRawDataLen = pCfg570->rowsCnt + pCfg570->colsCnt;

	TestResultInfo( _T("\r\n------------------------------ScapData Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip570* iChip570 = (ISMChip570*)SM_ChipBase(m_deviceNo);

	int addRow = ( pCfg570->real_channel_num - pCfg570->va_channel_num ) ? 1 : 0;

	//iReCode = iChip570->IncokeCommand( 0x05,0x02,0x5c);//取消补偿命令
	SysDelay( 100 );

	iReCode = iChip570->SwitchMode( MODE_RAWDATA, iRawDataLen   );
	if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	SysDelay( 20 );

	for( int index = 0; index < 2; index++ )
	{
		iReCode = iChip570->GetRawData( baseTempBuffer, iRawDataLen  );
		//if( iReCode == ERROR_CODE_OK ) break;
		if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	}

	int ref_channel_num = min(pCfg570->real_channel_num - pCfg570->va_channel_num, pCfg570->colsCnt);
	AnalyzeInfo info( pCfg570->rowsCnt, pCfg570->colsCnt );
	unsigned short maxCols[] = { pCfg570->colsCnt, pCfg570->rowsCnt };
	ReShappingData</*unsigned*/ short>( dataMatrix, (/*unsigned*/ short*)baseTempBuffer + pCfg570->rowsCnt * pCfg570->colsCnt, iScapRawDataLen, 2, maxCols );
	//short baseMin[MAX_MCAP_ROW][MAX_MCAP_COL] = {0}, baseMax[MAX_MCAP_ROW][MAX_MCAP_COL] = {0};
	//FillArrayUseValue( baseMin, pCfg570->base_min );
	//FillArrayUseValue( baseMax, pCfg570->base_max );

	NodeVal nodeOutRange;
	ColorText textTemp( _T("\r\nScap Data:\r\n") );
	bool bResult = AnalyzeTestResultMSCap( dataMatrix, pCfg570->scap_rawdata_min, pCfg570->scap_rawdata_max, pCfg570->invalid_node, info, textTemp, nodeOutRange, true );
	TestResultInfo( textTemp );
	if( !bResult )
	{
		failerCount++;
		LPCTSTR strHead = _T("\r\n//========= Out of Threshold in ScapDataTest: \r\n");
		PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
	}

	if( failerCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//ScapData Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//ScapData Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}
