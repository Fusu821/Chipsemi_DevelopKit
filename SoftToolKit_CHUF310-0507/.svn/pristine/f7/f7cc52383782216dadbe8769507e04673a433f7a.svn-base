unsigned int CTest570::STC_Test( NativeTestItem& itemQuote )
{
	int failerCount = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );
	signed short baseTempBuffer[MAX_MCAP_CHANNEL * 2] = {0};
	signed int baseSum[MAX_MCAP_CHANNEL * 2] = {0};
	/*unsigned*/ short baseMatrix[MAX_MCAP_ROW][MAX_MCAP_COL], uniformityMin[MAX_MCAP_ROW][MAX_MCAP_COL];
	const unsigned int iRawDataLen = ((pCfg570->rowsCnt) * (pCfg570->colsCnt) * 2 + 3) & 0xfffffffc;
	const unsigned int iRetry = 20;

	TestResultInfo( _T("\r\n------------------------------STC Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip570* iChip570 = (ISMChip570*)SM_ChipBase(m_deviceNo);

	int addRow = ( pCfg570->real_channel_num - pCfg570->va_channel_num ) ? 1 : 0;
	memset( uniformityMin, 0, sizeof(uniformityMin) );

	//iReCode = iChip570->IncokeCommand( CMD_CTP_RST );
	//SysDelay( 100 );

	//iReCode = iChip570->SetClkInFctMode( pCfg570->stc_clk_div, false );
	//if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	//SysDelay( 20 );

	iReCode = iChip570->SwitchMode( MODE_RAWDATA, iRawDataLen );
	if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	SysDelay( 20 );

	memset( baseSum, 0, sizeof(baseSum) );
	for( int index = 0; index < iRetry; index++ )
	{
		iReCode = iChip570->GetRawData( baseTempBuffer, iRawDataLen );
		if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

		if(0 == index) continue;
		ArrayAddtion( baseSum, baseTempBuffer, iRawDataLen );
	}
	ArrayAverage( baseTempBuffer, baseSum, iRawDataLen, iRetry - 1);

	int ref_channel_num = min(pCfg570->real_channel_num - pCfg570->va_channel_num, pCfg570->colsCnt);
	AnalyzeInfo info( pCfg570->rowsCnt, pCfg570->colsCnt, ref_channel_num, false );
	ReShappingData</*unsigned*/ short>( baseMatrix, (/*unsigned*/ short*)baseTempBuffer, G_XMLConfig->real_channel_num * 2, pCfg570->rowsCnt, pCfg570->colsCnt );
	//short baseMin[MAX_MCAP_ROW][MAX_MCAP_COL] = {0}, baseMax[MAX_MCAP_ROW][MAX_MCAP_COL] = {0};
	//FillArrayUseValue( baseMin, pCfg570->base_min );
	//FillArrayUseValue( baseMax, pCfg570->base_max );

	{
		NodeVal nodeOutRange;
		ColorText textTemp( _T("\r\nstc_rawdata:\r\n") );
		short baseMin[MAX_MCAP_ROW][MAX_MCAP_COL] = {0}, baseMax[MAX_MCAP_ROW][MAX_MCAP_COL] = {0};
		FillMatrixUseValue<short>( baseMax, 30000 );
		bool bResult = AnalyzeTestResult( baseMatrix, baseMin, baseMax, pCfg570->invalid_node, info, textTemp, nodeOutRange, true );
		TestResultInfo( textTemp );
	}

	{
		NodeVal nodeOutRange;
		ColorText textTemp( _T("\r\nstc_deviation:\r\n") );
		for( int iRow = 0; iRow < pCfg570->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg570->colsCnt; iCol++ )
			{
				int deviation = 10 * abs( baseMatrix[iRow][iCol] - pCfg570->stc_mean[iRow][iCol] );
				baseMatrix[iRow][iCol] = (short)(100 * deviation / (deviation + 3 * pCfg570->stc_mse[iRow][iCol] + 0.001));
			}
		}


		short stcMin[MAX_MCAP_ROW][MAX_MCAP_COL] = {0}, stcMax[MAX_MCAP_ROW][MAX_MCAP_COL] = {0};
		FillMatrixUseValue( stcMin, pCfg570->stc_min );
		FillMatrixUseValue( stcMax, pCfg570->stc_max );
		bool bResult = AnalyzeTestResult( baseMatrix, stcMin, stcMax, pCfg570->invalid_node, info, textTemp, nodeOutRange, true );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			failerCount++;
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in STC Test: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
		}
	}

	// 	{
	// 		NodeVal nodeOutRange;
	// 		ColorText textTemp( _T("\r\nstc_convolution_h:\r\n") );
	// 		short uniformityHorMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];
	// 		unsigned char uniformityHorInvalid[MAX_MCAP_ROW][MAX_MCAP_COL];
	// 		CopyAndInvalid( uniformityHorInvalid, pCfg570->invalid_node, 0, MAX_MCAP_COL );
	// 		GenHorizontalConvolution( baseMatrix, uniformityHorMatrix, pCfg570->rowsCnt, pCfg570->colsCnt );
	// 		bool bResult = AnalyzeTestResult( uniformityHorMatrix, uniformityMin, pCfg570->stc_uniformity_h, uniformityHorInvalid, info, textTemp, nodeOutRange, true );
	// 		TestResultInfo( textTemp );
	// 		if( !bResult )
	// 		{
	// 			failerCount++;
	// 			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in STC Uniformity-H: \r\n");
	// 			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
	// 		}
	// 	}
	// 	
	// 	{
	// 		NodeVal nodeOutRange;
	// 		ColorText textTemp( _T("\r\nstc_convolution_v:\r\n") );
	// 		short uniformityVerMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];
	// 		unsigned char uniformityVerInvalid[MAX_MCAP_ROW][MAX_MCAP_COL];
	// 		CopyAndInvalid( uniformityVerInvalid, pCfg570->invalid_node, MAX_MCAP_ROW, 0 );
	// 		GenVerticalConvolution( baseMatrix, uniformityVerMatrix, pCfg570->rowsCnt, pCfg570->colsCnt );
	// 		bool bResult = AnalyzeTestResult( uniformityVerMatrix, uniformityMin, pCfg570->stc_uniformity_v, uniformityVerInvalid, info, textTemp, nodeOutRange, true );
	// 		TestResultInfo( textTemp );
	// 		if( !bResult )
	// 		{
	// 			failerCount++;
	// 			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in STC Uniformity-V: \r\n");
	// 			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
	// 		}
	// 	}

	if( failerCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//STC Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//STC Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}
unsigned int CTest570::MCapRawData_Test( NativeTestItem& itemQuote )
{
	int failerCount = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );
	signed short baseTempBuffer[MAX_MCAP_CHANNEL * 2] = {0};
	signed int baseSum[MAX_MCAP_CHANNEL * 2] = {0};
	/*unsigned*/ short baseMatrix[MAX_MCAP_ROW][MAX_MCAP_COL], uniformityMin[MAX_MCAP_ROW][MAX_MCAP_COL];
	short NormalizationMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];
	const unsigned int iRawDataLen = ((pCfg570->rowsCnt) * (pCfg570->colsCnt) * 2 + 3) & 0xfffffffc;
	const unsigned int iRetry = 20;

	TestResultInfo( _T("\r\n------------------------------MCap RawData Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip570* iChip570 = (ISMChip570*)SM_ChipBase(m_deviceNo);

	int addRow = ( pCfg570->real_channel_num - pCfg570->va_channel_num ) ? 1 : 0;
	memset( uniformityMin, 0, sizeof(uniformityMin) );

	//iReCode = iChip570->IncokeCommand( CMD_CTP_RST );
	//SysDelay( 100 );

	//iReCode = iChip570->SetClkInFctMode( pCfg570->mcap_clk_div, false );
	//if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	//SysDelay( 20 );
	//iReCode = iChip570->IncokeCommand( 0x05,0x02,0x5c);//取消补偿命令
	//SysDelay( 20 );

	iReCode = iChip570->SwitchMode( MODE_RAWDATA, iRawDataLen );
	if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	SysDelay( 20 );

	memset( baseSum, 0, sizeof(baseSum) );
	for( int index = 0; index < iRetry; index++ )
	{
		iReCode = iChip570->GetRawData( baseTempBuffer, iRawDataLen );
		if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

		if(0 == index) continue;
		ArrayAddtion( baseSum, baseTempBuffer, iRawDataLen );
	}
	ArrayAverage( baseTempBuffer, baseSum, iRawDataLen, iRetry - 1);

	int ref_channel_num = min(pCfg570->real_channel_num - pCfg570->va_channel_num, pCfg570->colsCnt);
	AnalyzeInfo info( pCfg570->rowsCnt, pCfg570->colsCnt, ref_channel_num, false );
	ReShappingData</*unsigned*/ short>( baseMatrix, (/*unsigned*/ short*)baseTempBuffer, G_XMLConfig->real_channel_num * 2, pCfg570->rowsCnt, pCfg570->colsCnt );
	//short baseMin[MAX_MCAP_ROW][MAX_MCAP_COL] = {0}, baseMax[MAX_MCAP_ROW][MAX_MCAP_COL] = {0};
	//FillArrayUseValue( baseMin, pCfg570->base_min );
	//FillArrayUseValue( baseMax, pCfg570->base_max );

	ColorText textTempa( _T("\r\nmcap_rawdata:\r\n") );
	PrintMaxtrixValue( textTempa, baseMatrix,pCfg570->invalid_node, info, true );
	TestResultInfo( textTempa );
	Copy_RawData<MAX_MCAP_ROW,MAX_MCAP_COL>(NormalizationMatrix, baseMatrix, pCfg570->rowsCnt, pCfg570->colsCnt);

	auto pioce = 1.0f;
	RawData_Normalization<MAX_MCAP_ROW,MAX_MCAP_COL>(NormalizationMatrix,pCfg570->mcap_rawdata_min, pCfg570->mcap_rawdata_max,pCfg570->rowsCnt, pCfg570->colsCnt,pCfg570->macp_normalization_ratio_min,pCfg570->macp_normalization_ratio_max,pioce);

	TestResultInfoR(_T("\r\nnormalization_constant = %.2f, min =%.2f, max= %.2f\r\n"),pioce,pCfg570->macp_normalization_ratio_min,pCfg570->macp_normalization_ratio_max );

	{
		NodeVal nodeOutRange;
		ColorText textTemp( _T("\r\nmcap_normalization:\r\n") );
		bool bResult = AnalyzeTestResult( NormalizationMatrix, pCfg570->mcap_rawdata_min, pCfg570->mcap_rawdata_max, pCfg570->invalid_node, info, textTemp, nodeOutRange, true );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			failerCount++;
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in MCap RawData Test: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
		}
	}

	if(pCfg570->check_uniformity_hor)
	{
		NodeVal nodeOutRange;
		NodeVal nodeOutRange1;
		unsigned short hv_over_limit_num=0;
		ColorText textTemp( _T("\r\nmcap_uniformity_h:\r\n") );
		short uniformityHorMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];
		unsigned char uniformityHorInvalid[MAX_MCAP_ROW][MAX_MCAP_COL];
		CopyAndInvalid( uniformityHorInvalid, pCfg570->invalid_node, 0, MAX_MCAP_COL );
		GenHorizontalUniformity( NormalizationMatrix, uniformityHorMatrix, pCfg570->rowsCnt, pCfg570->colsCnt );
		bool bResult = AnalyzeTestResult_H_V<short,short,unsigned short,float,unsigned short,50,50>
			( uniformityHorMatrix, uniformityMin, pCfg570->mcap_uniformity_h, uniformityHorInvalid, info, textTemp, nodeOutRange,
			pCfg570->uniformity_invalid_node,pCfg570->macp_h_v_over_limit_ratio,hv_over_limit_num, nodeOutRange1,true );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			failerCount++;
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in MCap Uniformity-H: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
		}
		if (hv_over_limit_num > 0)
		{
			TestResultInfoR("\r\nPoint:%d,Exceeds the threshold by (%.2f%%)\r\n",hv_over_limit_num,pCfg570->macp_h_v_over_limit_ratio*100);
			LPCTSTR strHead1 = _T("//========= Risk Point in MCap Uniformity-H: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange1, strHead1 );
			if (hv_over_limit_num > pCfg570->macp_h_v_over_limit_maxnum)
			{
				TestResultInfoR("Uniformity-H:number of abnormal points(%d) > limit num(%d)\r\n",hv_over_limit_num,pCfg570->macp_h_v_over_limit_maxnum);
				failerCount++;
			}
		}
	}

	if(pCfg570->check_uniformity_ver)
	{
		NodeVal nodeOutRange;
		ColorText textTemp( _T("\r\nmcap_uniformity_v:\r\n") );
		NodeVal nodeOutRange1;
		unsigned short hv_over_limit_num=0;
		short uniformityVerMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];
		unsigned char uniformityVerInvalid[MAX_MCAP_ROW][MAX_MCAP_COL];
		CopyAndInvalid( uniformityVerInvalid, pCfg570->invalid_node, MAX_MCAP_ROW, 0 );
		GenVerticalUniformity( NormalizationMatrix, uniformityVerMatrix, pCfg570->rowsCnt, pCfg570->colsCnt );
		bool bResult = AnalyzeTestResult_H_V<short,short,unsigned short,float,unsigned short,50,50>
			( uniformityVerMatrix, uniformityMin, pCfg570->mcap_uniformity_v, uniformityVerInvalid, info, textTemp, nodeOutRange, 
			pCfg570->uniformity_invalid_node,pCfg570->macp_h_v_over_limit_ratio,hv_over_limit_num, nodeOutRange1,true );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			failerCount++;
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in MCap Uniformity-V: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
		}
		if (hv_over_limit_num > 0)
		{
			TestResultInfoR("\r\nPoint:%d,Exceeds the threshold by (%.2f%%)\r\n",hv_over_limit_num,pCfg570->macp_h_v_over_limit_ratio*100);
			LPCTSTR strHead1 = _T("//========= Risk Point in MCap Uniformity-V: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange1, strHead1 );
			if (hv_over_limit_num > pCfg570->macp_h_v_over_limit_maxnum)
			{
				TestResultInfoR("Uniformity-V:number of abnormal points(%d) > limit num(%d)\r\n",hv_over_limit_num,pCfg570->macp_h_v_over_limit_maxnum);
				failerCount++;
			}
		}
	}

	auto sampling = Judge_RawData_sampling<MAX_MCAP_ROW,MAX_MCAP_COL>(pCfg570->mcap_rawdata_min, pCfg570->mcap_rawdata_max,pCfg570->invalid_node,pCfg570->rowsCnt, pCfg570->colsCnt,pCfg570->rawdata_min_value,pCfg570->rawdata_max_value);
	if(sampling == false)
	{
		failerCount++;
		TestResultInfoR(_T("\r\nMcap_rawdata not sampled\r\n"));
	}

	if( failerCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//MCap RawData Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//MCap Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}
unsigned int CTest570::Short_Test( NativeTestItem& itemQuote )
{

	int failerCount = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );
	const int max_short_adc_num = (20+40);
	unsigned short shortAdc[max_short_adc_num] = {0};
	unsigned short adcMatrix[2][MAX_MCAP_COL] = {0};
	AnalyzeInfo info( pCfg570->rowsCnt, pCfg570->colsCnt, 0, false );

	TestResultInfo( _T("\r\n------------------------------Short Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip570* iChip570 = (ISMChip570*)SM_ChipBase(m_deviceNo);

	iReCode = iChip570->IncokeCommand(CMD_CTP_RST);
	SysDelay( 500 );

	iReCode = iChip570->GetShortData( shortAdc, max_short_adc_num * 2 );
	if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	unsigned short maxCols[] = { pCfg570->colsCnt, pCfg570->rowsCnt };
	ICArrayToSensorMatrix( adcMatrix, shortAdc, max_short_adc_num, 2, maxCols );

	NodeVal nodeOutRange;
	unsigned short adcMin[2][MAX_MCAP_COL] = {0};
	unsigned short adcMax[2][MAX_MCAP_COL] = {0}; 
	ColorText textTemp( _T("\r\nShort Data:\r\n") );
	FillMatrixUseValue( adcMin, (unsigned short)0 );
	FillMatrixRowUseValue( adcMax, pCfg570->short_tx_max, 0 );
	FillMatrixRowUseValue( adcMax, pCfg570->short_rx_max, 1 );
	adcMax[0][6] = 1300;
	bool bResult = AnalyzeTestResultMSCap<unsigned short>( adcMatrix, adcMin, adcMax, pCfg570->invalid_node, info, textTemp, nodeOutRange, true );
	TestResultInfo( textTemp );
	if( !bResult )
	{
		failerCount++;
		LPCTSTR strHead = _T("\r\n//========= Out of Threshold in ShortTest: \r\n");
		PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
	}

	if( failerCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//Short Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//Short Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}
unsigned int CTest570::FRT_Test( NativeTestItem& itemQuote )
{
	int failerCnt = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR, errCode = 0;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );
	unsigned char retBuffer[20];
	//char tempBuffer[MAX_PATH];

	TestResultInfo( _T("\r\n------------------------------FRT Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip570* iChip570 = (ISMChip570*)SM_ChipBase(m_deviceNo);

	iReCode = iChip570->IncokeCommand( CMD_RAM_TST, 0, 0, 0, retBuffer );
	if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	errCode = *(unsigned int*)&retBuffer[2];
	if(0x54000000 != errCode)
	{
		failerCnt++;
		//transformat( tempBuffer, _T("ReadCoreSpace, Code = 0x%x\r\n"), errCode );
		//TestResultInfo( tempBuffer );
		TestResultInfoR( _T("ReadCoreSpace, Code = 0x%x\r\n"), errCode );
	}


	iReCode = iChip570->IncokeCommand( CMD_FLASH_TST, 0, 0, 0, retBuffer );
	if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	errCode = *(unsigned int*)&retBuffer[2];
	if(0x54000000 != errCode)
	{
		failerCnt++;
		//transformat( tempBuffer, _T("ReadBurnSpace, Code = 0x%x\r\n"), errCode );
		//TestResultInfo( tempBuffer );
		TestResultInfoR( _T("ReadBurnSpace, Code = 0x%x\r\n"), errCode );
	}

	if( failerCnt )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//FRT Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//FRT Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}
unsigned int CTest570::IOVoltage_Test( NativeTestItem& itemQuote )
{
	int failerCnt = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );
	//TCHAR szTemp[MAX_PATH] = {0};

	TestResultInfo( _T("\r\n------------------------------IOVoltage Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip570* iChip570 = (ISMChip570*)SM_ChipBase(m_deviceNo);

	unsigned int ioVols[2][10] = {0};
	iReCode = iChip570->GetIoVoltage( ioVols );
	if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	if( PROTOCAL_IIC == pCfg570->protocalType )
	{
		//transformat( szTemp, _T("pin = low,  int vol = %-6d,	sda vol = %-6d,	scl vol = %-6d\r\n"), ioVols[0][2], ioVols[0][0], ioVols[0][1] );
		//TestResultInfo( szTemp );
		TestResultInfoR( _T("pin = low,  int vol = %-6d,	sda vol = %-6d,	scl vol = %-6d\r\n"), ioVols[0][2], ioVols[0][0], ioVols[0][1] );
		//transformat( szTemp, _T("pin = high, int vol = %-6d,	sda vol = %-6d,	scl vol = %-6d\r\n"), ioVols[1][2], ioVols[1][0], ioVols[1][1] );
		//TestResultInfo( szTemp );
		TestResultInfoR( _T("pin = high, int vol = %-6d,	sda vol = %-6d,	scl vol = %-6d\r\n"), ioVols[1][2], ioVols[1][0], ioVols[1][1] );
	}
	else if( PROTOCAL_SPI == pCfg570->protocalType )
	{
		//transformat( szTemp, _T("pin = low,  int vol = %-6d,	csn vol = %-6d,	mosi vol = %-6d,	miso = %-6d,	clk = %-6d\r\n"), ioVols[0][2], ioVols[0][3], ioVols[0][4], ioVols[0][5], ioVols[0][6] );
		//TestResultInfo( szTemp );
		TestResultInfoR( _T("pin = low,  int vol = %-6d,	csn vol = %-6d,	mosi vol = %-6d,	miso = %-6d,	clk = %-6d\r\n"), ioVols[0][2], ioVols[0][3], ioVols[0][4], ioVols[0][5], ioVols[0][6] );
		//transformat( szTemp, _T("pin = high, int vol = %-6d,	csn vol = %-6d,	mosi vol = %-6d,	miso = %-6d,	clk = %-6d\r\n"), ioVols[1][2], ioVols[1][3], ioVols[1][4], ioVols[1][5], ioVols[1][6] );
		//TestResultInfo( szTemp );
		TestResultInfoR( _T("pin = high, int vol = %-6d,	csn vol = %-6d,	mosi vol = %-6d,	miso = %-6d,	clk = %-6d\r\n"), ioVols[1][2], ioVols[1][3], ioVols[1][4], ioVols[1][5], ioVols[1][6] );
	}

	if( ioVols[0][2] < pCfg570->int_low_min || ioVols[0][2] > pCfg570->int_low_max )
	{
		failerCnt++;
		//transformat( szTemp, _T("int vol = %d, th = [%d - %d]\r\n"), ioVols[0][2], pCfg570->int_low_min, pCfg570->int_low_max );
		//TestResultInfo( szTemp );
		TestResultInfoR( _T("int vol = %d, th = [%d - %d]\r\n"), ioVols[0][2], pCfg570->int_low_min, pCfg570->int_low_max );
	}
	if( ioVols[1][2] < pCfg570->int_high_min || ioVols[1][2] > pCfg570->int_high_max )
	{
		failerCnt++;
		//transformat( szTemp, _T("int vol = %d, th = [%d - %d]\r\n"), ioVols[1][2], pCfg570->int_high_min, pCfg570->int_high_max );
		//TestResultInfo( szTemp );
		TestResultInfoR( _T("int vol = %d, th = [%d - %d]\r\n"), ioVols[1][2], pCfg570->int_high_min, pCfg570->int_high_max );
	}

	if( PROTOCAL_IIC == pCfg570->protocalType )
	{
		if( ioVols[0][0] < pCfg570->iic_low_min || ioVols[0][0] > pCfg570->iic_low_max )
		{
			failerCnt++;
			//transformat( szTemp, _T("sda vol = %d, th = [%d - %d]\r\n"), ioVols[0][0], pCfg570->iic_low_min, pCfg570->iic_low_max );
			//TestResultInfo( szTemp );
			TestResultInfoR( _T("sda vol = %d, th = [%d - %d]\r\n"), ioVols[0][0], pCfg570->iic_low_min, pCfg570->iic_low_max);
		}
		if( ioVols[1][0] < pCfg570->iic_high_min || ioVols[1][0] > pCfg570->iic_high_max )
		{
			failerCnt++;
			//transformat( szTemp, _T("sda vol = %d, th = [%d - %d]\r\n"), ioVols[1][0], pCfg570->iic_high_min, pCfg570->iic_high_max );
			//TestResultInfo( szTemp );
			TestResultInfoR( _T("sda vol = %d, th = [%d - %d]\r\n"), ioVols[1][0], pCfg570->iic_high_min, pCfg570->iic_high_max );
		}

		if( ioVols[0][1] < pCfg570->iic_low_min || ioVols[0][1] > pCfg570->iic_low_max )
		{
			failerCnt++;
			//transformat( szTemp, _T("scl vol = %d, th = [%d - %d]\r\n"), ioVols[0][1], pCfg570->iic_low_min, pCfg570->iic_low_max );
			//TestResultInfo( szTemp );
			TestResultInfoR( _T("scl vol = %d, th = [%d - %d]\r\n"), ioVols[0][1], pCfg570->iic_low_min, pCfg570->iic_low_max );
		}
		if( ioVols[1][1] < pCfg570->iic_high_min || ioVols[1][1] > pCfg570->iic_high_max )
		{
			failerCnt++;
			//transformat( szTemp, _T("scl vol = %d, th = [%d - %d]\r\n"), ioVols[1][1], pCfg570->iic_high_min, pCfg570->iic_high_max );
			//TestResultInfo( szTemp );
			TestResultInfoR( _T("scl vol = %d, th = [%d - %d]\r\n"), ioVols[1][1], pCfg570->iic_high_min, pCfg570->iic_high_max );
		}
	}
	else if( PROTOCAL_SPI == pCfg570->protocalType )
	{
		if( ioVols[0][3] < pCfg570->spi_low_min || ioVols[0][3] > pCfg570->spi_low_max )
		{
			failerCnt++;
			//transformat( szTemp, _T("csn vol = %d, th = [%d - %d]\r\n"), ioVols[0][3], pCfg570->spi_low_min, pCfg570->spi_low_max );
			//TestResultInfo( szTemp );
			TestResultInfoR( _T("csn vol = %d, th = [%d - %d]\r\n"), ioVols[0][3], pCfg570->spi_low_min, pCfg570->spi_low_max );
		}
		if( ioVols[1][3] < pCfg570->spi_high_min || ioVols[1][3] > pCfg570->spi_high_max )
		{
			failerCnt++;
			//transformat( szTemp, _T("csn vol = %d, th = [%d - %d]\r\n"), ioVols[1][3], pCfg570->spi_high_min, pCfg570->spi_high_max );
			//TestResultInfo( szTemp );
			TestResultInfoR( _T("csn vol = %d, th = [%d - %d]\r\n"), ioVols[1][3], pCfg570->spi_high_min, pCfg570->spi_high_max );
		}

		if( ioVols[0][4] < pCfg570->spi_low_min || ioVols[0][4] > pCfg570->spi_low_max )
		{
			failerCnt++;
			//transformat( szTemp, _T("mosi vol = %d, th = [%d - %d]\r\n"), ioVols[0][4], pCfg570->spi_low_min, pCfg570->spi_low_max );
			//TestResultInfo( szTemp );
			TestResultInfoR( _T("mosi vol = %d, th = [%d - %d]\r\n"), ioVols[0][4], pCfg570->spi_low_min, pCfg570->spi_low_max );
		}
		if( ioVols[1][4] < pCfg570->spi_high_min || ioVols[1][4] > pCfg570->spi_high_max )
		{
			failerCnt++;
			//transformat( szTemp, _T("mosi vol = %d, th = [%d - %d]\r\n"), ioVols[1][4], pCfg570->spi_high_min, pCfg570->spi_high_max );
			//TestResultInfo( szTemp );
			TestResultInfoR( _T("mosi vol = %d, th = [%d - %d]\r\n"), ioVols[1][4], pCfg570->spi_high_min, pCfg570->spi_high_max );
		}

		if( ioVols[0][5] < pCfg570->spi_low_min || ioVols[0][5] > pCfg570->spi_low_max )
		{
			failerCnt++;
			//transformat( szTemp, _T("miso vol = %d, th = [%d - %d]\r\n"), ioVols[0][5], pCfg570->spi_low_min, pCfg570->spi_low_max );
			//TestResultInfo( szTemp );
			TestResultInfoR(  _T("miso vol = %d, th = [%d - %d]\r\n"), ioVols[0][5], pCfg570->spi_low_min, pCfg570->spi_low_max );
		}
		if( ioVols[1][5] < pCfg570->spi_high_min || ioVols[1][5] > pCfg570->spi_high_max )
		{
			failerCnt++;
			//transformat( szTemp, _T("miso vol = %d, th = [%d - %d]\r\n"), ioVols[1][5], pCfg570->spi_high_min, pCfg570->spi_high_max );
			//TestResultInfo( szTemp );
			TestResultInfoR( _T("miso vol = %d, th = [%d - %d]\r\n"), ioVols[1][5], pCfg570->spi_high_min, pCfg570->spi_high_max );
		}

		if( ioVols[0][6] < pCfg570->spi_low_min || ioVols[0][6] > pCfg570->spi_low_max )
		{
			failerCnt++;
			//transformat( szTemp, _T("sclk vol = %d, th = [%d - %d]\r\n"), ioVols[0][6], pCfg570->spi_low_min, pCfg570->spi_low_max );
			//TestResultInfo( szTemp );
			TestResultInfoR( _T("sclk vol = %d, th = [%d - %d]\r\n"), ioVols[0][6], pCfg570->spi_low_min, pCfg570->spi_low_max );
		}
		if( ioVols[1][6] < pCfg570->spi_high_min || ioVols[1][6] > pCfg570->spi_high_max )
		{
			failerCnt++;
			//transformat( szTemp, _T("sclk vol = %d, th = [%d - %d]\r\n"), ioVols[1][6], pCfg570->spi_high_min, pCfg570->spi_high_max );
			//TestResultInfo( szTemp );
			TestResultInfoR(_T("sclk vol = %d, th = [%d - %d]\r\n"), ioVols[1][6], pCfg570->spi_high_min, pCfg570->spi_high_max );
		}
	}

	if( failerCnt )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//IOVoltage Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//IOVoltage Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}
unsigned int CTest570::Noise_Test( NativeTestItem& itemQuote )
{
	int failerCount = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );
	signed short baseTempBuffer[MAX_MCAP_CHANNEL * 2] = {0};
	//signed short MaxTempBuffer[MAX_MCAP_CHANNEL * 2] = {0};
	//signed short MinTempBuffer[MAX_MCAP_CHANNEL * 2] = {0};
	//signed short diffTempBuffer[MAX_MCAP_CHANNEL * 2] = {0};
	/*unsigned*/ short dataMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];
	const unsigned int iRawDataLen = ((pCfg570->rowsCnt + 1) * (pCfg570->colsCnt + 1) * 2 + 3) & 0xfffffffc;
	const unsigned int iScapRawDataLen = pCfg570->rowsCnt + pCfg570->colsCnt;
	unsigned short retBuffer[16] = {0};
	short noiseMin[MAX_MCAP_ROW][MAX_MCAP_COL], noiseMax[MAX_MCAP_ROW][MAX_MCAP_COL];

	short MaxMcapNoise[8] = {pCfg570->noise_max_mcap1, pCfg570->noise_max_mcap2, pCfg570->noise_max_mcap3, pCfg570->noise_max_mcap4, pCfg570->noise_max_mcap5, pCfg570->noise_max_mcap6, pCfg570->noise_max_mcap7, pCfg570->noise_max_mcap7 };
	short MaxScapNoise[8] = {pCfg570->noise_max_scap1, pCfg570->noise_max_scap2, pCfg570->noise_max_scap3, pCfg570->noise_max_scap4, pCfg570->noise_max_scap5, pCfg570->noise_max_scap6, pCfg570->noise_max_scap7, pCfg570->noise_max_scap7 };

	TestResultInfo( _T("\r\n------------------------------Noise Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip570* iChip570 = (ISMChip570*)SM_ChipBase(m_deviceNo);

	iReCode = iChip570->SwitchMode( MODE_RAWDATA, iRawDataLen );
	if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	for (int i =1; i<= pCfg570->tmp_num; i++)
	{
		iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand(CMD_CTP_FREQ,16,i, pCfg570->noise_frame,(unsigned char*)retBuffer);
		if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
		for (int k=0; k<100; k++)
		{
			SysDelay(20);
			iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand(CMD_CTP_FREQ,16,100, 0,(unsigned char*)retBuffer);
			if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
			unsigned short d0 = retBuffer[1];
			if(1 == d0)
			{
				break;

			}else if(0 == d0)
			{
				TestResultInfoR("\r\nGet tmp %d noise fail!!!", i);
				return itemNotify.UpdateItemResult( ITEM_STA_FAIL);
			}
			if (k > 30)
			{
				TestResultInfoR("\r\nGet tmp %d noise timeout!!!", i);
				return itemNotify.UpdateItemResult( ITEM_STA_FAIL);
			}

		}

		iReCode = iChip570->GetFwData((short*)baseTempBuffer, iRawDataLen );
		if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

		//iReCode = iChip570->SwitchMode( MODE_RAWDATA, iRawDataLen );
		//if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
		//SysDelay( 5 );
		//iReCode = iChip570->GetRawData( (short*)baseTempBuffer, iRawDataLen  );
		//if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

		int ref_channel_num = min(pCfg570->real_channel_num - pCfg570->va_channel_num, pCfg570->colsCnt);
		AnalyzeInfo info( pCfg570->rowsCnt, pCfg570->colsCnt, ref_channel_num, false );
		ReShappingData</*unsigned*/ short>( dataMatrix, (/*unsigned*/ short*)baseTempBuffer, G_XMLConfig->real_channel_num * 2, pCfg570->rowsCnt, pCfg570->colsCnt );


		FillMatrixUseValue( noiseMin, (short)0 );
		FillMatrixUseRatio<short,float,50,50>( noiseMax,pCfg570->noise_mcap_base ,((float)MaxMcapNoise[i-1])/100 );

		NodeVal nodeOutRange;
		ColorText textTemp(StrFormat("\r\nNoise Tmp %d McapData:\r\n",i) );
		bool bResult = AnalyzeTestResult<short, short, short, MAX_MCAP_ROW, MAX_MCAP_COL>( dataMatrix, noiseMin, noiseMax, pCfg570->invalid_node, info, textTemp, nodeOutRange, true );
		TestResultInfo( textTemp );
		if( !bResult )
		{
			failerCount++;
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in McapNoiseTest: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
			//break;
		}


		NodeVal nodeOutRangeScap;
		FillMatrixUseValue( dataMatrix, (short)0 );
		FillMatrixUseValue( noiseMin, (short)0 );
		FillMatrixUseRatio<short,float,50,50>( noiseMax,pCfg570->noise_scap_base, ((float)MaxScapNoise[i-1])/100 );
		unsigned short maxCols[] = { pCfg570->colsCnt, pCfg570->rowsCnt };
		ReShappingData</*unsigned*/ short>( dataMatrix, (/*unsigned*/ short*)baseTempBuffer + pCfg570->rowsCnt * pCfg570->colsCnt, iScapRawDataLen, 2, maxCols );
		ColorText textTempScap(StrFormat("\r\nNoise Tmp %d ScapData:\r\n",i) );
		bResult = AnalyzeTestResultMSCap<short, short, short, MAX_MCAP_ROW, MAX_MCAP_COL>( dataMatrix, noiseMin, noiseMax, pCfg570->invalid_node, info, textTempScap, nodeOutRangeScap, true );
		TestResultInfo( textTempScap );
		if( !bResult )
		{
			failerCount++;
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in ScapNoiseTest: \r\n");
			PrintNodeValue( m_ColorText, &nodeOutRangeScap, strHead );
			//break;
		}

		if(0 != failerCount)
		{
			//break;
		}

	}

	if( failerCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//Noise Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//Noise Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;


}

typedef struct _raw_flash_info {
	unsigned int sig;
	unsigned char sizeHead;
	unsigned char cnt;
	unsigned char version;
	unsigned char type;
	unsigned short lenTotal;
	unsigned short lenSingle;
	unsigned int chkHead;
	unsigned int chkAll;
	unsigned int chk[8];
	unsigned int chkCfgCdsp;
	unsigned char head2En;
	unsigned char reserveByte;
	unsigned short head2Offset;
	unsigned int time;
	unsigned int reserve[4];
} raw_flash_info;

unsigned int CTest570::Base_Test( NativeTestItem& itemQuote )
{
	int failerCount = 0;
	unsigned short retBuffer[16];
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );
	short baseTempBuffer[MAX_MCAP_CHANNEL * 2] = {0};
	short baseTempBuffer1[MAX_MCAP_CHANNEL] = {0};
	short mcap_dataMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];
	short scap_dataMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];

	const unsigned short (*tmp_base[8])[50]={pCfg570->tmp_1_mcapdata, pCfg570->tmp_2_mcapdata, pCfg570->tmp_3_mcapdata, pCfg570->tmp_4_mcapdata, pCfg570->tmp_5_mcapdata, pCfg570->tmp_6_mcapdata, pCfg570->tmp_7_mcapdata, pCfg570->tmp_8_mcapdata};

	const unsigned int iRetry = 10;

	const unsigned int iRawDataLen = ((pCfg570->rowsCnt * pCfg570->colsCnt + pCfg570->rowsCnt + pCfg570->colsCnt) * 2 + 3) & 0xfffffffc;
	const unsigned int iScapRawDataLen = pCfg570->rowsCnt + pCfg570->colsCnt;

	short diff_dataMatrix[MAX_MCAP_ROW][MAX_MCAP_COL];

	TestResultInfo( _T("\r\n------------------------------Base Data Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip570* iChip570 = (ISMChip570*)SM_ChipBase(m_deviceNo);

	int addRow = ( pCfg570->real_channel_num - pCfg570->va_channel_num ) ? 1 : 0;

	int ref_channel_num = min(pCfg570->real_channel_num - pCfg570->va_channel_num, pCfg570->colsCnt);
	AnalyzeInfo info( pCfg570->rowsCnt, pCfg570->colsCnt );
	unsigned short maxCols[] = { pCfg570->colsCnt, pCfg570->rowsCnt };

	ColorText textTemp;

	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand( CMD_CTP_RST );
	if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	SysDelay( 200 );

	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand( CMD_SWITCH_IIC );
	if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	SysDelay( 10 );

	iReCode = iChip570->SwitchMode( MODE_RAWDATA, iRawDataLen );
	if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	for(int i = 0; i < 8; i++)
	{
		if (i < pCfg570->tmp_num)
		{ 
			iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand(CMD_CTP_FREQ,0x15,i + 1, 20);
			if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

			for (int k=0; k<100; k++)
			{
				SysDelay(20);
				iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand(CMD_CTP_FREQ,0x15,100, 0,(unsigned char*)retBuffer);
				if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
				unsigned short d0 = retBuffer[1];
				if(1 == d0)
				{
					break;

				}else if(0 == d0)
				{
					TestResultInfoR("\r\nGet fast freq data fail!!!");
					return itemNotify.UpdateItemResult( ITEM_STA_FAIL);
				}
				if (k > 30)
				{
					TestResultInfoR("\r\nGet fast freq data timeout!!!");
					return itemNotify.UpdateItemResult( ITEM_STA_FAIL);
				}

			}

			iReCode = iChip570->GetFwData((short*)baseTempBuffer, iRawDataLen );
			if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

		}
		else
		{
			memset(baseTempBuffer,0,sizeof(baseTempBuffer));
			break;
		}

		auto str = StrFormat("\r\ntmp_%d_mcapdata:\r\n",i+1);
		textTemp+=str;

		ReShappingData</*unsigned*/ short>( mcap_dataMatrix, (/*unsigned*/ short*)baseTempBuffer, G_XMLConfig->real_channel_num * 2, pCfg570->rowsCnt, pCfg570->colsCnt );
		PrintMaxtrixValue<short, MAX_MCAP_ROW, MAX_MCAP_COL>( textTemp, mcap_dataMatrix, info, true );

		str = StrFormat("\r\ntmp_%d_scapdata:\r\n",i+1);
		textTemp+=str;
		ReShappingData</*unsigned*/ short>( scap_dataMatrix, (/*unsigned*/ short*)baseTempBuffer + pCfg570->rowsCnt * pCfg570->colsCnt, iScapRawDataLen, 2, maxCols );
		PrintScapData<short, MAX_MCAP_ROW, MAX_MCAP_COL>( textTemp, scap_dataMatrix, pCfg570->tmp_invalid_node, info, true );

		str = StrFormat("\r\nnormalization_%d_mcapdata:\r\n",i+1);
		textTemp+=str;
		tmp_data_normalization<short, short, MAX_MCAP_ROW, MAX_MCAP_COL>(mcap_dataMatrix, mcap_dataMatrix, pCfg570->rowsCnt, pCfg570->colsCnt,1);
		PrintMaxtrixValue<short, MAX_MCAP_ROW, MAX_MCAP_COL>( textTemp, mcap_dataMatrix, info, true );

		str = StrFormat("\r\nnormalization_%d_bmcapdata:\r\n",i+1);
		textTemp+=str;
		PrintMaxtrixValue<const unsigned short, MAX_MCAP_ROW, MAX_MCAP_COL>( textTemp, tmp_base[i], info, true );

		MatrixSubtraction<short, short, const unsigned short, MAX_MCAP_ROW, MAX_MCAP_COL>(diff_dataMatrix, mcap_dataMatrix, tmp_base[i], MAX_MCAP_ROW, MAX_MCAP_COL);	

		str = StrFormat("\r\ndiff_%d_mcapdata:\r\n",i+1);
		textTemp+=str;
		PrintMaxtrixValue<short, MAX_MCAP_ROW, MAX_MCAP_COL>( textTemp, diff_dataMatrix, info, true );

		ConvertShappingData<short, MAX_MCAP_ROW, MAX_MCAP_COL>(baseTempBuffer1,diff_dataMatrix, G_XMLConfig->real_channel_num * 2, pCfg570->rowsCnt, pCfg570->colsCnt );

		RollingR pRolling;
		pRolling.RollingNoiseFit1(baseTempBuffer1,(unsigned char)pCfg570->rowsCnt, (unsigned char)pCfg570->colsCnt);

		ReShappingData</*unsigned*/ short>( diff_dataMatrix, (/*unsigned*/ short*)baseTempBuffer1, G_XMLConfig->real_channel_num * 2, pCfg570->rowsCnt, pCfg570->colsCnt );

		MatrixInvalidSet<short, MAX_MCAP_ROW, MAX_MCAP_COL>(diff_dataMatrix, pCfg570->tmp_invalid_node, MAX_MCAP_ROW, MAX_MCAP_COL, 0);

		str = StrFormat("\r\nfinal_diff_%d_mcapdata:\r\n",i+1);
		textTemp+=str;
		NodeVal nodeOutRange;
		bool bResult = WTmpDiffAnalyzeTestResult<short, MAX_MCAP_ROW,MAX_MCAP_COL>(diff_dataMatrix, pCfg570->rowsCnt, pCfg570->colsCnt, pCfg570->base_diff_max, pCfg570->base_num_max,
			pCfg570->base_all_diff_max, pCfg570->base_all_num_max, textTemp, nodeOutRange);
		if (!bResult)
		{
			failerCount++;
			LPCTSTR strHead = _T("\r\n//========= Out of Threshold in base Test: \r\n");
			PrintBaseNodeValue( textTemp, &nodeOutRange, strHead );
		}

	}

	TestResultInfo( textTemp );

	if( failerCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//BaseData Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//BaseData Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}
unsigned int CTest570::SetClkInFctMode( unsigned short clkDiv )
{
	return SM_ChipBase(m_deviceNo)->SetClkInFctMode(clkDiv, pCfg570->filter_off);
}
unsigned int CTest570::WorkForGraphMode( bool bEnterGraphing /*= false*/ )
{
	unsigned int iReCode = ERROR_CODE_OK;

	if( bEnterGraphing && !IsTestInGraphStep() )
	{
		iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand( CMD_CTP_RST );
		CHECK_RETURN_IF_FAIL( iReCode );

		SysDelay( 200 );

		iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand( CMD_SWITCH_IIC );
		CHECK_RETURN_IF_FAIL( iReCode );

		SysDelay( 50 );

		iReCode = SM_ChipBase(m_deviceNo)->SwitchMode( MODE_TOUCH );
		CHECK_RETURN_IF_FAIL( iReCode );
	}
	else
	{

	}

	bEnterGraphing ? SetTestStatusInGraphStep() : SetTestStatusInDataStep();

	return iReCode;
}

