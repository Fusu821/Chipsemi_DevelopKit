struct ItemNotifyer
{
public:
	ItemNotifyer( const NativeTestInterface*& client, NativeTestItem& item )
		:m_pNativeIntr(client)
		,m_itemCopy(item)
	{
		m_itemCopy.testResult = ITEM_STA_START;
		navCallBack.onListItemChange( &m_itemCopy );
		//const NativeCallBack& call = m_pNativeIntr->GetCallBack();
		//OnListItemChangeCallBack back = call.onListItemChange;
		//(*back)();
	}
	virtual ~ItemNotifyer()
	{
		navCallBack.onListItemChange( &m_itemCopy );
		//NativeTestItem item = m_itemCopy;
		//const NativeCallBack& call = m_pNativeIntr->GetCallBack();
		//call.onListItemChange(m_itemCopy);
	}
	TEST_ITEM_STATUS UpdateItemResult( TEST_ITEM_STATUS status, LPCTSTR szMark = NULL )
	{
		if( m_pNativeIntr->FAEMode() )
		    m_itemCopy.testResult = ( status > ITEM_STA_TBD ) ? ITEM_STA_TBD : status;
		else
			m_itemCopy.testResult = status;
		if( szMark )
		{
			memcpy_s( m_itemCopy.testMark, sizeof(m_itemCopy.testMark), szMark, lengthof(szMark) );
		}
		else
		{
			memset( m_itemCopy.testMark, 0, sizeof(m_itemCopy.testMark) );
		}

		navCallBack.onListItemChange( &m_itemCopy );
		return status;
	}
	operator TEST_ITEM_STATUS()
	{
		return (TEST_ITEM_STATUS)m_itemCopy.testResult;
	}
private:
	NativeTestItem& m_itemCopy;
	const NativeTestInterface*& m_pNativeIntr;
};


