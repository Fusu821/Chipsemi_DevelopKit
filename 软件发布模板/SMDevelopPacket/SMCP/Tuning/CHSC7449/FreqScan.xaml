<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewModel="clr-namespace:SEMIDevelopKit.Src.WinSub"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="525"></RowDefinition>
			<RowDefinition Height="285"></RowDefinition>
        </Grid.RowDefinitions>
		
        <GroupBox Header="9：扫频参数（XY分频、截位、积分、累和）" Grid.Row="0">
            <UniformGrid Rows="12">
				<UniformGrid Columns="16">
                <Control></Control>
				<Control></Control>
				<Label Content="主频" HorizontalAlignment="Right" Margin="5"></Label>
				</UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="XY分频系数(mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="clkdiv_xy_mul"></TextBox>
                <Label Content="4的倍数" HorizontalAlignment="Left" Margin="5"></Label>
				<Label Content="XY分频系数(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="clkdiv_xy_self"></TextBox>
                <Label Content="4的倍数" HorizontalAlignment="Left" Margin="5"></Label>
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="积分次数(mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="clkdiv_hd_mul"></TextBox>
				<Label Content="(4~80)" HorizontalAlignment="Left" Margin="5"></Label>
				<Label Content="积分次数(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="clkdiv_hd_self"></TextBox>
				<Label Content="(4~80)" HorizontalAlignment="Left" Margin="5"></Label>  
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="数据截位(mul)"  Margin="5" HorizontalAlignment="Right"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="shift_mul"></TextBox>
                <Label Content="(0~7)" HorizontalAlignment="Left" Margin="5"></Label>
				<Label Content="数据截位(self-tx)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" Tag="7:4" viewModel:TuningItem.ItemName="shift_self" ></TextBox>
				<Label Content="数据截位(self-rx)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" Tag="3:0" viewModel:TuningItem.ItemName="shift_self"></TextBox>
                <!--Label Content="[7:4]Tx;[3:0]Rx(0~7)" HorizontalAlignment="Left" Margin="5"></Label-->
                </UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="ADC输出截位(sel+mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="shift_adc"></TextBox>
                <Label Content="[7:4]自容;[3:0]互容(0~7)" HorizontalAlignment="Left" Margin="5"></Label>
				<Label Content="DAC输出步进(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="dac_step"></TextBox>
				<Label Content="可配置(1~7)" HorizontalAlignment="Left" Margin="5"></Label>
                </UniformGrid>
				
				<UniformGrid Columns="16">
				<Control></Control>	
				<Control></Control>	
				<Control></Control>	
				<Label Content="累和次数(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="self_inte"></TextBox>
				<Label Content="(1~16)" HorizontalAlignment="Left" Margin="5"></Label>                  
				</UniformGrid>	
				
				<UniformGrid Columns="16">
                <Control></Control>
				<Control></Control>
				<Label Content="辅频" HorizontalAlignment="Right" Margin="5"></Label>
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="XY分频系数(mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="clkdiv_xy_mul1"></TextBox>
                <Label Content="4的倍数" HorizontalAlignment="Left" Margin="5"></Label>
				<Label Content="XY分频系数(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="clkdiv_xy_self1"></TextBox>
                <Label Content="4的倍数" HorizontalAlignment="Left" Margin="5"></Label>				
				</UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="积分次数(mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="clkdiv_hd_mul1"></TextBox>
				<Label Content="(4~80)" HorizontalAlignment="Left" Margin="5"></Label> 
				<Label Content="积分次数(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="clkdiv_hd_self1"></TextBox>
				<Label Content="可配置(4~80)" HorizontalAlignment="Left" Margin="5"></Label>
                </UniformGrid>
				
				<UniformGrid Columns="16">
                <Label Content="数据截位(mul）"  Margin="5" HorizontalAlignment="Right"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="shift_mul1"></TextBox>
                <Label Content="(0~7)" HorizontalAlignment="Left" Margin="5"></Label>
                <Label Content="数据截位(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="shift_self1"></TextBox>
                <Label Content="[7:4]Tx;[3:0]Rx(0~7)" HorizontalAlignment="Left" Margin="5"></Label>
                </UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="ADC输出截位(sel+mul)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="shift_adc1"></TextBox>
                <Label Content="[7:4]自容;[3:0]互容(0~7)" HorizontalAlignment="Left" Margin="5"></Label>
				<Label Content="DAC输出步进(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="dac_step1"></TextBox>
				<Label Content="(1~7)" HorizontalAlignment="Left" Margin="5"></Label>
                </UniformGrid>
				
				<UniformGrid Columns="16">
				<Control></Control>	
				<Control></Control>	
				<Control></Control>	
				<Label Content="累和次数(self)" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="self_inte1"></TextBox>
				<Label Content="(1~16)" HorizontalAlignment="Left" Margin="5"></Label>                  
				</UniformGrid>
			</UniformGrid>
        </GroupBox>
		
		<GroupBox Header="9.1：大屏（Pad）配置" Grid.Row="1">
            <UniformGrid Rows="6">
				<UniformGrid Columns="16">
				<Label Content="大屏开关"  HorizontalAlignment="Right" Margin="5"></Label>
                <CheckBox Content="Pad Func"       Tag="11" viewModel:TuningItem.ItemName="funcCfgEx1"  HorizontalAlignment="Left" Margin="5" ></CheckBox>
				<CheckBox Content="单指断线强滤波"   Tag="27" viewModel:TuningItem.ItemName="funcCfgEx1"  HorizontalAlignment="Left" Margin="5" ></CheckBox>
				</UniformGrid>
				
				<UniformGrid Columns="16">
                <Control></Control>
				<Label Content="主频 Slt" HorizontalAlignment="Center" Margin="5"></Label>
				<Control></Control>
				<Control></Control>
				<Label Content="辅频 Slt" HorizontalAlignment="Center" Margin="5"></Label>
				</UniformGrid>
			
				<UniformGrid Columns="16">
                <Label Content="XY分频系数" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="clkdiv_xy_self_txM"></TextBox>
                <Label Content="4的倍数" HorizontalAlignment="Left" Margin="5"></Label>
				<Label Content="XY分频系数" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="clkdiv_xy_self_txA"></TextBox>
                <Label Content="4的倍数" HorizontalAlignment="Left" Margin="5"></Label>				
				</UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="积分次数" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="clkdiv_hd_self_txM"></TextBox>
				<Label Content="(4~80)" HorizontalAlignment="Left" Margin="5"></Label> 
				<Label Content="积分次数" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="clkdiv_hd_self_txA"></TextBox>
				<Label Content="可配置(4~80)" HorizontalAlignment="Left" Margin="5"></Label>
                </UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="DAC输出步进" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="dac_step_txM"></TextBox>
				<Label Content="(1~7)" HorizontalAlignment="Left" Margin="5"></Label>
				<Label Content="DAC输出步进" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="dac_step_txA"></TextBox>
				<Label Content="(1~7)" HorizontalAlignment="Left" Margin="5"></Label>
                </UniformGrid>
				
				<UniformGrid Columns="16">
				<Label Content="累和次数" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="self_inte_txM"></TextBox>
				<Label Content="(1~16)" HorizontalAlignment="Left" Margin="5"></Label> 
				<Label Content="累和次数" HorizontalAlignment="Right" Margin="5"></Label>
                <TextBox Margin="5" viewModel:TuningItem.ItemName="self_inte_txA"></TextBox>
				<Label Content="(1~16)" HorizontalAlignment="Left" Margin="5"></Label>                  
				</UniformGrid>
			</UniformGrid>
        </GroupBox>
    </Grid>
</UserControl>
