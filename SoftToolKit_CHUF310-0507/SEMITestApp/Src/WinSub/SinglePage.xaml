<Page x:Class="SEMITestApp.Src.WinSub.SinglePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SEMITestApp.Src.WinSub"
      xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SinglePage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <ContentControl Grid.Row="0" Template="{StaticResource ListGraphTemplate}"></ContentControl>
            <!--DockPanel Grid.Row="1" Margin="5,0,5,4" Visibility="{Binding SNCodeVisible}">
                <Label Content="SN:" Width="35" DockPanel.Dock="Left"></Label>
                <TextBox DockPanel.Dock="Right" Text="{Binding SNCode}" IsReadOnly="True" IsEnabled="{Binding SNCodeEnable}"></TextBox>
            </DockPanel-->
        </Grid>
        
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition Height="10"></RowDefinition>
                <RowDefinition Height="60"></RowDefinition>
            </Grid.RowDefinitions>
            <RichTextBox x:Name="testMessage" Margin="0,0,5,2" Padding="1" IsReadOnly="True" BorderBrush="{DynamicResource AccentColorBrush}" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Auto">
              
            </RichTextBox>
            <Controls:MetroProgressBar Value="{Binding ProcessBarPosition}"
                                       Maximum="{Binding ProcessBarMax}"
                                       Grid.Row="1"
                                       Minimum="0"
                                       Foreground="Blue"
                                       Margin="0, 0, 0, 5" />
            <Button Style="{DynamicResource MetroFlatButton}" BorderThickness="1" Content="{Binding TestStatus, Converter={StaticResource TestStatusToTextConverter}}" FontSize="32" FontWeight="Bold" BorderBrush="Blue" Grid.Row="2" Margin="0,0,5,5" Background="{Binding TestStatus, Converter={StaticResource TestStatusToBrushConverter}}">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="Click">
                        <i:InvokeCommandAction Command="{Binding ctrlClickCommand}" CommandParameter="start-button-click"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </Button>
        </Grid>
    </Grid>
</Page>
