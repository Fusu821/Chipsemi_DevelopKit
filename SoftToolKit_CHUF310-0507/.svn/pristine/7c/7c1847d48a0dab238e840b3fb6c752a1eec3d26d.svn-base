struct LinkParam
{
	union 
	{
		struct  
		{
			LPCTSTR pszIpAddress;
			unsigned short port;
			unsigned short nport;
			unsigned char async;
		}tcp;
		struct 
		{
			unsigned int boartRate;
			unsigned short port;
		}com;
		struct  
		{
			LPCTSTR pszLinkName;
			unsigned short devID;
		}usb;
		struct
        {
            LPCTSTR procName;
        }proc;
	};
	unsigned char LinkType;
};

struct CtpHalCfg
{
	unsigned short icType;
    unsigned char protocalType;
	unsigned char vddVoltage;
	unsigned char iovddVotage;
	unsigned short vihVotage;//hjx-221216
	unsigned short speed;
	struct _IIC
	{
		unsigned char slaveAddr;
		//unsigned short speed;
	}IIC;
	struct _SPI 
	{
		unsigned char mode;
		//unsigned short speed;
	}SPI;
};

struct Device 
{
	int iDevIndex;
	HANDLE handle;
};

typedef struct __ts352x_rpt_pt
{
	unsigned char  x_h:6;
	unsigned char  event:2;
	unsigned char  x_l:8;
	unsigned char  y_h:4;
	unsigned char  id:4;
	unsigned char  y_l:8;
	unsigned char  z;
	unsigned char  area;   //5th point, i.e pts[4] and 10th point, i.e. pts[9] is special 
}sm_pt_t;  

typedef struct __ts352x_rpt_data
{
	unsigned char resv;
	unsigned char act;
	unsigned char num;  
	//offset 4;
	sm_pt_t pts[2];  //reserved for 2 points
}scap_rpt_data_t;

typedef struct _rpt_point_t 
{
	union 
	{
		struct 
		{
			unsigned char x_l8;
			unsigned char y_l8;
			unsigned char z;
			unsigned char x_h4:4;
			unsigned char y_h4:4;
			unsigned char id:4;
			unsigned char event:4;
		};
		unsigned char data[5];
	};
}rpt_point_t;

typedef struct _rpt_content_t 
{
	unsigned char act;
	unsigned char num;
	rpt_point_t points[15];
}mcap_content_t;

#define MAX_MUTI_TRIM    (5)
typedef struct _fct_osc_trim{
	unsigned int osc32k_trim;
	unsigned int osc32k_freq;

	unsigned int osc96m_trim;
	unsigned int osc96m_freq;

	unsigned int osc250m_trim;
	unsigned int osc250m_freq;

	unsigned int osc96m_table[MAX_MUTI_TRIM];
	unsigned int osc96m_freqs[MAX_MUTI_TRIM];
	unsigned int osc96m_meter[MAX_MUTI_TRIM];

	unsigned int checskum;
}fct_osc_trim;


typedef void (*LPCheckCatchBootCallBack)( int dev, int curPos, int maxPos, LPCTSTR szText );
typedef void (__stdcall *LPUpdateProcessPosCallBack)( unsigned char devNo, int pos, int maxPos );

class ProtocalApi;

class SM_CHIP_API ICommBase
{
public:
	virtual ~ICommBase() {}

	virtual BOOL Connected() = 0;
	virtual unsigned int GetCommType() = 0;
	virtual unsigned int SyncWorkcInit( unsigned char bHold = 1 ){ return ERROR_CODE_NO_DEVICE; }
	virtual unsigned int HalTrySetDeviceManuly( Device hDevice ) = 0;
	virtual unsigned int SendCommand( unsigned char* pWrite, unsigned char* pRead ) = 0;
	virtual unsigned int SendCommandAndCheck( ProtocalApi* protocalApi, unsigned char* pWrite, unsigned char* pRead, unsigned short delay = 30 ) = 0;
	virtual unsigned int ReadFromUsbMemory( unsigned short addr, unsigned char* pRead, unsigned short len ) = 0;
	virtual unsigned int WriteToUsbMemory( unsigned short addr, const unsigned char* pWrite, unsigned short len ) = 0;
	virtual unsigned int SetIoVoltage( unsigned short vdd, unsigned short iovdd, unsigned short vih ) = 0;
	//virtual unsigned int SetIoVoltageTest( unsigned short vdd, unsigned short iovdd, unsigned short vih,unsigned short vih1000) = 0;
	virtual unsigned int UpgradeMtkBoard( unsigned char devNo, unsigned char* pMtkBin, unsigned int len, LPUpdateProcessPosCallBack lpProcess ) = 0;
	virtual unsigned int ReadMtkBoard( unsigned char devNo, unsigned char* pMtkBin, unsigned int len, LPUpdateProcessPosCallBack lpProcess ) {return 0;};
	virtual unsigned int PrepareMtkBoardUpgrade(  ) = 0;
	virtual unsigned int MtkBoardReBoot(unsigned int wantGo){ return ERROR_CODE_NO_DEVICE; }
	virtual unsigned int DetectMtkExtendSignal( unsigned char* signal = 0 ){ return ERROR_CODE_NO_DEVICE; }
	virtual unsigned int SetMtkExternOutput( unsigned char PB0, unsigned char PB1, unsigned char PB2 ){ return ERROR_CODE_NO_DEVICE; }
	virtual unsigned int SetSimulateContext( LPVOID pContext ) { return ERROR_CODE_NO_DEVICE; }

	virtual unsigned short GET_MTK_LINK_AND_ID() { return MTK_LINK_AND_ID;  }
	virtual unsigned short GET_MTK_DEVICE_NO_ADDR() { return SM_MTK_DEVICE_NO_ADDR;  }
	virtual unsigned short GET_MTK_CMD_BUF() { return MTK_CMD_BUF;  }
	virtual unsigned short GET_MTK_RSP_BUF() { return MTK_RSP_BUF;  }
	virtual unsigned short GET_MTK_FUNC_BUF() { return MTK_FUNC_BUF;  }
	virtual unsigned short GET_MTK_TXRX_BUF_SCAP() { return MTK_TXRX_BUF_SCAP;  }
	virtual unsigned short GET_MTK_TXRX_BUF_MCAP() { return MTK_TXRX_BUF_MCAP;  }
	virtual unsigned short GET_MTK_DATA_RDY() { return MTK_DATA_RDY;  }
	virtual unsigned short GET_MTK_TXRX_BUF_MTK() { return MTK_TXRX_BUF_MTK;  }
	virtual unsigned short GET_MTK_DEV_TYPE_ADDR() { return DEV_TYPE_ADDR;  }
	virtual unsigned short GET_MTK_VER_ADDR() { return MTK_VER_ADDR;  }
	virtual unsigned short GET_MTK_FLASHBOOT_1KCHK() { return MTK_FLASHBOOT_1KCHK; }
	
};
class SM_CHIP_API ISMChipBase
{
public:
	virtual ~ISMChipBase(){}

	virtual LPVOID GetSRefInterface() = 0;

	virtual BOOL HaveTpLinked( unsigned int retry = 1 ) = 0;
	virtual unsigned int SwitchMode( unsigned char modeType, unsigned short len = 0 ) = 0;
	virtual unsigned int SetCommContext( const CtpHalCfg& halCfg ) = 0;
	virtual unsigned int IncokeCommand( unsigned char command, unsigned int d0 = 0, unsigned short d1 = 0, unsigned short d2 = 0, unsigned char* retBuffer = NULL ) = 0;
	virtual unsigned int HalAccessMode( unsigned char accType = 0 ) = 0;
	virtual unsigned int WriteRegister( unsigned int address, unsigned int ucData ) = 0;
	virtual unsigned int ReadRegister( unsigned int address, unsigned int* pUcData ) = 0;
	virtual unsigned int GetTouchPoint( unsigned char* pointBuffer, unsigned short* len ) = 0;
	virtual unsigned int GetRawData( short* rawdataBuffer, unsigned short len ) = 0;
	virtual unsigned int ReadCoreSpace( unsigned int addr, unsigned char* buffer, unsigned int len ) = 0;
	virtual unsigned int WriteCoreSpace( unsigned int addr, unsigned char* buffer, unsigned int len ) = 0;
	virtual unsigned int ReadBurnSpace( unsigned int addr, unsigned char* buffer, unsigned int len ) = 0;
	virtual unsigned int ReadMtkFlash( unsigned int addr, unsigned char* buffer, unsigned int len) = 0;
	virtual unsigned int EraseBurnSpace( unsigned int addr, unsigned int len ) = 0;
	virtual unsigned int WriteBurnSpace( unsigned int addr, const unsigned char* buffer, unsigned int len, unsigned char type ) = 0;
	virtual unsigned int CheckCatchBootToMtk( unsigned int addr, unsigned char* bootBuffer, unsigned int bootLen, LPCheckCatchBootCallBack onBootCallBack = NULL ) = 0;
	virtual unsigned int SetClkInFctMode( unsigned short clkDiv, unsigned char filterOff ) = 0;
// 	virtual unsigned int BSPRWrite( unsigned char* writeBuffer, unsigned int iWrite ) = 0;
// 	virtual unsigned int BSPRRead( unsigned char* readBuffer, unsigned int iRead ) = 0;
	virtual unsigned int BSPRWriteAndRead( unsigned char* writeBuffer, unsigned int iWrite, unsigned char* readBuffer, unsigned int iRead ) = 0;
};

