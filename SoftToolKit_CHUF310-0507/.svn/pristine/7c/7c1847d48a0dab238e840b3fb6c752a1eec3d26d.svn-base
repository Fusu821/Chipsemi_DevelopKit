	CC_ERR_GOING =7,
	CC_ERR_INIT =8,
	CC_ERR_X =9,
	CC_EDRV_NOTCMD =0x10,  //  16
	CC_EDRV_MAGIC =0x11,     //  17
	CC_EDRV_RSPFRM =0x12,     //  18
