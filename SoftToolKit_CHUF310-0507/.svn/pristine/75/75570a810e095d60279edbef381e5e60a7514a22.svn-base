unsigned int CTest3536::Boot_Test( NativeTestItem& itemQuote )
{
	BOOL bCheckFlashOk = FALSE;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );

	TestResultInfo( _T("\r\n------------------------------BOOT Test------------------------------\r\n") );

	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);
	if( NULL == iChip3536 )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	iChip3536->IncokeCommand(CMD_ENTER_UPGRADE_MODE);

	for( int index = 0; index < 3; index++ )
	{
		bCheckFlashOk = ERROR_CODE_OK == CheckFlashEraseOk();
		if( bCheckFlashOk ) break;
		SysDelay( 200 );
	}

	if( !bCheckFlashOk )
	{
		TestResultInfo( _T("Check Erase Falsh Failed\r\n") );
		return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( ERROR_CODE_CHECK_SUM_MISMATCH ) );
	}

	unsigned short booVerFromTp = 0;
	iReCode = iChip3536->GetBootVersion( &booVerFromTp );
	if( ERROR_CODE_OK != iReCode )  return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	TCHAR szBootVer[MAX_PATH] = {0};
	transformat( szBootVer, _T("Ver=0x%x"), booVerFromTp );

	BOOL bSameBoot = CheckTpBootSame();

	//wasim
	//bSameBoot = FALSE;

	if( bSameBoot )
	{
		TestResultInfo( _T("\r\nBoot from tp is same with Boot from setting\r\n") );
		TestResultInfo( szBootVer );
		TestResultInfo( "\r\n\r\n//BOOT Test is Pass\r\n", ITEM_STA_PASS );
		itemNotify.UpdateItemResult( ITEM_STA_PASS, szBootVer );
	}
	else
	{
		if( pCfg3536->boot_only_check )
		{
			TestResultInfo( _T("\r\nBoot from tp is differant from setting\r\n") );
			TestResultInfo( szBootVer );
			TestResultInfo( "\r\n\r\n//BOOT Test is Fail\r\n", ITEM_STA_FAIL );
			itemNotify.UpdateItemResult( ITEM_STA_FAIL, szBootVer );
		}
		else
		{
			TestResultInfo( _T("\r\nDownlad new boot bin...\r\n") );
			iReCode = iChip3536->BurnBootBin( pCfg3536->bootBinSize, pCfg3536->boot_svn, m_stOneRecord.Scap.oscTrim );
			if( iReCode == ERROR_CODE_OK )   
			{
				/*unsigned short */booVerFromTp = 0;
				iReCode = iChip3536->GetBootVersion( &booVerFromTp );
				if( ERROR_CODE_OK != iReCode )  return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
				TCHAR szBootVer[MAX_PATH] = {0};
				transformat( szBootVer, _T("NewVer=0x%x"), booVerFromTp );

				BOOL bSameBoot2 = CheckTpBootSame();
				if( bSameBoot2 )
				{
					TestResultInfo( "\r\n\r\n//BOOT Test is Pass\r\n", ITEM_STA_PASS );
					TestResultInfo( szBootVer );
					itemNotify.UpdateItemResult( ITEM_STA_PASS, szBootVer );
				}
				else
				{
					TestResultInfo( _T("\r\nBoot from tp is differant from setting\r\n") );
					TestResultInfo( szBootVer );
					TestResultInfo( "\r\n\r\n//BOOT Test is Fail\r\n", ITEM_STA_FAIL );
					itemNotify.UpdateItemResult( ITEM_STA_FAIL, szBootVer );
				}
			}
			else
			{
				TestResultInfo( _T("\r\nDownload boot exception\r\n") );
				TestResultInfo( szBootVer );
				TestResultInfo( "\r\n\r\n//BOOT Test is Fail\r\n", ITEM_STA_FAIL );
				itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
			}
		}
	}

	return itemNotify;
}
BOOL CTest3536::CheckConfigSame( const unsigned char* pCfg, unsigned short len )
{
	if( len != pCfg3536->cfgBinSize ) return FALSE;

	unsigned int iReCode = ERROR_CODE_OK;
	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);
	if( NULL == iChip3536 )   return FALSE;

	unsigned int check = caculate_check_sum_ex( pCfg, len );
	if( check != pCfg3536->config_check_sum )
	{
		return FALSE;
	}

	for( int index = 0; index < len; index++ ) 
	{
		if( pCfg[index] != pCfg3536->cfgBinBuffer[index] )
			return FALSE;
	}

	//unsigned char workSpaceCfg[MAX_CFG_BIN_SIZE] = {0};
	//iReCode = iChip3536->ReadBurnSpace( 0x8000, workSpaceCfg, len );
	//for( int index = 0; index < len; index++ ) 
	//{
	//	if( pCfg[index] != workSpaceCfg[index] )
	//		return FALSE;
	//}

	unsigned char backSpaceCfg[MAX_CFG_BIN_SIZE] = {0};
	iReCode = iChip3536->ReadBurnSpace( 0xf000, backSpaceCfg, len );

	for( int index = 0; index < len; index++ ) 
	{
		if( pCfg[index] != backSpaceCfg[index] )
			return FALSE;
	}

	return TRUE;
}
BOOL CTest3536::Ram_TestOk()
{
	BOOL bRamOk = FALSE;
	unsigned int iReCode = ERROR_CODE_OK;

	unsigned char regHead1[] = { 0x05 };
	iReCode = SM_ChipBase(m_deviceNo)->WriteCoreSpace( 0x602, regHead1, 1 );
	unsigned char regHead2[] = { 0x00 };
	iReCode = SM_ChipBase(m_deviceNo)->WriteCoreSpace( 0x643, regHead2, 1 );

	iReCode = SM_ChipBase(m_deviceNo)->WriteCoreSpace( 0x8000, (unsigned char*)ramTestCodeBin, sizeof(ramTestCodeBin) );

	unsigned char regHead3[] = { pCfg3536->I2cAddr };
	iReCode = SM_ChipBase(m_deviceNo)->WriteCoreSpace( 0x001, regHead3, 1 );

	unsigned char regHead4[] = { 0x88 };
	iReCode = SM_ChipBase(m_deviceNo)->WriteCoreSpace( 0x602, regHead4, 1 );
	SysDelay( 30 );

	for( int index = 0; index < 3; index++ )
	{
		unsigned int ramTestResult = 0;
		iReCode = SM_ChipBase(m_deviceNo)->ReadCoreSpace( 0x8000, (unsigned char*)&ramTestResult, 4 );
		if( (ramTestResult >> 24) == 0x54  )
		{
			if( 0 == (ramTestResult & 0x00ffffff) )
			{
				bRamOk = TRUE;
			}
			else
			{
				bRamOk = FALSE;
				TCHAR chTemp[MAX_PATH] = {0};
				transformat( chTemp, _T("WriteCoreSpace, Err = 0x%x\r\n"), ramTestResult );
				TestResultInfo( chTemp );
			}
			break;
		}
		else
		{
			SysDelay(50);
			TestResultInfo( _T("WriteCoreSpace LoopOnce...\r\n") );
			continue;
		}
	}

	return bRamOk;
}
unsigned int CTest3536::MakeTraceRecord()
{
	unsigned int iReCode = ERROR_CODE_OK;
#ifdef _MSC_VER
	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);
	char szBuffer[MAX_PATH] = {0};
	unsigned char record_buffer[3*1024] = {0};
	//auto record_buffer = new unsigned char[2*1024];
	Trace_Info* traceInfo = (Trace_Info*)record_buffer;
	One_Record* record = (One_Record*)(record_buffer + sizeof(Trace_Info));
	tstring userInfo = pCfg3536->szUserRecord ? tstring(pCfg3536->szUserRecord) : _T("");
	unsigned short crc = caculate_check_sum_ex( (unsigned char*)userInfo.c_str(), userInfo.length() + 1 ) >> 16;

	iReCode = iChip3536->ReadBurnSpace( 0xc000, record_buffer, sizeof(Trace_Info) );
	if(iReCode != ERROR_CODE_OK) return iReCode;
	
	BOOL bExitSameUserRecord = FALSE;
	if(traceInfo->trace_cnt + traceInfo->reverse == 0xff)
	{
		traceInfo->tlen =  traceInfo->tlen >= 0x800 ? 0x800 : traceInfo->tlen ;
		iReCode = iChip3536->ReadBurnSpace( 0xc000 + sizeof(Trace_Info), (unsigned char*)record, traceInfo->tlen );
		if(iReCode != ERROR_CODE_OK) return iReCode;

		for(int index = 0; index < traceInfo->trace_cnt; index++)
		{
			if(0 != caculate_check_sum_u16((unsigned short*)record, sizeof(One_Record))) break;

			unsigned char textOutCnt = 0;
			if(m_pNativeIntr->DebugMode())
			{
				textOutCnt++;
				transformat(szBuffer, _T("0x%010llX CRC = 0x%04x, %d-%d, %d:%d:%d	"), record->vid_pid, record->sz_crc, (record->time>>22)&0xf, (record->time>>17)&0x1f, 
					(record->time>>12)&0x1f, (record->time>>6)&0x3f, record->time&0x3f);
				TestResultInfo( szBuffer );
			}

			if((record->szlen > 0) && (record->szlen == align_2(lengthof((char*)(record + 1)) + 1)))
			{
				textOutCnt++;
				transformat(szBuffer, _T("%s"), (char*)(record + 1) );
				TestResultInfo(szBuffer);
			}

			if(textOutCnt > 0)
			{
				TestResultInfo( _T("\r\n") );
			}

			if(record->sz_crc == crc)
			{
				bExitSameUserRecord = TRUE;
			}

			record = (One_Record*)((unsigned char*)record + record->szlen + sizeof(One_Record));
		}
	}
	else if(0xff == traceInfo->trace_cnt && 0xff == traceInfo->reverse)
	{
		traceInfo->tlen = traceInfo->trace_cnt = 0;
	}
	else
	{
		//compatible to v5
		//delete[] record_buffer;
		return iReCode;
	}

	if(traceInfo->tlen + sizeof(Trace_Info) + sizeof(One_Record) + userInfo.length() + 1 > 0x800)
	{
		TestResultInfo(_T("\r\nTrace Info Exceed Max Buffer Count\r\n"));
	}
	else
	{
		SYSTEMTIME SysTime;
		::GetLocalTime(&SysTime);

		record->reserve = 0;
		record->record_crc = 0;
		record->vid_pid = pCfg3536->vid_pid;
		record->time = (SysTime.wMonth << 22) + (SysTime.wDay << 17) + (SysTime.wHour << 12) + (SysTime.wMinute << 6) + SysTime.wSecond;

		if(bExitSameUserRecord)
		{
			record->szlen = 0;
			record->sz_crc = crc;
		}
		else
		{
			record->szlen = align_2(userInfo.length() + 1);
			copytextto((TCHAR*)(record + 1), record->szlen, userInfo.c_str(), record->szlen);
			record->sz_crc = crc;
		}
		record->record_crc = 1 + (~caculate_check_sum_u16((unsigned short*)record, sizeof(One_Record)));

		traceInfo->trace_cnt++;
		traceInfo->reverse = ~traceInfo->trace_cnt;
		traceInfo->tlen += record->szlen + sizeof(One_Record);

		iReCode = iChip3536->WriteBurnSpace(0xc000, record_buffer, traceInfo->tlen + sizeof(Trace_Info), OTP_W_CHK | TLK_DATACHK_EX1);
		SysDelay(10);

		transformat(szBuffer, _T("0x%010llX CRC = 0x%04x, %d-%d, %d:%d:%d	"), record->vid_pid, record->sz_crc, (record->time>>22)&0xf, (record->time>>17)&0x1f, 
			(record->time>>12)&0x1f, (record->time>>6)&0x3f, record->time&0x3f);
		TestResultInfo(szBuffer);

		if(record->szlen > 0)
		{
			transformat(szBuffer, _T("%s"), (char*)(record + 1) );
			TestResultInfo(szBuffer);
		}

		TestResultInfo( _T("\r\n") );
	}
	//delete[] record_buffer;
#endif

	return iReCode;
}

unsigned int CTest3536:: ProblemJudgment(unsigned int addr, unsigned short plattenone,  unsigned short plattentwo)
{
	unsigned int iReCode = ERROR_CODE_OK;
	unsigned short pValue = 0;
	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);
	iReCode = iChip3536->ReadBurnSpace( addr, (unsigned char*)&pValue, 2 );
	if(iReCode != ERROR_CODE_OK) return iReCode;

	if((pValue == plattenone) || (pValue == plattentwo))
	{
		iReCode = ERROR_CODE_COMM_ERROR;
	}

	return iReCode;
}

unsigned int CTest3536::ProjectCode_Test( NativeTestItem& itemQuote )
{
	unsigned int iReCode = ERROR_CODE_OK;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );

	TestResultInfo( _T("\r\n------------------------------Project Test------------------------------\r\n") );

	if(ProblemJudgment(0xc000,0x5aa5,0xa55a)!=ERROR_CODE_OK)
	{
		iReCode = SM_ChipBase(m_deviceNo)->EraseBurnSpace(0xc000,4096);//在ProjectCode_Test测试前先擦除0xc000长度为4k的内容，在进行ICID的写入，解决残留5aa5的问题
		if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	}

	MakeTraceRecord();

	if( !Ram_TestOk() )
	{
		return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( ERROR_CODE_CHECK_SUM_MISMATCH ) );
	}

	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand( CMD_CTP_RST );
	if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	SysDelay( 5 );

	unsigned short cfgBuffer[MAX_CFG_BIN_SIZE] = {0};
	iReCode = SM_ChipBase(m_deviceNo)->ReadCoreSpace( 0x9E00, (unsigned char*)cfgBuffer, 204 );
	if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	TCHAR chTemp[MAX_PATH] = {0};
	unsigned short s = cfgBuffer[1] >> 10;
	unsigned short p = (((cfgBuffer[1] >> 4) & 0x03) << 9) | (cfgBuffer[0] & 0x1ff);
	unsigned short v = (((cfgBuffer[1] >> 6) & 0x03) << 7) | (cfgBuffer[0] >> 9);
	transformat( chTemp, _T("SoftWare Ver = %d, ProjectCode = %d, VenderID = %d\r\n"), s, p, v );
	TestResultInfo( chTemp );

	transformat( chTemp, _T("S=%d, P=%d, V=%d"), s, p, v );
		
	if( pCfg3536->sVersion == s && pCfg3536->pVersion == p && pCfg3536->vVersion == v )
	{
		TestResultInfo( "\r\n\r\n//Project Test is Pass\r\n", ITEM_STA_PASS );
		itemNotify.UpdateItemResult( ITEM_STA_PASS, chTemp );
	}
	else
	{
		TestResultInfo( "\r\n\r\n//Project Test is Fail\r\n", ITEM_STA_FAIL );
		itemNotify.UpdateItemResult( ITEM_STA_FAIL, chTemp );
	}

	return itemNotify;
}
unsigned int CTest3536::Config_Test( NativeTestItem& itemQuote )
{
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );

	TestResultInfo( _T("\r\n------------------------------CONFIG Test------------------------------\r\n") );

	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);
	if( NULL == iChip3536 )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	unsigned short cfgVerFromTp = 0;
	unsigned char configBuffer[MAX_CFG_BIN_SIZE] = {0};
	iReCode = iChip3536->GetFirmWareConfig( configBuffer, pCfg3536->cfgBinSize );
	if( ERROR_CODE_OK != iReCode )  return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	cfgVerFromTp = configBuffer[3] >> 2;
	TCHAR szConfigVer[MAX_PATH] = {0};
	transformat( szConfigVer, _T("Ver=0x%x"), cfgVerFromTp );

	BOOL bSameConfig = CheckConfigSame( configBuffer, pCfg3536->cfgBinSize );

	//wasim
	//bSameConfig = FALSE;

	if( bSameConfig )
	{
		TestResultInfo( _T("\r\nConfig from tp is same with Config from setting\r\n") );
		TestResultInfo( szConfigVer );
		TestResultInfo( "\r\n\r\n//Config Test is Pass\r\n", ITEM_STA_PASS );
		itemNotify.UpdateItemResult( ITEM_STA_PASS, szConfigVer );
	}
	else
	{
		if( pCfg3536->config_only_check )
		{
			TestResultInfo( _T("\r\nConfig from tp is differant from setting\r\n") );
			TestResultInfo( szConfigVer );
			TestResultInfo( "\r\n\r\n//Config Test is Fail\r\n", ITEM_STA_FAIL );
			itemNotify.UpdateItemResult( ITEM_STA_FAIL, szConfigVer );
		}
		else
		{
			TestResultInfo( _T("\r\nDownlad new config bin...\r\n") );
			iReCode = iChip3536->BurnConfigBin( pCfg3536->cfgBinBuffer, pCfg3536->cfgBinSize );
			if( iReCode == ERROR_CODE_OK )   
			{
				memset( configBuffer, 0, sizeof(configBuffer) );
				iChip3536->GetFirmWareConfig( configBuffer, pCfg3536->cfgBinSize );
				BOOL bSameConfig2 = CheckConfigSame( configBuffer, pCfg3536->cfgBinSize );

				cfgVerFromTp = configBuffer[3] >> 2;
				TCHAR szConfigVer[MAX_PATH] = {0};
				transformat( szConfigVer, _T("NewVer=0x%x"), cfgVerFromTp );

				if( bSameConfig2 )
				{
					TestResultInfo( "\r\n\r\n//Config Test is Pass\r\n", ITEM_STA_PASS );
					TestResultInfo( szConfigVer );
					itemNotify.UpdateItemResult( ITEM_STA_PASS, szConfigVer );
				}
				else
				{
					TestResultInfo( _T("\r\nConfig from tp is differant from setting\r\n") );
					TestResultInfo( szConfigVer );
					TestResultInfo( "\r\n\r\n//Config Test is Fail\r\n", ITEM_STA_FAIL );
					itemNotify.UpdateItemResult( ITEM_STA_FAIL, szConfigVer );
				}
			}
			else
			{
				TestResultInfo( _T("\r\nDownload config exception\r\n") );
				TestResultInfo( szConfigVer );
				TestResultInfo( "\r\n\r\n//Config Test is Fail\r\n", ITEM_STA_FAIL );
				itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
			}
		}
	}

	return itemNotify;
}
unsigned int CTest3536::OSCTrim_Test( NativeTestItem& itemQuote )
{
	unsigned int iReCode = ERROR_CODE_OK, failerCnt=0;
	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );

	TestResultInfo( _T("\r\n------------------------------OSC Trim Test------------------------------\r\n") );

	unsigned short osTrim1 = 0, osTrim2 = 0, oscTrimNew = 0;
	unsigned char readBuffer[16] = {0};
	char szBuffer[MAX_PATH] = {0};

	if(ProblemJudgment(0xe000,0x5aa5,0xa55a)!=ERROR_CODE_OK)
	{
		iReCode = SM_ChipBase(m_deviceNo)->EraseBurnSpace( 0xe000, 4096);   //有项目测试残留5aa5导致校准这里有问题，现在该项目校准前擦除4k在校准
		if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	}

	iReCode = SM_ChipBase(m_deviceNo)->ReadBurnSpace( 0xe000, readBuffer, sizeof(readBuffer) );
	if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	if(readBuffer[0]==0xa5 && readBuffer[1]==0x5a && readBuffer[2]==0xa5)
	{
		memset(readBuffer,0x00,16);
	}
	if( (0xff != (readBuffer[0] + readBuffer[1])) || (readBuffer[0] < pCfg3536->osctrim_min) || (readBuffer[0] > pCfg3536->osctrim_max) || pCfg3536->must_test)
	{
		TestResultInfo( _T("Start Trim And Refresh Trim Value\r\n") );

		SysDelay( 10 );
		iReCode = iChip3536->GetOSCTrim( &osTrim1, pCfg3536->tick_standard );
		if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

		iReCode = iChip3536->GetOSCTrim( &osTrim2, pCfg3536->tick_standard );
		if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

		if((osTrim1 - osTrim2) * (osTrim1 - osTrim2) > 49)
		{
			TestResultInfo( _T("OSTrim Value Out Of Range\r\n") );
			return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( ERROR_CODE_INVALID_PARAM ) );
		}

		oscTrimNew = (osTrim1 + osTrim2) >> 1;
		m_stOneRecord.Scap.oscTrim = oscTrimNew;

		//unsigned short osc =  ( ~oscTrimNew ) & 0xff;
		//osc = ( osc << 8 ) + oscTrimNew;	

		readBuffer[0] = oscTrimNew & 0xff;
		readBuffer[1] = ~readBuffer[0];

		//Gen ICID
		unsigned int* pIntData = (unsigned int*)&readBuffer[8];
		unsigned short* pShortData = (unsigned short*)&readBuffer[8];
		if(0xffff != (pShortData[2] + pShortData[3]))
		{
			SYSTEMTIME SysTime;
			::GetLocalTime(&SysTime);
			pIntData[0] = (SysTime.wMonth << 22) + (SysTime.wDay << 17) + (SysTime.wHour << 12) + (SysTime.wMinute << 6) + SysTime.wSecond;

			std::srand((pIntData[0]+SysTime.wMilliseconds));
			::GetLocalTime(&SysTime);
			pShortData[2] = (((rand()&0xffff) + ((SysTime.wMilliseconds % 1000)<<3))&0xfff8) + m_deviceNo;
			pShortData[3] = ~pShortData[2];
		}

		iReCode = SM_ChipBase(m_deviceNo)->WriteBurnSpace( 0xe000, readBuffer, sizeof(readBuffer), OTP_W_CHK | TLK_DATACHK_EX1 );
		if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

		SysDelay( 10 );
		iReCode = SM_ChipBase(m_deviceNo)->ReadBurnSpace( 0xe000, readBuffer, sizeof(readBuffer) );
		if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	}

	m_stOneRecord.ReleaseID = *(UINT64*)(readBuffer + 8);

	//compatible to v5
	if(0xffffffffffffffff == m_stOneRecord.ReleaseID)
	{
		iReCode = iChip3536->ReadBurnSpace( 0xc000, (unsigned char*)&m_stOneRecord.ReleaseID, sizeof(m_stOneRecord.ReleaseID) );
		if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	}

	UINT32 otm_time = *(UINT32*)&m_stOneRecord.ReleaseID;
	transformat( szBuffer, _T("ICID = 0x%llx,   %d-%d, %d:%d:%d\r\n"), m_stOneRecord.ReleaseID, (otm_time>>22)&0xf, (otm_time>>17)&0x1f,(otm_time>>12)&0x1f, (otm_time>>6)&0x3f, otm_time&0x3f );
	TestResultInfo( szBuffer );

	transformat( szBuffer, _T("OSCTrim = 0x%02x"), readBuffer[0] );
	TestResultInfo( szBuffer );

	int fo_trim =0;
	int offset = (unsigned int)(pCfg3536->tick_standard * (float)pCfg3536->offset_tick /1000);

	iReCode = iChip3536->GetTrimeDosc(fo_trim);
	if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	int err = fo_trim - pCfg3536->tick_standard;

	TestResultInfoR( _T("\r\nTicks = %d, Actual offset(%d), offset(%d), proportion(%d/1000)\r\n"),fo_trim, abs(err), offset, pCfg3536->offset_tick);

	if (abs(err) > offset)
	{
		failerCnt++;
		TestResultInfoR(_T("Err TrimeDosc!"));
	}


	if( readBuffer[0] >= pCfg3536->osctrim_min && readBuffer[0] <= pCfg3536->osctrim_max && 0==failerCnt)
	{
		TestResultInfo( "\r\n\r\n//OSCTrim Test is Pass\r\n", ITEM_STA_PASS );
		itemNotify.UpdateItemResult( ITEM_STA_PASS, szBuffer );
	}
	else
	{
		TestResultInfo( "\r\n\r\n//OSCTrim Test is Fail\r\n", ITEM_STA_FAIL );
		itemNotify.UpdateItemResult( ITEM_STA_FAIL, szBuffer );
	}

	return itemNotify;
}
unsigned int CTest3536::Current_Test( NativeTestItem& itemQuote )
{
	TEST_ITEM_STATUS itemStatus = ITEM_STA_NONE;
	for( int index = 0; index < 3; index++ )
	{
		itemStatus = (TEST_ITEM_STATUS)Current_TestEx( itemQuote, index );
		if( itemStatus == ITEM_STA_PASS ) break;
	}
	return itemStatus;
}
unsigned int CTest3536::Current_TestEx( NativeTestItem& itemQuote, unsigned char times )
{
	int failedCount = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );

	TestResultInfo( _T("\r\n------------------------------Current Test------------------------------\r\n") );

	times = (0 == times) ? 1 : 0;
	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);
	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	//new SEMI.Util.SMDefinition(0x80, "sleep"),
    //new SEMI.Util.SMDefinition(0x40, "stop"),
	//new SEMI.Util.SMDefinition(0x00, "active"),

	short deltaCurrent = 0;
	short workCurrent = 0, sleepCurrent = 0, activeCurrent = 0, emptyCurrent = 0;
	short level1[2][2] = {
		(short)(-30 * times), (short)(0 * times),
		(short)(50 * times), (short)(pCfg3536->sleep_current_max * times),
	};
	iReCode = iChip3536->GetCurrent( 0x80, level1, (unsigned short*)&workCurrent, (unsigned short*)&sleepCurrent );
	if( iReCode != ERROR_CODE_OK )
	{
		failedCount++;
	}

	short level2[2][2] = {
		(short)(pCfg3536->active_current_min * times), 0,
		(short)(pCfg3536->active_current_max * times), 0,
	};
	iReCode = iChip3536->GetCurrent( 0x00, level2, (unsigned short*)&activeCurrent, (unsigned short*)&emptyCurrent );
	if( iReCode != ERROR_CODE_OK )
	{
		failedCount++;
	}

	//iReCode = iChip3536->IncokeCommand( CMD_CTP_RST );
	//SysDelay( 50 );

	deltaCurrent = workCurrent - sleepCurrent;

	TCHAR szTmep[MAX_PATH] = {0};

	{
		m_stOneRecord.current_mode1 = workCurrent;
		m_stOneRecord.current_mode2 = sleepCurrent;
		m_stOneRecord.current_mode3 = activeCurrent;
		m_stOneRecord.current_delta = deltaCurrent;
		transformat( szTmep, _T("\r\nmode1 = %d, mode2 = %d, mode3 = %d, delta = %d\r\n"), workCurrent, sleepCurrent, activeCurrent, deltaCurrent );
		TestResultInfo( szTmep );
	}
	if( workCurrent < pCfg3536->work_current_min )
	{
		failedCount++;
		transformat( szTmep, _T( "\r\nmode1(%d) < setting min(%d)\r\n"), workCurrent, pCfg3536->work_current_min );
		TestResultInfo( szTmep );
	}
	if( workCurrent > pCfg3536->work_current_max )
	{
		failedCount++;
		transformat( szTmep, _T( "\r\nmode1(%d) > setting max(%d)\r\n"), workCurrent, pCfg3536->work_current_max );
		TestResultInfo( szTmep );
	}
	if( sleepCurrent < pCfg3536->sleep_current_min )
	{
		failedCount++;
		transformat( szTmep, _T( "\r\nmode2(%d) < setting min(%d)\r\n"), sleepCurrent, pCfg3536->sleep_current_min );
		TestResultInfo( szTmep );
	}
	if( sleepCurrent > pCfg3536->sleep_current_max )
	{
		failedCount++;
		transformat( szTmep, _T( "\r\nmode2(%d) > setting max(%d)\r\n"), sleepCurrent, pCfg3536->sleep_current_max );
		TestResultInfo( szTmep );
	}
	if( deltaCurrent < pCfg3536->delta_current_min )
	{
		failedCount++;
		transformat( szTmep, _T( "\r\ndelta(%d) < setting min(%d)\r\n"), deltaCurrent, pCfg3536->delta_current_min );
		TestResultInfo( szTmep );
	}
	if( deltaCurrent > pCfg3536->delta_current_max )
	{
		failedCount++;
		transformat( szTmep, _T( "\r\ndelta(%d) > setting max(%d)\r\n"), deltaCurrent, pCfg3536->delta_current_max );
		TestResultInfo( szTmep );
	}
	if( activeCurrent < pCfg3536->active_current_min )
	{
		failedCount++;
		transformat( szTmep, _T( "\r\nmode3(%d) < setting min(%d)\r\n"), activeCurrent, pCfg3536->active_current_min );
		TestResultInfo( szTmep );
	}
	if( activeCurrent > pCfg3536->active_current_max )
	{
		failedCount++;
		transformat( szTmep, _T( "\r\nmode3(%d) > setting max(%d)\r\n"), activeCurrent, pCfg3536->active_current_max );
		TestResultInfo( szTmep );
	}

	if( failedCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//Current Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//Current Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}
unsigned int CTest3536::RawData_Test( NativeTestItem& itemQuote )
{
	int failerCount = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );
	signed short rawdataTempBuffer[100] = {0};
	unsigned short rawdataMatrix[MAX_SCAP_ROW][MAX_SCAP_COL];

	TestResultInfo( _T("\r\n------------------------------RawData Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);

	int addRow = ( pCfg3536->real_channel_num - pCfg3536->va_channel_num ) ? 1 : 0;

	//iReCode = iChip3536->IncokeCommand( CMD_CTP_RST );
	//SysDelay( 20 );

	iReCode = iChip3536->SwitchMode( pCfg3536->sync_type, pCfg3536->sync_length );
	if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	SysDelay( 50 );

	for( int index = 0; index < 2; index++ )
	{
		iReCode = iChip3536->GetRawData( rawdataTempBuffer, pCfg3536->sync_length/*(pCfg3536->rowsCnt + 1) * pCfg3536->colsCnt * 2*/ );
		//if( iReCode == ERROR_CODE_OK ) break;
		if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	}
	
	int ref_channel_num = min(pCfg3536->real_channel_num - pCfg3536->va_channel_num, pCfg3536->colsCnt);
	AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt, ref_channel_num, true );
	ReShappingData( rawdataMatrix, (unsigned short*)rawdataTempBuffer, G_XMLConfig->real_channel_num, pCfg3536->rowsCnt + 1, pCfg3536->colsCnt );
	//short rawdataMin[MAX_SCAP_ROW][MAX_SCAP_COL] = {0}, rawdataMax[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	//FillMatrixUseValue( rawdataMin, pCfg3536->rawdata_min );
	//FillMatrixUseValue( rawdataMax, pCfg3536->rawdata_max );

	NodeVal nodeOutRange;
	ColorText textTemp( _T("\r\nScapData:\r\n") );
	bool bResult = AnalyzeTestResult( rawdataMatrix, pCfg3536->rawdata_min, pCfg3536->rawdata_max, pCfg3536->invalid_node, info, textTemp, nodeOutRange );
	TestResultInfo( textTemp );
	if( !bResult )
	{
		failerCount++;
		LPCTSTR strHead = _T("\r\n//========= Out of Threshold in BaseTest: \r\n");
		PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
	}

	if( !failerCount )
	{
		BOOL bAllInvalid = TRUE;
		for( int iRow = 0; iRow < pCfg3536->rowsCnt; iRow++ )
		{
			for( int iCol = 0; iCol < pCfg3536->colsCnt; iCol++ )
			{
				if( 4096 != rawdataMatrix[iRow][iCol] )
					bAllInvalid = FALSE;
				if( 2048 != rawdataMatrix[iRow][iCol] )
					bAllInvalid = FALSE;
			}
		}
		if( bAllInvalid ) 
		{
			TestResultInfo( _T("\r\nRawData Is Invalid\r\n") );
			failerCount++;
		}
	}

	if( failerCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//RawData Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//RawData Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}
unsigned int CTest3536::Noise_Test( NativeTestItem& itemQuote )
{
	int failerCount = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );
	signed short noiseTempBuffer[100] = {0}, noiseMaxBuffer[100] = {0};
	signed short rawdataTempBuffer[5][100] = {0}, rawdataBaseBuffer[100] = {0};
	unsigned short noiseMatrix[MAX_SCAP_ROW][MAX_SCAP_COL];

	TestResultInfo( _T("\r\n------------------------------Noise Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);

	int addRow = ( pCfg3536->real_channel_num - pCfg3536->va_channel_num ) ? 1 : 0;

	iReCode = iChip3536->IncokeCommand( CMD_CTP_RST );
	SysDelay( 20 );

	iReCode = iChip3536->SwitchMode( MODE_RAWDATA, pCfg3536->sync_length );
	if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	for( int index = 0; index < 5; index++ )
	{
		iReCode = iChip3536->GetRawData( rawdataTempBuffer[index], pCfg3536->sync_length );
		if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
		SysDelay(10);
	}

	for(int iCnt = 0; iCnt < (pCfg3536->rowsCnt + 1) * pCfg3536->colsCnt; iCnt++ )
	{
		int sum = 0;
		for(int index = 0; index < 5; index++)
		{
			sum += rawdataTempBuffer[index][iCnt];
		}

		rawdataBaseBuffer[iCnt] = sum/5;
	}



	for( int index = 0; index < pCfg3536->noise_frame; index++ )
	{
		iReCode = iChip3536->GetRawData( noiseTempBuffer, pCfg3536->sync_length );
		if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

		for( int iCnt = 0; iCnt < (pCfg3536->rowsCnt + 1) * pCfg3536->colsCnt; iCnt++ )
		{
			noiseTempBuffer[iCnt] = noiseTempBuffer[iCnt] - rawdataBaseBuffer[iCnt];
			noiseMaxBuffer[iCnt] = max( noiseMaxBuffer[iCnt], abs(noiseTempBuffer[iCnt]) );
		}

		/*for( int iCnt = 0; iCnt < (pCfg3536->rowsCnt + 1) * pCfg3536->colsCnt; iCnt++ )
		noiseMaxBuffer[iCnt] = max( noiseMaxBuffer[iCnt], abs(noiseTempBuffer[iCnt]) );*/

		SysDelay(5);
	}

	int ref_channel_num = min(pCfg3536->real_channel_num - pCfg3536->va_channel_num, pCfg3536->colsCnt);
	AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt, ref_channel_num, true );
	ReShappingData( noiseMatrix, (unsigned short*)noiseMaxBuffer, G_XMLConfig->real_channel_num * 2, pCfg3536->rowsCnt + 1, pCfg3536->colsCnt );
	short noiseMin[MAX_SCAP_ROW][MAX_SCAP_COL] = {0}, noiseMax[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	FillMatrixUseValue( noiseMin, (signed short)0 );
	FillMatrixUseValue( noiseMax, pCfg3536->noise_max );

	NodeVal nodeOutRange;
	ColorText textTemp( _T("\r\nNoise Data:\r\n") );
	bool bResult = AnalyzeTestResult( noiseMatrix, noiseMin, noiseMax, pCfg3536->invalid_node, info, textTemp, nodeOutRange );
	TestResultInfo( textTemp );
	if( !bResult )
	{
		failerCount++;
		LPCTSTR strHead = _T("\r\n//========= Out of Threshold in NoiseTest: \r\n");
		PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
	}

	if( failerCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//Noise Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//Noise Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}
unsigned int CTest3536::IOVoltage_Test( NativeTestItem& itemQuote )
{
	int failerCnt = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );
	TCHAR szTemp[MAX_PATH] = {0};

	TestResultInfo( _T("\r\n------------------------------IOVoltage Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);

	unsigned int ioVols[2][8] = {0};
	iReCode = iChip3536->GetIoVoltage( ioVols );
	if( iReCode != ERROR_CODE_OK ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	transformat( szTemp, _T("pin = low,  int vol = %-6d,	sda vol = %-6d,	scl vol = %-6d\r\n"), ioVols[0][2], ioVols[0][0], ioVols[0][1] );
	TestResultInfo( szTemp );
	transformat( szTemp, _T("pin = high, int vol = %-6d,	sda vol = %-6d,	scl vol = %-6d\r\n"), ioVols[1][2], ioVols[1][0], ioVols[1][1] );
	TestResultInfo( szTemp );

	if( ioVols[0][2] < pCfg3536->int_low_min || ioVols[0][2] > pCfg3536->int_low_max )//if( ioVols[0][2] > pCfg3536->int_low )
	{
		failerCnt++;
		transformat( szTemp, _T("int vol = %d, th = [%d - %d]\r\n"), ioVols[0][2], pCfg3536->int_low_min, pCfg3536->int_low_max  );
		TestResultInfo( szTemp );
	}
	if( ioVols[1][2] < pCfg3536->int_high_min || ioVols[1][2] > pCfg3536->int_high_max )//if( ioVols[1][2] < pCfg3536->int_high )
	{
		failerCnt++;
		transformat( szTemp, _T("int vol = %d, th = [%d - %d]\r\n"), ioVols[1][2], pCfg3536->int_high_min, pCfg3536->int_high_max );
		TestResultInfo( szTemp );
	}

	if( ioVols[0][0] < pCfg3536->iic_low_min || ioVols[0][0] > pCfg3536->iic_low_max  )//if( ioVols[0][0] > pCfg3536->iic_low )
	{
		failerCnt++;
		transformat( szTemp, _T("sda vol = %d, th = [%d - %d]\r\n"), ioVols[0][0], pCfg3536->iic_low_min, pCfg3536->iic_low_max );
		TestResultInfo( szTemp );
	}
	if( ioVols[1][0] < pCfg3536->iic_high_min || ioVols[1][0] > pCfg3536->iic_high_max )//if( ioVols[1][0] < pCfg3536->iic_high )
	{
		failerCnt++;
		transformat( szTemp, _T("sda vol = %d, th = [%d - %d]\r\n"), ioVols[1][0], pCfg3536->iic_high_min, pCfg3536->iic_high_max );
		TestResultInfo( szTemp );
	}

	if( ioVols[0][1] < pCfg3536->iic_low_min || ioVols[0][1] > pCfg3536->iic_low_max )//if( ioVols[0][1] > pCfg3536->iic_low )
	{
		failerCnt++;
		transformat( szTemp, _T("scl vol = %d, th = [%d - %d]\r\n"), ioVols[0][1], pCfg3536->iic_low_min, pCfg3536->iic_low_max  );
		TestResultInfo( szTemp );
	}
	if(ioVols[1][1] < pCfg3536->iic_high_min || ioVols[1][1] > pCfg3536->iic_high_max )//if( ioVols[1][1] < pCfg3536->iic_high )
	{
		failerCnt++;
		transformat( szTemp, _T("scl vol = %d, th = [%d - %d]\r\n"), ioVols[1][1], pCfg3536->iic_high_min, pCfg3536->iic_high_max  );
		TestResultInfo( szTemp );
	}

	if( failerCnt )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//IOVoltage Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//IOVoltage Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}
unsigned int CTest3536::Vp_Test( NativeTestItem& itemQuote )
{
	int failerCount = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );
	unsigned short baseTempBuffer[100] = {0}, baseCopyBuffer[100] = {0};
	unsigned short baseMatrix[MAX_SCAP_ROW][MAX_SCAP_COL];

	TestResultInfo( _T("\r\n------------------------------VP Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);

	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand( CMD_CTP_RST );
	if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	SysDelay( 100 );

	for( int index = 0; index < 2; index++ )
	{
		iReCode = iChip3536->SwitchMode( pCfg3536->sync_type, pCfg3536->sync_length );
		if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

		iReCode = iChip3536->GetRawData( (signed short*)baseCopyBuffer, pCfg3536->sync_length );
		if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	}

	//extern triger
	//SM_CommBase(m_deviceNo)->SetMtkExternOutput( TEST_GOING, 0, 0, 0 );

	for(int retry = 0; retry < (int)(pCfg3536->vp_out_time*3); retry++)
	{
		TCHAR szTimer[MAX_PATH];
		transformat(szTimer, _T("Timer: %d S"), (int)(((pCfg3536->vp_out_time*3) - retry) / 3));

		if(retry % 2)
			itemNotify.UpdateItemResult( ITEM_STA_PRESS, szTimer);
		else
			itemNotify.UpdateItemResult( ITEM_STA_NONE, szTimer);

		iReCode = iChip3536->SwitchMode( pCfg3536->sync_type, pCfg3536->sync_length );
		if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

		iReCode = iChip3536->GetRawData( (signed short*)baseTempBuffer, pCfg3536->sync_length );
		if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

		BOOL bTouchLikely = TRUE;
		for(int index = 0; index < pCfg3536->rowsCnt * pCfg3536->colsCnt; index++)
		{
			int delta = (int)baseTempBuffer[index] - (int)baseCopyBuffer[index];
			//if(delta < -1000) delta += (1 << 14);
			if(abs(delta) < (int)pCfg3536->vp_trigger)
			{ 
				bTouchLikely = FALSE; 
				SysDelay(300); 
				break;
			}
		}

		if(bTouchLikely)
		{
			SysDelay(100); 
			iReCode = iChip3536->SwitchMode( pCfg3536->sync_type, pCfg3536->sync_length );
			if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
			SysDelay(10); 
			iReCode = iChip3536->GetRawData( (signed short*)baseTempBuffer, pCfg3536->sync_length );
			if( ERROR_CODE_OK != iReCode ) return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
			
			break;
		}
	}

	for(int index = 0; index < pCfg3536->rowsCnt * pCfg3536->colsCnt * 2; index++)
	{
		baseTempBuffer[index] = abs((int)(unsigned short)baseTempBuffer[index] - (int)(unsigned short)baseCopyBuffer[index]);
		//if(baseTempBuffer[index] < -1000) baseTempBuffer[index] += (1 << 14);
	}

	int ref_channel_num = min(pCfg3536->real_channel_num - pCfg3536->va_channel_num, pCfg3536->colsCnt);
	AnalyzeInfo info( pCfg3536->rowsCnt, pCfg3536->colsCnt, ref_channel_num, true );
	ReShappingData( baseMatrix, baseTempBuffer, G_XMLConfig->real_channel_num, pCfg3536->rowsCnt + 1, pCfg3536->colsCnt );
	unsigned short baseMin[MAX_SCAP_ROW][MAX_SCAP_COL] = {0},  baseMax[MAX_SCAP_ROW][MAX_SCAP_COL] = {0};
	FillMatrixUseValue( baseMin, (unsigned short)pCfg3536->vp_min );
	FillMatrixUseValue( baseMax, (unsigned short)65535 );

	NodeVal nodeOutRange;
	ColorText textTemp( _T("\r\nBase Data:\r\n") );
	bool bResult = AnalyzeTestResult( baseMatrix, baseMin, baseMax, pCfg3536->invalid_node, info, textTemp, nodeOutRange );
	TestResultInfo( textTemp );
	if( !bResult )
	{
		failerCount++;
		LPCTSTR strHead = _T("\r\n//========= Out of Threshold in BaseTest: \r\n");
		PrintNodeValue( m_ColorText, &nodeOutRange, strHead );
	}

	if( failerCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//VP Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//VP Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}
void CTest3536::PrepareSimulate( SimulateData& sm )
{
	unsigned char cmdID = sm.itemID & 0xff;
	unsigned char dataIndex = (sm.itemID >> 8) & 0xff;
	unsigned char sumCnt = 1;

	if( CMD_OPEN_TST == cmdID )
	{
		sm.itemArray[48] = 0x6306;
		sm.itemArray[50] = 0x5555;
		unsigned short exeParam = pCfg3536->integral;
		exeParam = (exeParam << 8) + pCfg3536->scale_a;
		exeParam = (exeParam << 8) + pCfg3536->scale_b;
		sm.itemID |= (exeParam << 16);
	}
	else if( CMD_FSD_TST == cmdID )
	{
		if(pCfg3536->fsd.fsdT.fsd_selected)
		{
			sumCnt = 1;
			sm.itemArray[48] = 0x6306;
			sm.itemArray[49] = 0x5555;
			dataIndex ? (sm.itemID |= pCfg3536->fsd.fsdT.s_clk << 16) : (sm.itemID |= pCfg3536->fsd.fsdT.f_clk << 16);
		}
		else
		{
			sumCnt = 1;
			sm.itemArray[48] = 0x6306;
			sm.itemArray[49] = 0x5555;
			dataIndex ? (sm.itemID |= pCfg3536->fsd.fsdB.s_clk << 16) : (sm.itemID |= pCfg3536->fsd.fsdB.f_clk << 16);
		}
	}

	for( int iRow = 0; iRow < sm.rows; iRow++ )
	{
		for( int iCol = 0; iCol < sm.cols; iCol++ )
		{
			int index = iRow * sm.cols + iCol;
			if( index >= pCfg3536->real_channel_num ) break;

			int icPosition = pCfg3536->sensor_2_ic_map[index];
			sm.itemArray[icPosition] = sm.itemData[iRow][iCol] * sumCnt;
		}
	}
}

unsigned int CTest3536::Algorithm_Test(NativeTestItem& itemQuote)
{
	int failerCount = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );

	unsigned short readBuff[16] = {0};
	unsigned short checkBuff[16] = {0x32,0x63,0xC4,0xEA,0x112,0x141,0x172,0x1A4,0x0A,0x3B,0x6E,0x8D, 0xB7, 0xE7,0x118,0x14A};

	TestResultInfo( _T("\r\n------------------------------Algorithm Test------------------------------\r\n") );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);

	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand( CMD_CTP_RST );
	if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	unsigned char regHead1[] = { 0x05 };
	iReCode = SM_ChipBase(m_deviceNo)->WriteCoreSpace( 0x602, regHead1, 1 );
	unsigned char regHead2[] = { 0x00 };
	iReCode = SM_ChipBase(m_deviceNo)->WriteCoreSpace( 0x643, regHead2, 1 );

	iReCode = SM_ChipBase(m_deviceNo)->WriteCoreSpace( 0x8000, (unsigned char*)ramAlgorithmTestCodeBin, sizeof(ramAlgorithmTestCodeBin) );

	unsigned char regHead3[] = { pCfg3536->I2cAddr };
	iReCode = SM_ChipBase(m_deviceNo)->WriteCoreSpace( 0x001, regHead3, 1 );

	unsigned char regHead4[] = { 0x88 };
	iReCode = SM_ChipBase(m_deviceNo)->WriteCoreSpace( 0x602, regHead4, 1 );
	SysDelay( 200 );

	auto check = [&]()->bool{

		for ( int i = 0; i<5; i++)
		{
			unsigned int ramTestResult = 0;
			iReCode = SM_ChipBase(m_deviceNo)->ReadCoreSpace( 0x9600, (unsigned char*)&ramTestResult, 4 );
			if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
			if( (ramTestResult >> 24) == 0x54  )
			{
				if( 0 == (ramTestResult & 0x00ffffff) )
				{
					return true;
				}
				else
				{
					TestResultInfoR(  _T("ReadCoreSpace, Err = 0x%x\r\n"), ramTestResult );
					failerCount++;
				}
				return false;;
			}
			else
			{
				SysDelay(50);
				TestResultInfoR( _T("ReadCoreSpace LoopOnce...\r\n") );
				continue;
			}
		}

		failerCount++;
		return false;

	};

	if (check() == true)
	{
		iReCode = SM_ChipBase(m_deviceNo)->ReadCoreSpace( 0x9480, (unsigned char*)readBuff, 32 );
		if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
		for (int i = 0; i<16;i++)
		{
			if(readBuff[i] != checkBuff[i])
			{
				failerCount++;
				TestResultInfoR(  _T("ReadBuff[%d](0x%x) != CheckBuff[%d](0x%x)\r\n"), i, readBuff[i], i, checkBuff[i]);
				break;
			}
		}

	}
	else
	{
		failerCount++;
	}

	if( failerCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//Algorithm Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//Algorithm Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}

unsigned int CTest3536::MISC_Test(NativeTestItem& itemQuote)
{
	int failerCount = 0;
	unsigned int iReCode = ERROR_CODE_COMM_ERROR;
	ItemNotifyer itemNotify( m_pNativeIntr, itemQuote );

	if( NULL == SM_ChipBase(m_deviceNo) )   return itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );
	ISMChip3536* iChip3536 = (ISMChip3536*)SM_ChipBase(m_deviceNo);

	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand( CMD_CTP_RST );
	if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	unsigned short rsp[8] = {0};
	iReCode = SM_ChipBase(m_deviceNo)->IncokeCommand( CMD_MISC_TST, 0, 0, 0,(unsigned char*)rsp );
	if( iReCode != ERROR_CODE_OK ) itemNotify.UpdateItemResult( ITEM_STA_EXCEPTION, GetErrorMessage( iReCode ) );

	if((rsp[2]<<16|rsp[1]) != 0x54000000)
	{
		failerCount++;
	}

	TestResultInfoR( _T("Misc, Code = 0x%x\r\n"), rsp[2] << 16|rsp[1]);

	if( failerCount )
	{
		itemNotify.UpdateItemResult( ITEM_STA_FAIL );
		TestResultInfo( "\r\n\r\n//MISC Test is Fail\r\n", ITEM_STA_FAIL );
	}
	else
	{
		itemNotify.UpdateItemResult( ITEM_STA_PASS );
		TestResultInfo( "\r\n\r\n//MISC Test is Pass\r\n", ITEM_STA_PASS );
	}

	return itemNotify;
}
