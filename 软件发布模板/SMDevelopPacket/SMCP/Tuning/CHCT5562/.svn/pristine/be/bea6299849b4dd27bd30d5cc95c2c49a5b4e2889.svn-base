<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewModel="clr-namespace:SEMIDevelopKit.Src.WinSub"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
			<RowDefinition Height="125"></RowDefinition>
			<RowDefinition Height="285"></RowDefinition>
			<RowDefinition Height="125"></RowDefinition>
        </Grid.RowDefinitions>
		
		<GroupBox Header="8.1：补点、滤点、抖动抑制" Grid.Row="0">
			<UniformGrid Rows="2">
				<UniformGrid Columns="16">
					<Label Content="滤点" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x00" viewModel:TuningItem.ItemName="confirmTouch"></TextBox>
				</UniformGrid>
				<UniformGrid Columns="16">
					<Label Content="补点" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x00" viewModel:TuningItem.ItemName="confirmLeave"></TextBox>
				</UniformGrid>
			</UniformGrid>
		</GroupBox>
		
		<GroupBox Header="8.2：补点、滤点、抖动抑制" Grid.Row="1">			
			<UniformGrid Rows="6">
				<UniformGrid Columns="16">
					<Label Content="Edge 分界线" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x600" viewModel:TuningItem.ItemName="ms_edge_boundary"></TextBox>
				</UniformGrid>
				
				<UniformGrid Columns="16">
					<Label Content="Jitter center" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x600" viewModel:TuningItem.ItemName="ms_jitter_dist_center"></TextBox>
					<Label Content="Jitter edge" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x600" viewModel:TuningItem.ItemName="ms_jitter_dist_edge"></TextBox>
				</UniformGrid>
				
				<UniformGrid Columns="16">
					<Label Content="Jitter 面积" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x600" viewModel:TuningItem.ItemName="ms_jitter_weight"></TextBox>
					<Label Content="Jitter 面积比例%" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x600" viewModel:TuningItem.ItemName="ms_jitter_weight_ratio"></TextBox>
				</UniformGrid>
				
				<UniformGrid Columns="16">
					<Label Content="Jitter帧数" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x600" viewModel:TuningItem.ItemName="ms_jitter_shake_frame"></TextBox>
					<Label Content="Jitter比例" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x600" viewModel:TuningItem.ItemName="ms_jitter_shake_ratio"></TextBox>
				</UniformGrid>
				
				<UniformGrid Columns="16">
					<Label Content="Jitter帧平滑" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x600" viewModel:TuningItem.ItemName="ms_jitter_insert_frame"></TextBox>
				</UniformGrid>
				
				<UniformGrid Columns="16">
					<Label Content="smooth ratio" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x600" viewModel:TuningItem.ItemName="ms_smooth_ratio_center"></TextBox>
					<Label Content="smooth ratio edge" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x600" viewModel:TuningItem.ItemName="ms_smooth_ratio_edge"></TextBox>
				</UniformGrid>
			</UniformGrid>
        </GroupBox>

		<GroupBox Header="8.3：Palm Rejection" Grid.Row="2">
			<UniformGrid Rows="2">
				<UniformGrid Columns="16">
					<Label Content="疑似节点数" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x600" viewModel:TuningItem.ItemName="ms_palm_index_maybe"></TextBox>
					<Label Content="确认节点数" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x600" viewModel:TuningItem.ItemName="ms_palm_index_confirm"></TextBox>
					<Label Content="确认比例%" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x600" viewModel:TuningItem.ItemName="ms_palm_ratio"></TextBox>
				</UniformGrid>
				<UniformGrid Columns="16">
					<Label Content="过虑帧数" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x600" viewModel:TuningItem.ItemName="ms_palm_point_confirm"></TextBox>
					<Label Content="补偿帧数" HorizontalAlignment="Right" Margin="5"></Label>
					<TextBox Margin="5" viewModel:TuningItem.ItemBase="0x600" viewModel:TuningItem.ItemName="ms_palm_point_leave"></TextBox>
				</UniformGrid>
			</UniformGrid>
		</GroupBox>
    </Grid>
</UserControl>
