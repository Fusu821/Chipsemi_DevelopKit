		static bool IsSameKind( const unsigned short compared, const unsigned short compareto )
		{
			ISMChipNodeContainer* iContainer = GetContainerInterface();
		    return TRUE == iContainer->IsSameKind( compared, compareto );
		}

		static int Count( unsigned char type )
		{
			ISMChipNodeContainer* iContainer = GetContainerInterface();
			return iContainer->Count( type );
		}

		static unsigned short GetIcCodeByIndex( int index, unsigned char type )
		{
			ISMChipNodeContainer* iContainer = GetContainerInterface();
			return iContainer->GetIcCodeByIndex( index, type );
		}

		static String^ GetIcNameByIndex( int index, unsigned char type )
		{
			ISMChipNodeContainer* iContainer = GetContainerInterface();
			return gcnew String( iContainer->GetIcNameByIndex( index, type ) );
		}

		static unsigned short GetIcCode( String^ icName )
		{
			ISMChipNodeContainer* iContainer = GetContainerInterface();
			TCHAR szICName[MAX_PATH] = {0};
			for( int index = 0; index < icName->Length; index++ )
				szICName[index] = (TCHAR)icName[index];

			return iContainer->GetIcCode( szICName );
		}

		static String^ GetIcName( unsigned short icCode )
		{
			ISMChipNodeContainer* iContainer = GetContainerInterface();
			return gcnew String( iContainer->GetIcName( icCode ) );
		}

		static byte GetSubType(unsigned short icID)
		{
			ISMChipNodeContainer* iContainer = GetContainerInterface();
			return iContainer->GetSubType( icID );
		}
