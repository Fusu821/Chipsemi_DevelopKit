        public ushort Accuracy = 16;
        private ushort selectedIC = 0;
        public ushort SelectedIC
        {
            get { return selectedIC; }
            set
            {
                if (value != selectedIC)
                {
                    selectedIC = value;
                    OnPropertyChanged("SelectedIC");

                    RuningKernel.Instance().Work.AddWorkTemporary(() =>
                    {
                        RuningKernel.Instance().Work.Clear();
                        SMChipBase.SetICTypeAndCreateComponent(selectedIC);
                        CommContext ctx = new CommContext();
                        ctx.icType = selectedIC;
                        ctx.protocalType = (byte)SelectedProtocal;
                        ctx.slaveAddr = SlaveAddr;
                        ctx.i2cSpeed = I2cSpeedIndex;
                        ctx.spiMode = 0;
                        ctx.spiSpeed = SpiSpeedDivision;
                        ctx.vdd = VddVotage;
                        ctx.iovdd = IoVddVotage;
                        ctx.vih = VIHVotage;
                        SMChipBase.SetCommContext(ctx);
                        Application.Current.Dispatcher.BeginInvoke(new Action(() =>
                        {
                            view.rawdataframe.Navigate(SMDevelopChipReflex.Instance.GetSemiModuleByChipAndType(SMDevelopChipReflex.SEMI_DEVLOP_RAWDATA, selectedIC));
                            foreach (var item in ModeCatch.GetListModes(SelectedIC))
                            {
                                MethodInfo info = item.GetType().GetMethod("ActionOnICChanged");
                                if (null != info)
                                {
                                    info.Invoke(item, null);
                                }
                            }

                            foreach(Xceed.Wpf.AvalonDock.Layout.LayoutAnchorable child in view.AnchorPane.Children)
                            {
                                var frame = child.Content as Frame;
                                if (null == frame.Content) continue;
                                MethodInfo info = frame.Content.GetType().GetMethod("ActionOnICChanged");
                                if (null != info)
                                {
                                    info.Invoke(frame.Content, null);
                                }
                            }
                        })); 
                    });
                }
            }
        }

