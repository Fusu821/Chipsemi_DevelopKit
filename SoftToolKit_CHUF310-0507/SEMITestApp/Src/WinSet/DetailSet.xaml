<Page x:Class="SEMITestApp.Src.WinSet.DetailSet"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SEMITestApp.Src.WinSet"
      xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"    
      mc:Ignorable="d" 
      KeepAlive="True"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DetailSet" IsVisibleChanged="Detail_IsVisibleChanged">

    <ScrollViewer VerticalScrollBarVisibility="Visible">
        <Grid Height="1200">
            <Grid.RowDefinitions>
                <RowDefinition Height="850" ></RowDefinition>
                <RowDefinition Height="200"></RowDefinition>
                <RowDefinition Height="*" ></RowDefinition>
            </Grid.RowDefinitions>
            <TabControl x:Name="tabDetails" TabStripPlacement="Left" BorderBrush="{DynamicResource AccentColorBrush}" BorderThickness="1" Margin="7,3,3,36" SelectedItem ="{Binding CurSelItem}"> </TabControl>
            <GroupBox Header="Import" Grid.Row="1" Margin="5,5,5,12">
                <StackPanel Orientation="Vertical">
                    <WrapPanel Orientation="Horizontal">
                        <TextBox Controls:TextBoxHelper.Watermark="Please Select Sample Folder!" Text="{Binding SelectedFolder}" Margin="5" Width="400"></TextBox>
                        <Button Content="Import" Width="100" Margin="5">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="Click">
                                    <i:InvokeCommandAction Command="{Binding ctrlClickCommand}" CommandParameter="detail-import-click"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Button>
                        <Label Content="Kick out" Margin="5"></Label>
                        <TextBox Margin="1, 5" Text="{Binding AnalyzeRatio}" TextAlignment="Right" Width="50"></TextBox>
                        <Label Content="%" Margin="0,5"></Label>
                        <Button Content="十" Width="45" Margin="5" FontWeight="Bold" Focusable="False">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="Click">
                                    <i:InvokeCommandAction Command="{Binding ctrlClickCommand}" CommandParameter="detail-add-click"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Button>
                        <Button Content="一" Width="45" Margin="5" FontWeight="Bold" Focusable="False">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="Click">
                                    <i:InvokeCommandAction Command="{Binding ctrlClickCommand}" CommandParameter="detail-dec-click"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Button>
                        <TextBox Margin="1, 5" Text="{Binding SetValue}" TextAlignment="Right" Width="50"></TextBox>
                        <Button Content="set" Width="45" Margin="5" FontWeight="Bold" Focusable="False">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="Click">
                                    <i:InvokeCommandAction Command="{Binding ctrlClickCommand}" CommandParameter="detail-set-click"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Button>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Margin="5" Text="{Binding AnalyzeResultText}" TextWrapping="Wrap" Width="513" Foreground="Blue"></TextBlock>
                        <CheckBox Content="Base" IsChecked="{Binding RefreshBase}" Margin="5" Name="chkBase"></CheckBox>
                        <CheckBox Content="Threshold" IsChecked="{Binding GenThreshold}" Margin="5" Name="chkThr"></CheckBox>
                        <CheckBox Content="Simulate" IsChecked="{Binding Simulate}" Margin="5"></CheckBox>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Margin="5" Width="513" Foreground="Blue" Visibility="Hidden"></TextBlock>
                        <Label Margin="5" Visibility="{Binding ElementName=chkThr,Path=IsChecked, Converter={StaticResource CheckToVisibleConverter}}" Content="Th-Bias"></Label> 
                        <TextBox Text="{Binding ThresholdCof}" Width="50" Margin="1,5,0,5" Visibility="{Binding ElementName=chkThr,Path=IsChecked, Converter={StaticResource CheckToVisibleConverter}}"></TextBox>
                        <Label Margin="5" Content="%" Visibility="{Binding ElementName=chkThr,Path=IsChecked, Converter={StaticResource CheckToVisibleConverter}}"></Label>
                    </WrapPanel>
                    <Controls:MetroProgressBar  Maximum="100" Value="{Binding AnalyzeProcessVal}"  Foreground="Blue"></Controls:MetroProgressBar>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Hist" Name="grpHist" Grid.Row="2">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <UniformGrid x:Name="uiniGridHist"></UniformGrid>
                </ScrollViewer>
            </GroupBox>
        </Grid>
    </ScrollViewer> 
</Page>
