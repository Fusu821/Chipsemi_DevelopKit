class CChipNodeContainer : public ISMChipNodeContainer
{
public:
	int Count( unsigned char type = 0xff )
	{ 
		if( 0xff == type ) return arraycount(arrayNode);

		int iCount = 0;
		for( int index = 0; index < arraycount(arrayNode); ++index )
		{
			if( type == arrayNode[index].chipType )
				++iCount;
		}
		return iCount;
	}
	LPCTSTR GetIcName( unsigned short IcCode )
	{
		for( int index = 0; index < Count(); ++index )
			if( IcCode == arrayNode[index].chipId ) 
				return arrayNode[index].chipName;
		return NULL;
	}
	LPCTSTR GetIcNameByIndex( int index, unsigned char type = 0xff )
	{
		int match = -1;
		for( int iter = 0; iter < arraycount(arrayNode); ++iter )
		{
            if( type & arrayNode[iter].chipType )
				++match;
			if( match == index ) return arrayNode[iter].chipName;
		}
		return NULL;
	} 
	unsigned short GetIcCode( LPCTSTR strIcName )
	{
		for( int index = 0; index < Count(); ++index )
			if( 0 == icomparetext( strIcName, arrayNode[index].chipName ) ) 
				return arrayNode[index].chipId;
		return 0;
	}
	unsigned short GetIcCodeByIndex( int index, unsigned char type = 0xff )
	{
		int match = -1;
		for( int iter = 0; iter < arraycount(arrayNode); ++iter )
		{
			if( type & arrayNode[iter].chipType )
				++match;
			if( match == index ) return arrayNode[iter].chipId;
		}
		return 0;
	}
	unsigned char GetChipFamily( unsigned short icID )
	{
		for( int index = 0; index < arraycount(arrayNode); index++ )
		{
			if( arrayNode[index].chipId == icID )
			{
				return arrayNode[index].chipFamily;
			}
		}

		return 0;
	}
// 	LPCTSTR GetIcPrambootName( unsigned short IcCode )
// 	{
// 		for( int index = 0; index < Count(); ++index )
// 			if( IcCode == arrayNode[index].chipId ) 
// 				return arrayNode[index].pramMapping;
// 		return NULL;
// 	}
	unsigned char GetSubType( LPCTSTR strIcName )
	{
		unsigned char ucChipType = 0;
		for( int index = 0; index < Count(); ++index )
		{
			if( 0 == icomparetext( strIcName, arrayNode[index].chipName ) ) 
			{
				return arrayNode[index].chipType;
			}
		}
	
		return 0;
	}
	unsigned char GetSubType( unsigned short icID )
	{
		unsigned char ucChipType = 0;
		for( int index = 0; index < Count(); ++index )
		{
			if( icID == arrayNode[index].chipId ) 
			{
				return arrayNode[index].chipType;
			}
		}

		return 0;
	}
	BOOL IsSameKind( const unsigned short compared, const unsigned short compareto )
	{
		return (compared & 0xff00) == (compareto & 0xff00);
	}
};

ISMChipNodeContainer* GetContainerInterface()
{
    static CChipNodeContainer contain;
	return &contain;
}