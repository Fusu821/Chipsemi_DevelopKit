<Page x:Class="SEMITestApp.Src.WinSub.MutiplePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SEMITestApp.Src.WinSub"
      xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MutiplePage">

    <TabControl Margin="0, 0, 0, 0" Padding="0,0,0,0">
        <TabItem Header="List" Style="{DynamicResource TabItemStyle}" Height="20">
            <!--ListBox>
                <ContentControl DockPanel.Dock="Left" x:Name="tester1" Grid.Row="0" Grid.Column="0" Template="{StaticResource MultiOneTemplate}"></ContentControl>
                <ContentControl DockPanel.Dock="Left" x:Name="tester3" Grid.Row="0" Grid.Column="0" Template="{StaticResource MultiOneTemplate}"></ContentControl>
                <ContentControl DockPanel.Dock="Left" x:Name="tester2" Grid.Row="0" Grid.Column="0" Template="{StaticResource MultiOneTemplate}"></ContentControl>
            </-->
            <UniformGrid Rows="1" Columns="{Binding ElementName=tester1, Path=Tag}">
                <ContentControl x:Name="tester1" Grid.Row="0" Grid.Column="0" Template="{StaticResource MultiOneTemplate}" Tag="{Binding TestMode}"></ContentControl>
                <ContentControl x:Name="tester2" Grid.Row="0" Grid.Column="1" Template="{StaticResource MultiOneTemplate}" Visibility="{Binding TestMode, Converter={StaticResource ModeToVisibleConverter}, ConverterParameter=2}"></ContentControl>
                <ContentControl x:Name="tester3" Grid.Row="0" Grid.Column="2" Template="{StaticResource MultiOneTemplate}" Visibility="{Binding TestMode, Converter={StaticResource ModeToVisibleConverter}, ConverterParameter=3}"></ContentControl>
                <ContentControl x:Name="tester4" Grid.Row="0" Grid.Column="3" Template="{StaticResource MultiOneTemplate}" Visibility="{Binding TestMode, Converter={StaticResource ModeToVisibleConverter}, ConverterParameter=4}"></ContentControl>
                <ContentControl x:Name="tester5" Grid.Row="0" Grid.Column="4" Template="{StaticResource MultiOneTemplate}" Visibility="{Binding TestMode, Converter={StaticResource ModeToVisibleConverter}, ConverterParameter=5}"></ContentControl>
                <ContentControl x:Name="tester6" Grid.Row="0" Grid.Column="5" Template="{StaticResource MultiOneTemplate}" Visibility="{Binding TestMode, Converter={StaticResource ModeToVisibleConverter}, ConverterParameter=6}"></ContentControl>
                <ContentControl x:Name="tester7" Grid.Row="0" Grid.Column="6" Template="{StaticResource MultiOneTemplate}" Visibility="{Binding TestMode, Converter={StaticResource ModeToVisibleConverter}, ConverterParameter=7}"></ContentControl>
                <ContentControl x:Name="tester8" Grid.Row="0" Grid.Column="7" Template="{StaticResource MultiOneTemplate}" Visibility="{Binding TestMode, Converter={StaticResource ModeToVisibleConverter}, ConverterParameter=8}"></ContentControl>
                
            </UniformGrid>
            <!--Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="{Binding ElementName=tester3, Path=Tag}"></ColumnDefinition>
                    <ColumnDefinition Width="{Binding ElementName=tester4, Path=Tag}" ></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <ContentControl x:Name="tester1" Grid.Row="0" Grid.Column="0" Tag="{Binding test}" Template="{StaticResource MultiOneTemplate}"></ContentControl>
                <ContentControl x:Name="tester2" Grid.Row="0" Grid.Column="1" Template="{StaticResource MultiOneTemplate}"></ContentControl>
                <ContentControl x:Name="tester3" Grid.Row="0" Grid.Column="2" Width="{Binding TestMode, Converter={StaticResource ModeToWidthConverter}, ConverterParameter=3}" Template="{StaticResource MultiOneTemplate}"></ContentControl>
                <ContentControl x:Name="tester4" Grid.Row="0" Grid.Column="3" Width="{Binding TestMode, Converter={StaticResource ModeToWidthConverter}, ConverterParameter=4}"  Template="{StaticResource MultiOneTemplate}"></ContentControl>
            </-->
        </TabItem>
        <TabItem Header="Message" Style="{DynamicResource TabItemStyle}" Height="20" Margin="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="110"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <RichTextBox x:Name="testMessage"  Grid.Column="0" VerticalScrollBarVisibility="Auto"></RichTextBox>
                <StackPanel Grid.Column="1">
                    <TextBlock Margin="10, 0, 10, 0" Text="DeviceNo:"></TextBlock>
                    <ComboBox Margin="10, 2, 10, 10" SelectedIndex="0" SelectionChanged="CbxDeviceItem_SelectionChanged">
                        <ComboBoxItem Content="#1" />
                        <ComboBoxItem Content="#2" />
                        <ComboBoxItem Content="#3" />
                        <ComboBoxItem Content="#4" />
                        <ComboBoxItem Content="#5" />
                        <ComboBoxItem Content="#6" />
                        <ComboBoxItem Content="#7" />
                        <ComboBoxItem Content="#8" />
                    </ComboBox>
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
</Page>
