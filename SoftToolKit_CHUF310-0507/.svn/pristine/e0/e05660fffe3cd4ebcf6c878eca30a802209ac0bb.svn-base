        private bool filterOff = false;
        public bool FilterOff
        {
            get { return filterOff; }
            set
            {
                if (value != filterOff)
                {
                    filterOff = value;
                    OnPropertyChanged("FilterOff");

                    var mdBase = ModeCatch.GetModeByIdAndICType(SMDevelopChipReflex.SEMI_DEVLOP_RAWDATA, MainViewModel.Intr.SelectedIC) as ModelBase;
                    if (null != mdBase)
                        RuningKernel.Instance().Work.AddWorkTemporary(new Action(mdBase.SwitchModeEx));
                }
            }
        }

        private bool notReset = false;
        public bool NotReset
        {
            get { return notReset; }
            set
            {
                if (value != notReset)
                {
                    notReset = value;
                    OnPropertyChanged("NotReset");
                }
            }
        }

        private uint directAddr = 0x0000;
        public uint DirectAddr
        {
            get { return directAddr; }
            set { if (value != directAddr) { directAddr = value; OnPropertyChanged("DirectAddr"); } }
        }

        private uint directValue = 0x0000;
        public uint DirectValue
        {
            get { return directValue; }
            set { if (value != directValue) { directValue = value; OnPropertyChanged("DirectValue"); } }
        }

        private uint dedicateAddr = 0x0000;
        public uint DedicateAddr
        {
            get { return dedicateAddr; }
            set { if (value != dedicateAddr) { dedicateAddr = value; OnPropertyChanged("DedicateAddr"); } }
        }

        private uint dedicateValue = 0x0000;
        public uint DedicateValue
        {
            get { return dedicateValue; }
            set { if (value != dedicateValue) { dedicateValue = value; OnPropertyChanged("DedicateValue"); } }
        }

        private ushort workClk = 0;
        public ushort WorkClk
        {
            get { return workClk; }
            set
            {
                bool userUpdate = workClk > 0 ? true : false;
                if (value != workClk)
                {
                    workClk = value;
                    OnPropertyChanged("WorkClk");

                    if (userUpdate)
                    {
                        var mdBase = ModeCatch.GetModeByIdAndICType(SMDevelopChipReflex.SEMI_DEVLOP_RAWDATA, MainViewModel.Intr.SelectedIC) as ModelBase;
                        if (null != mdBase)
                            RuningKernel.Instance().Work.AddWorkTemporary(new Action(mdBase.SwitchModeEx));
                    }
                } 
            }
        }

        private ushort vihVotage = 1800;
        public ushort VIHVotage
        {
            get { return vihVotage; }
            set 
            { 
                if (value != vihVotage)
                { 
                    vihVotage = value; OnPropertyChanged("VIHVotage");
                    RuningKernel.Instance().Work.AddWorkTemporary(() =>
                    {
                        SMCommBase.SetIoVoltage(VddVotage, IoVddVotage, VIHVotage);
                    });
                } 
            }
        }

        private string textScriptIn = "";
        public string TextScriptIn
        {
            get { return textScriptIn; }
            set { textScriptIn = value; OnPropertyChanged("TextScriptIn"); }
        }

        private string textScriptOut = "";
        public string TextScriptOut
        {
            get { return textScriptOut; }
            set { if (value != textScriptOut) { textScriptOut = value; OnPropertyChanged("TextScriptOut"); } }
        }

        public override void OnCtrlClickCommand(object param)
        {
            string strParam = param as string;
            if (null == strParam) return;

            if ("direct-write-click" == strParam)
            {
                RuningKernel.Instance().Work.AddWorkTemporary(() =>
                {
                    MainViewModel.Intr.ReturnCode = SMChipBase.HalAccessMode(0);
                    if (0 == MainViewModel.Intr.ReturnCode)
                    {
                        MainViewModel.Intr.ReturnCode = SMChipBase.WriteRegister( DirectAddr, DirectValue );
                    }
                });
            }
            else if ("direct-read-click" == strParam)
            {
                RuningKernel.Instance().Work.AddWorkTemporary(() =>
                {
                    MainViewModel.Intr.ReturnCode = SMChipBase.HalAccessMode(0);
                    if (0 == MainViewModel.Intr.ReturnCode)
                    {
                        uint readVal = 0;
                        MainViewModel.Intr.ReturnCode = SMChipBase.ReadRegister(DirectAddr, ref readVal);
                        DirectValue = readVal;
                    }
                });
            }
            else if ("dedicate-write-click" == strParam)
            {
                RuningKernel.Instance().Work.AddWorkTemporary(() =>
                {
                    MainViewModel.Intr.ReturnCode = SMChipBase.HalAccessMode(1);
                    if (0 == MainViewModel.Intr.ReturnCode)
                    {
                        MainViewModel.Intr.ReturnCode = SMChipBase.WriteRegister(DedicateAddr, DedicateValue);
                    }
                });
            }
            else if ("dedicate-read-click" == strParam)
            {
                RuningKernel.Instance().Work.AddWorkTemporary(() =>
                {
                    MainViewModel.Intr.ReturnCode = SMChipBase.HalAccessMode(0);
                    if (0 == MainViewModel.Intr.ReturnCode)
                    {
                        uint readVal = 0;
                        MainViewModel.Intr.ReturnCode = SMChipBase.ReadRegister(DedicateAddr, ref readVal);
                        DedicateValue = readVal;
                    }
                });
            }
            else if ("script-all-click" == strParam)
            {
                RuningKernel.Instance().Work.AddWorkTemporary(() =>
                {
                    TextScriptOut = "";
                    string[] vecCommmand = System.Text.RegularExpressions.Regex.Split(textScriptIn, "\r\n", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                    List<string> lsCommandLoop = new List<string>();
                    bool loopTriger = false;
                    uint loopCount = 0, ret = 0;
                    string commandResult = "";

                    foreach (var commnad in vecCommmand)
                    {
                        if (commnad.Contains("endloop"))
                        {
                            loopTriger = false;
                            for (int index = 0; index < loopCount; index++)
                            {
                                foreach (var cmd in lsCommandLoop)
                                {
                                    ret = IOCommand.DoCommand(cmd, ref commandResult);
                                    TextScriptOut = TextScriptOut + commandResult;

                                    if (ret > 0) return;
                                }
                            }
                            continue;
                        }
                        else if (commnad.Contains("loop"))
                        {
                            loopTriger = true;
                            loopCount = uint.Parse(commnad.Replace("loop", "").Trim());
                            continue;
                        }

                        if (loopTriger)
                        {
                            lsCommandLoop.Add(commnad);
                            continue;
                        }

                        ret = IOCommand.DoCommand(commnad, ref commandResult);
                        TextScriptOut = TextScriptOut + commandResult;
                        

                        if (ret > 0) return;
                    }
                });
            }
            else if ("script-clp-click" == strParam)
            {
                string strText = Clipboard.GetText();
                TextScriptOut = "";
                string[] vecCommmand = strText.Split("\r\n".ToCharArray());

                foreach (var commnad in vecCommmand)
                {
                    string commandResult = "";
                    uint ret = IOCommand.DoCommand(commnad, ref commandResult);
                    TextScriptOut = TextScriptOut + commandResult;

                    if (ret > 0) break;
                }
            }
            else if ("short-cut-click" == strParam)
            {
                view.ShowFlyout(this);
            }
        }

    }

}
