struct ChipNode 
{
#define CHIP_NAME_LENGTH 20
#define PRAM_NAME_LENGTH 100
	unsigned char chipType;
	unsigned char chipFamily;
	unsigned short chipId;
	TCHAR chipName[CHIP_NAME_LENGTH];
	TCHAR pramMapping[PRAM_NAME_LENGTH];
	ChipNode( unsigned short id, LPCTSTR name, unsigned char ictype, unsigned char family, LPCTSTR pramName = NULL )
		:chipId(id)
		,chipType(ictype)
		,chipFamily(family)
	{
		memset( chipName, 0, sizeof(chipName) );
		copytextto( chipName, name, lengthof(name) );
		memset( pramMapping, 0, sizeof(pramMapping) );
		if(pramName) copytextto( pramMapping, pramName, lengthof(pramName) );
	}
};

